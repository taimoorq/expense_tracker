<%= turbo_frame_tag "pay_schedules_section" do %>
  <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h3 class="mb-3 text-lg font-semibold">1) Paycheck Schedules</h3>
    <%= form_with model: pay_schedule, url: pay_schedules_path, class: "grid gap-2 sm:grid-cols-2 lg:grid-cols-5" do |form| %>
      <%= hidden_field_tag :budget_month_id, budget_month.id %>
      <%= form.text_field :name, placeholder: "Employer/Source", required: true, class: "fb-input" %>
      <%= form.select :cadence, PaySchedule.cadences.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
      <%= form.number_field :amount, step: 0.01, placeholder: "Amount", required: true, class: "fb-input" %>
      <%= form.date_field :first_pay_on, required: true, class: "fb-input" %>
      <%= form.number_field :day_of_month_one, placeholder: "Day #1", class: "fb-input" %>
      <%= form.number_field :day_of_month_two, placeholder: "Day #2", class: "fb-input" %>
      <%= form.select :weekend_adjustment, PaySchedule.weekend_adjustments.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
      <%= form.text_field :account, placeholder: "Account", class: "fb-input" %>
      <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
      <%= form.submit "Save Schedule", class: "fb-btn-primary" %>
    <% end %>

    <div class="mt-3">
      <%= button_to "Add Paychecks to #{budget_month.label}", generate_paychecks_budget_month_path(budget_month), method: :post, class: "rounded-md bg-slate-800 px-3 py-2 text-white hover:bg-slate-700" %>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Name</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Cadence</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Amount</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Weekend Rule</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% pay_schedules.each do |schedule| %>
            <tr>
              <td class="px-3 py-2"><%= schedule.name %></td>
              <td class="px-3 py-2"><%= schedule.cadence.humanize %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(schedule.amount) %></td>
              <td class="px-3 py-2"><%= schedule.weekend_adjustment.humanize %></td>
              <td class="px-3 py-2">
                <%= button_to "Delete", pay_schedule_path(schedule, budget_month_id: budget_month.id), method: :delete, class: "rounded-md border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this schedule?" } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
