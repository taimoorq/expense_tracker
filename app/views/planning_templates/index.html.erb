<div class="space-y-6">
  <% content_for :page_header do %>
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-2xl font-semibold">Planning Templates</h2>
      <%= link_to root_path, class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Back to Months</span>
      <% end %>
    </div>
  <% end %>

  <section id="pay-schedules" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="text-lg font-semibold">Paycheck Schedules</h3>
      <button type="button" class="ta-icon-btn" aria-label="Paycheck Schedules Help" title="Paycheck Schedules Help" data-action="click->help-modal#open" data-help-title="Paycheck Schedules Help" data-help-body="Use this to define recurring income.

Cadence: weekly, biweekly, semimonthly, or monthly.
First Pay On: anchor date for recurrence.
    Day #1 and Day #2: used for semimonthly schedules.
    Weekend adjustment: move pay date when it falls on weekend."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">Template only. Generated into each month using the month action buttons.</p>
    <% if @pay_schedule.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= @pay_schedule.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "pay-schedules"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <%= form_with model: @pay_schedule, local: true, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-5" do |form| %>
      <%= hidden_field_tag :return_to, planning_templates_path(anchor: "pay-schedules") %>
      <div>
        <%= form.label :name, "Employer / Source", class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Employer/Source", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :cadence, class: "fb-label" %>
        <%= form.select :cadence, PaySchedule.cadences.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
        <p class="mt-1 text-xs text-slate-500">Choose how often this income repeats.</p>
      </div>
      <div>
        <%= form.label :amount, class: "fb-label" %>
        <%= form.number_field :amount, step: 0.01, placeholder: "0.00", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Expected amount for each deposit.</p>
      </div>
      <div>
        <%= form.label :first_pay_on, "First Pay On", class: "fb-label" %>
        <%= form.date_field :first_pay_on, required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Use the first known payday to anchor the schedule.</p>
      </div>
      <div>
        <%= form.label :day_of_month_one, "Day #1", class: "fb-label" %>
        <%= form.number_field :day_of_month_one, min: 1, max: 31, placeholder: "15", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Used for semimonthly schedules.</p>
      </div>
      <div>
        <%= form.label :day_of_month_two, "Day #2", class: "fb-label" %>
        <%= form.number_field :day_of_month_two, min: 1, max: 31, placeholder: "30", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Optional second semimonthly payday.</p>
      </div>
      <div>
        <%= form.label :weekend_adjustment, class: "fb-label" %>
        <%= form.select :weekend_adjustment, PaySchedule.weekend_adjustments.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
        <p class="mt-1 text-xs text-slate-500">Adjusts paydays that fall on weekends.</p>
      </div>
      <div>
        <%= form.label :account, class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Checking", class: "fb-input" %>
      </div>
      <div class="flex items-end">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
      </div>
      <div class="flex items-end">
        <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon(@pay_schedule.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
          <span><%= @pay_schedule.persisted? ? "Update Schedule" : "Save Schedule" %></span>
        <% end %>
      </div>
    <% end %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50"><tr><th class="px-3 py-2 text-left">Name</th><th class="px-3 py-2 text-left">Cadence</th><th class="px-3 py-2 text-right">Amount</th><th class="px-3 py-2 text-left">Action</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <% @pay_schedules.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2"><%= item.cadence.humanize %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.amount) %></td>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <%= link_to planning_templates_path(edit_pay_schedule_id: item.id, anchor: "pay-schedules"),
                              class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                              title: "Edit schedule",
                              aria: { label: "Edit schedule" } do %>
                    <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                  <% end %>
                  <%= button_to pay_schedule_path(item, return_to: planning_templates_path),
                                method: :delete,
                                class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                title: "Delete schedule",
                                aria: { label: "Delete schedule" },
                                form: { data: { turbo_confirm: "Delete this schedule?" } } do %>
                    <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section id="subscriptions" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="text-lg font-semibold">Subscriptions</h3>
      <button type="button" class="ta-icon-btn" aria-label="Subscriptions Help" title="Subscriptions Help" data-action="click->help-modal#open" data-help-title="Subscriptions Help" data-help-body="For recurring monthly items with no fixed end date.

Amount: expected monthly amount.
Due day: day of month this usually charges.
    Keep Active checked unless this subscription has been cancelled."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">Use for Netflix, phone plans, cloud storage, and other recurring charges.</p>
    <% if @subscription.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= @subscription.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "subscriptions"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <%= form_with model: @subscription, local: true, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-6" do |form| %>
      <%= hidden_field_tag :return_to, planning_templates_path(anchor: "subscriptions") %>
      <div>
        <%= form.label :name, class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Netflix, Google Fi...", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :amount, class: "fb-label" %>
        <%= form.number_field :amount, step: 0.01, placeholder: "0.00", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Expected monthly charge before any taxes or fees change.</p>
      </div>
      <div>
        <%= form.label :due_day, "Due Day", class: "fb-label" %>
        <%= form.number_field :due_day, min: 1, max: 31, placeholder: "1", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Day of the month this usually charges.</p>
      </div>
      <div>
        <%= form.label :account, class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Credit Card", class: "fb-input" %>
      </div>
      <div>
        <%= form.label :notes, class: "fb-label" %>
        <%= form.text_field :notes, placeholder: "Optional notes", class: "fb-input" %>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon(@subscription.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
          <span><%= @subscription.persisted? ? "Update Subscription" : "Save" %></span>
        <% end %>
      </div>
    <% end %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50"><tr><th class="px-3 py-2 text-left">Name</th><th class="px-3 py-2 text-right">Amount</th><th class="px-3 py-2 text-right">Due Day</th><th class="px-3 py-2 text-left">Action</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <% @subscriptions.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.amount) %></td>
              <td class="px-3 py-2 text-right"><%= item.due_day %></td>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <%= link_to planning_templates_path(edit_subscription_id: item.id, anchor: "subscriptions"),
                              class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                              title: "Edit subscription",
                              aria: { label: "Edit subscription" } do %>
                    <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                  <% end %>
                  <%= button_to subscription_path(item, return_to: planning_templates_path),
                                method: :delete,
                                class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                title: "Delete subscription",
                                aria: { label: "Delete subscription" },
                                form: { data: { turbo_confirm: "Delete this subscription?" } } do %>
                    <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section id="monthly-bills" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="text-lg font-semibold">Monthly Bills (fixed + variable)</h3>
      <button type="button" class="ta-icon-btn" aria-label="Monthly Bills Help" title="Monthly Bills Help" data-action="click->help-modal#open" data-help-title="Monthly Bills Help" data-help-body="Fixed Payment: stable bills like mortgage or car payment.
Variable Bill: amounts that vary monthly like utilities.

    Default amount is your estimate and can be adjusted later in the month entries."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">These are turned into planned month entries when you run generation.</p>
    <% if @monthly_bill.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= @monthly_bill.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "monthly-bills"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <%= form_with model: @monthly_bill, local: true, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-6" do |form| %>
      <%= hidden_field_tag :return_to, planning_templates_path(anchor: "monthly-bills") %>
      <div>
        <%= form.label :name, class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Mortgage, Pepco, Car payment...", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :kind, "Bill Type", class: "fb-label" %>
        <%= form.select :kind, MonthlyBill.kinds.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
        <p class="mt-1 text-xs text-slate-500">Use fixed for stable bills and variable for changing totals.</p>
      </div>
      <div>
        <%= form.label :default_amount, "Default Amount", class: "fb-label" %>
        <%= form.number_field :default_amount, step: 0.01, placeholder: "0.00", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Starting estimate used when a month is generated.</p>
      </div>
      <div>
        <%= form.label :due_day, "Due Day", class: "fb-label" %>
        <%= form.number_field :due_day, min: 1, max: 31, placeholder: "1", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Day of the month the bill is usually due.</p>
      </div>
      <div>
        <%= form.label :account, class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Checking", class: "fb-input" %>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon(@monthly_bill.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
          <span><%= @monthly_bill.persisted? ? "Update Monthly Bill" : "Save" %></span>
        <% end %>
      </div>
    <% end %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50"><tr><th class="px-3 py-2 text-left">Name</th><th class="px-3 py-2 text-left">Type</th><th class="px-3 py-2 text-right">Default</th><th class="px-3 py-2 text-left">Action</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <% @monthly_bills.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2"><%= item.kind.humanize %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.default_amount || 0) %></td>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <%= link_to planning_templates_path(edit_monthly_bill_id: item.id, anchor: "monthly-bills"),
                              class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                              title: "Edit monthly bill",
                              aria: { label: "Edit monthly bill" } do %>
                    <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                  <% end %>
                  <%= button_to monthly_bill_path(item, return_to: planning_templates_path),
                                method: :delete,
                                class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                title: "Delete monthly bill",
                                aria: { label: "Delete monthly bill" },
                                form: { data: { turbo_confirm: "Delete this bill?" } } do %>
                    <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section id="payment-plans" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="text-lg font-semibold">Payment Plans</h3>
      <button type="button" class="ta-icon-btn" aria-label="Payment Plans Help" title="Payment Plans Help" data-action="click->help-modal#open" data-help-title="Payment Plans Help" data-help-body="Use for balances you are paying down over time.

Total Due: full balance.
Amount Paid: how much already paid so far.
Custom Monthly: optional planned monthly payment amount.
    The app caps generated payment to remaining balance."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">Great for tax plans, financing, and installment balances.</p>
    <% if @payment_plan.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= @payment_plan.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "payment-plans"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <%= form_with model: @payment_plan, local: true, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-7" do |form| %>
      <%= hidden_field_tag :return_to, planning_templates_path(anchor: "payment-plans") %>
      <div>
        <%= form.label :name, class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Plan name", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :total_due, "Total Due", class: "fb-label" %>
        <%= form.number_field :total_due, step: 0.01, placeholder: "0.00", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Full balance still assigned to this plan.</p>
      </div>
      <div>
        <%= form.label :amount_paid, "Amount Paid", class: "fb-label" %>
        <%= form.number_field :amount_paid, step: 0.01, placeholder: "0.00", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">How much has already been paid toward the balance.</p>
      </div>
      <div>
        <%= form.label :monthly_target, "Monthly Target", class: "fb-label" %>
        <%= form.number_field :monthly_target, step: 0.01, placeholder: "0.00", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Optional custom payment amount to plan each month.</p>
      </div>
      <div>
        <%= form.label :due_day, "Due Day", class: "fb-label" %>
        <%= form.number_field :due_day, min: 1, max: 31, placeholder: "1", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :account, class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Checking", class: "fb-input" %>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon(@payment_plan.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
          <span><%= @payment_plan.persisted? ? "Update Payment Plan" : "Save" %></span>
        <% end %>
      </div>
    <% end %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50"><tr><th class="px-3 py-2 text-left">Name</th><th class="px-3 py-2 text-right">Total Due</th><th class="px-3 py-2 text-right">Remaining</th><th class="px-3 py-2 text-left">Action</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <% @payment_plans.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.total_due) %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.remaining_balance) %></td>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <%= link_to planning_templates_path(edit_payment_plan_id: item.id, anchor: "payment-plans"),
                              class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                              title: "Edit payment plan",
                              aria: { label: "Edit payment plan" } do %>
                    <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                  <% end %>
                  <%= button_to payment_plan_path(item, return_to: planning_templates_path),
                                method: :delete,
                                class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                title: "Delete payment plan",
                                aria: { label: "Delete payment plan" },
                                form: { data: { turbo_confirm: "Delete this plan?" } } do %>
                    <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section id="credit-cards" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="text-lg font-semibold">Credit Cards</h3>
      <button type="button" class="ta-icon-btn" aria-label="Credit Cards Help" title="Credit Cards Help" data-action="click->help-modal#open" data-help-title="Credit Cards Help" data-help-body="Used by 'Estimate Cards' in month view.

Minimum: minimum amount to prioritize first.
Priority: lower number gets allocated first.
    After minimums, leftover can be spread across cards."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">These settings drive automatic estimated card payments from leftover cash.</p>
    <% if @credit_card.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= @credit_card.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "credit-cards"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <%= form_with model: @credit_card, local: true, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-5" do |form| %>
      <%= hidden_field_tag :return_to, planning_templates_path(anchor: "credit-cards") %>
      <div>
        <%= form.label :name, "Card Name", class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Card name", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :minimum_payment, "Minimum Payment", class: "fb-label" %>
        <%= form.number_field :minimum_payment, step: 0.01, placeholder: "0.00", class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Minimum amount this card should receive first.</p>
      </div>
      <div>
        <%= form.label :priority, class: "fb-label" %>
        <%= form.number_field :priority, min: 1, placeholder: "1", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Lower numbers are paid before higher priority values.</p>
      </div>
      <div>
        <%= form.label :account, class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Credit Card", class: "fb-input" %>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon(@credit_card.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
          <span><%= @credit_card.persisted? ? "Update Credit Card" : "Save" %></span>
        <% end %>
      </div>
    <% end %>
    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50"><tr><th class="px-3 py-2 text-left">Card</th><th class="px-3 py-2 text-right">Minimum</th><th class="px-3 py-2 text-right">Priority</th><th class="px-3 py-2 text-left">Action</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          <% @credit_cards.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.minimum_payment) %></td>
              <td class="px-3 py-2 text-right"><%= item.priority %></td>
              <td class="px-3 py-2">
                <div class="flex items-center gap-2">
                  <%= link_to planning_templates_path(edit_credit_card_id: item.id, anchor: "credit-cards"),
                              class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                              title: "Edit card",
                              aria: { label: "Edit card" } do %>
                    <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                  <% end %>
                  <%= button_to credit_card_path(item, return_to: planning_templates_path),
                                method: :delete,
                                class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                title: "Delete card",
                                aria: { label: "Delete card" },
                                form: { data: { turbo_confirm: "Delete this card?" } } do %>
                    <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
