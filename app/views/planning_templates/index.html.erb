<% recurring_groups = [
  {
    label: "Pay Schedules",
    anchor: "pay-schedules",
    icon: "cash",
    icon_classes: "text-emerald-600",
    records: @pay_schedules,
    active_count: @pay_schedules.filter { |record| record.active_on?(Date.current) }.size,
    linked_count: @pay_schedules.filter { |record| record.try(:linked_account_id).present? || record.try(:payment_account_id).present? }.size,
    description: "Income that should appear in future months.",
    empty_hint: "Start here if paychecks are predictable."
  },
  {
    label: "Subscriptions",
    anchor: "subscriptions",
    icon: "repeat",
    icon_classes: "text-indigo-600",
    records: @subscriptions,
    active_count: @subscriptions.filter(&:active?).size,
    linked_count: @subscriptions.filter { |record| record.try(:linked_account_id).present? || record.try(:payment_account_id).present? }.size,
    description: "Recurring services and memberships.",
    empty_hint: "Save recurring services and memberships."
  },
  {
    label: "Monthly Bills",
    anchor: "monthly-bills",
    icon: "cash",
    icon_classes: "text-sky-600",
    records: @monthly_bills,
    active_count: @monthly_bills.filter(&:active?).size,
    linked_count: @monthly_bills.filter { |record| record.try(:linked_account_id).present? || record.try(:payment_account_id).present? }.size,
    description: "Fixed or variable bills by month.",
    empty_hint: "Add rent, utilities, insurance, or other bills."
  },
  {
    label: "Payment Plans",
    anchor: "payment-plans",
    icon: "chart-bar",
    icon_classes: "text-rose-600",
    records: @payment_plans,
    active_count: @payment_plans.filter(&:active?).size,
    linked_count: @payment_plans.filter { |record| record.try(:linked_account_id).present? || record.try(:payment_account_id).present? }.size,
    description: "Balances paid down over time.",
    empty_hint: "Track installment plans and payoff targets."
  },
  {
    label: "Credit Cards",
    anchor: "credit-cards",
    icon: "shield-lock",
    icon_classes: "text-violet-600",
    records: @credit_cards,
    active_count: @credit_cards.filter(&:active?).size,
    linked_count: @credit_cards.filter { |record| record.try(:linked_account_id).present? || record.try(:payment_account_id).present? }.size,
    description: "Estimated card payments from leftover cash.",
    empty_hint: "Schedule card payment estimates."
  }
] %>
<% recurring_total = recurring_groups.sum { |group| group[:records].size } %>
<% recurring_active_total = recurring_groups.sum { |group| group[:active_count] } %>
<% recurring_linked_total = recurring_groups.sum { |group| group[:linked_count] } %>
<% editing_recurring_section =
     if @pay_schedule.persisted?
       "pay-schedules"
     elsif @subscription.persisted?
       "subscriptions"
     elsif @monthly_bill.persisted?
       "monthly-bills"
     elsif @payment_plan.persisted?
       "payment-plans"
     elsif @credit_card.persisted?
       "credit-cards"
     end %>
<% default_recurring_section = editing_recurring_section || "pay-schedules" %>
<% recurring_tab_urls = recurring_groups.to_h { |group| [group[:anchor], planning_templates_path(anchor: group[:anchor])] } %>

<div class="space-y-6" data-controller="tabs" data-tabs-default-tab-value="<%= default_recurring_section %>" data-tabs-tab-urls-value="<%= recurring_tab_urls.to_json %>">
  <% content_for :page_header do %>
    <div class="flex flex-wrap items-center gap-3">
      <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
        <%= tabler_icon("repeat", classes: "h-6 w-6 text-indigo-600") %>
        <span>Recurring Transactions</span>
      </h2>
    </div>
  <% end %>

  <section class="ta-card ta-surface-shell">
    <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Recurring payments</p>
        <h3 class="mt-2 text-xl font-semibold text-slate-900">Manage recurring payments by type</h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">Keep paychecks, subscriptions, bills, payment plans, and card payment estimates organized so each month can pull in the right planned entries.</p>
      </div>

      <div class="grid gap-3 text-sm sm:grid-cols-3 xl:min-w-[34rem]">
        <div class="rounded-2xl bg-white/80 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Saved</p>
          <p class="mt-1 text-2xl font-semibold text-slate-900"><%= recurring_total %></p>
        </div>
        <div class="rounded-2xl bg-white/80 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Active</p>
          <p class="mt-1 text-2xl font-semibold text-slate-900"><%= recurring_active_total %></p>
        </div>
        <div class="rounded-2xl bg-white/80 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Linked</p>
          <p class="mt-1 text-2xl font-semibold <%= recurring_linked_total.positive? ? 'text-emerald-700' : 'text-slate-900' %>"><%= recurring_linked_total %></p>
        </div>
      </div>
    </div>

    <% if recurring_total.zero? %>
      <div class="mt-5 rounded-2xl border border-dashed border-indigo-200 bg-white/80 px-4 py-3 text-sm leading-6 text-slate-600">
        Start small: add one paycheck schedule and one recurring bill or subscription. You can add the rest after the first month shows what is actually useful.
      </div>
    <% end %>

    <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-5">
      <% recurring_groups.each do |group| %>
        <button type="button"
                class="rounded-2xl border border-slate-200 bg-white/85 p-4 text-left transition hover:border-indigo-200 hover:bg-indigo-50 focus:outline-none focus:ring-4 focus:ring-indigo-100"
                data-action="click->tabs#switch"
                data-tabs-name-param="<%= group[:anchor] %>">
          <div class="flex items-center justify-between gap-3">
            <span class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900">
              <%= tabler_icon(group[:icon], classes: "h-4 w-4 #{group[:icon_classes]}") %>
              <span><%= group[:label] %></span>
            </span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= group[:records].size %></span>
          </div>
          <p class="mt-2 text-xs leading-5 text-slate-500"><%= group[:description] %></p>
          <div class="mt-3 flex flex-wrap gap-2 text-[11px] font-semibold text-slate-500">
            <span class="rounded-full bg-slate-100 px-2 py-1"><%= group[:active_count] %> active</span>
            <span class="rounded-full bg-slate-100 px-2 py-1"><%= group[:linked_count] %> linked</span>
          </div>
        </button>
      <% end %>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Choose type</p>
        <h3 class="mt-1 text-lg font-semibold text-slate-900">Pick the recurring payment type to review</h3>
      </div>

      <div class="ta-tab-list" role="tablist" aria-label="Recurring transaction types" style="view-transition-name: recurring-template-tabs; view-transition-class: ta-vt-nav;">
        <% recurring_groups.each do |group| %>
          <button type="button"
                  class="ta-tab <%= 'ta-tab-active' if group[:anchor] == default_recurring_section %>"
                  role="tab"
                  aria-selected="<%= (group[:anchor] == default_recurring_section).to_s %>"
                  data-tabs-target="tab"
                  data-tab-name="<%= group[:anchor] %>"
                  data-action="click->tabs#switch"
                  data-tabs-name-param="<%= group[:anchor] %>">
            <span class="inline-flex items-center gap-2">
              <%= tabler_icon(group[:icon], classes: "ta-tab-icon") %>
              <span class="hidden sm:inline"><%= group[:label] %></span>
              <span class="sm:hidden"><%= group[:label].split.first %></span>
            </span>
            <span class="rounded-full bg-white/20 px-2 py-0.5 text-xs font-semibold"><%= group[:records].size %></span>
          </button>
        <% end %>
      </div>
    </div>
  </section>

  <% recurring_groups.each do |group| %>
    <div
      data-tabs-target="panel"
      data-panel-name="<%= group[:anchor] %>"
      role="tabpanel"
      class="<%= group[:anchor] == default_recurring_section ? 'space-y-3' : 'hidden space-y-3' %>"
      <%= %(style="view-transition-name: recurring-template-panel; view-transition-class: ta-vt-panel;") if group[:anchor] == default_recurring_section %>>
      <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm text-slate-600">
        <span class="inline-flex items-center gap-2 font-medium text-slate-800">
          <%= tabler_icon(group[:icon], classes: "h-4 w-4 #{group[:icon_classes]}") %>
          <span><%= group[:description] %></span>
        </span>
        <span class="text-xs font-semibold text-slate-500"><%= group[:records].any? ? "#{group[:active_count]} active of #{group[:records].size}" : group[:empty_hint] %></span>
      </div>

      <% case group[:anchor] %>
      <% when "pay-schedules" %>
        <%= render "pay_schedules/section",
                   budget_month: nil,
                   return_to: planning_templates_path(anchor: "pay-schedules"),
                   pay_schedules: @pay_schedules,
                   pay_schedule: @pay_schedule %>
      <% when "subscriptions" %>
        <%= render "subscriptions/section",
                   budget_month: nil,
                   return_to: planning_templates_path(anchor: "subscriptions"),
                   subscriptions: @subscriptions,
                   subscription: @subscription %>
      <% when "monthly-bills" %>
        <%= render "monthly_bills/section",
                   budget_month: nil,
                   return_to: planning_templates_path(anchor: "monthly-bills"),
                   monthly_bills: @monthly_bills,
                   monthly_bill: @monthly_bill %>
      <% when "payment-plans" %>
        <%= render "payment_plans/section",
                   budget_month: nil,
                   return_to: planning_templates_path(anchor: "payment-plans"),
                   payment_plans: @payment_plans,
                   payment_plan: @payment_plan %>
      <% when "credit-cards" %>
        <%= render "credit_cards/section",
                   budget_month: nil,
                   return_to: planning_templates_path(anchor: "credit-cards"),
                   credit_cards: @credit_cards,
                   credit_card: @credit_card %>
      <% end %>
    </div>
  <% end %>
</div>
