<% content_for :title, "Settings" %>

<div class="space-y-6">
  <section class="ta-card ta-surface-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Preferences</p>
        <h2 class="mt-2 text-2xl font-semibold text-slate-900">Appearance and app settings</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">Use this page for user-adjustable preferences. Color schemes live here now, and future options can be added without crowding the main navigation.</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">Current theme</p>
        <p class="mt-1"><%= current_theme.name %></p>
      </div>
    </div>
  </section>

  <section class="ta-card">
    <div class="max-w-xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Workflow</p>
      <h3 class="mt-2 text-lg font-semibold text-slate-900">Default navigation preferences</h3>
      <p class="mt-2 text-sm leading-6 text-slate-600">Choose where to land after signing in and which month view should open first when you browse a budget month.</p>
    </div>

    <%= form_with model: current_user, url: settings_path, method: :patch, class: "mt-5 space-y-5" do |form| %>
      <div class="grid gap-5 lg:grid-cols-2">
        <div>
          <%= form.label :default_landing_page, "Default landing page", class: "fb-label" %>
          <%= form.select :default_landing_page, options_for_select(landing_page_options, current_user.default_landing_page), {}, class: "fb-select" %>
          <p class="mt-2 text-sm text-slate-500">Used after a normal sign-in when there is no stored redirect.</p>
        </div>

        <div>
          <%= form.label :preferred_month_view, "Preferred month view", class: "fb-label" %>
          <%= form.select :preferred_month_view, options_for_select(preferred_month_view_options, current_user.preferred_month_view), {}, class: "fb-select" %>
          <p class="mt-2 text-sm text-slate-500">This becomes the default tab on month pages unless a specific tab is requested.</p>
        </div>
      </div>

      <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
        <%= tabler_icon("check", classes: "ta-action-icon") %>
        <span>Save settings</span>
      <% end %>
    <% end %>
  </section>

  <section class="ta-card">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Color Scheme</p>
        <h3 class="mt-2 text-lg font-semibold text-slate-900">Choose your palette</h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">The active theme updates the app shell and the authentication pages. Your selection is saved for this browser.</p>
      </div>

      <div class="ta-settings-panel">
        <%= render "shared/theme_picker" %>
      </div>
    </div>
  </section>

  <section class="ta-card ta-surface-plan-soft">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Coming Later</p>
    <h3 class="mt-2 text-lg font-semibold text-slate-900">More settings can live here</h3>
    <p class="mt-2 text-sm leading-6 text-slate-600">This section is reserved for future user preferences such as date display, notification controls, export defaults, or other per-user options you decide to expose.</p>
  </section>
</div>
