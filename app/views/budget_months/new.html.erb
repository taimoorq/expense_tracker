<% content_for :page_header do %>
  <div class="flex flex-wrap items-center gap-3">
    <div>
      <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
        <%= tabler_icon("calendar-plus", classes: "h-6 w-6 text-indigo-600") %>
        <span>New Budget Month</span>
      </h2>
      <p class="ta-muted mt-1">Choose a quick clone workflow or start a month from scratch with guided details.</p>
    </div>
  </div>
<% end %>

<%= form_with model: @budget_month,
  class: "ta-wizard-shell",
  data: { controller: "month-wizard", month_wizard_start_step_value: @wizard_step } do |form| %>
  <div class="ta-wizard-header">
    <div class="flex items-center justify-between gap-3">
      <div class="text-sm font-medium text-slate-700" data-month-wizard-target="progress">Step 1 of 2</div>
      <div data-month-wizard-target="error" class="hidden rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
    </div>

    <div class="ta-wizard-steps mt-4">
      <div class="ta-wizard-step" data-month-wizard-target="stepIndicator">
        <span class="ta-wizard-step-badge">1</span>
        <div>
          <p class="text-sm font-semibold text-slate-900">Choose your path</p>
          <p class="mt-1 text-sm text-slate-500">Clone an existing month or start fresh.</p>
        </div>
      </div>
      <div class="ta-wizard-step" data-month-wizard-target="stepIndicator">
        <span class="ta-wizard-step-badge">2</span>
        <div>
          <p class="text-sm font-semibold text-slate-900">Enter details</p>
          <p class="mt-1 text-sm text-slate-500">Only needed for a fresh month setup.</p>
        </div>
      </div>
    </div>
  </div>

  <% if @budget_month.errors.any? %>
    <div class="mt-4 rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700">
      <%= @budget_month.errors.full_messages.join(", ") %>
    </div>
  <% end %>

  <section data-month-wizard-target="step" class="mt-4 space-y-4">
    <div>
      <h3 class="text-lg font-semibold text-slate-900">1. How do you want to create this month?</h3>
      <p class="ta-muted mt-1">Clone a previous month for a fast setup, or start fresh and enter the details manually.</p>
    </div>

    <div class="grid gap-3 md:grid-cols-2">
      <label class="ta-wizard-choice" data-month-wizard-target="choiceCard">
        <div class="flex items-start gap-3">
          <%= radio_button_tag :month_workflow, "clone", @month_workflow == "clone", class: "mt-1 h-4 w-4 text-indigo-600", data: { month_wizard_target: "workflow", action: "change->month-wizard#workflowChanged" } %>
          <div>
            <div class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900">
              <%= tabler_icon("copy", classes: "ta-action-icon-lg text-indigo-600") %>
              <span>Clone an existing month</span>
            </div>
            <p class="mt-1 text-sm text-slate-600">Next will immediately create the next available month and copy entries from the month you pick.</p>
          </div>
        </div>
      </label>

      <label class="ta-wizard-choice ta-wizard-choice-fresh" data-month-wizard-target="choiceCard">
        <div class="flex items-start gap-3">
          <%= radio_button_tag :month_workflow, "fresh", @month_workflow != "clone", class: "mt-1 h-4 w-4 text-emerald-600", data: { month_wizard_target: "workflow", action: "change->month-wizard#workflowChanged" } %>
          <div>
            <div class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900">
              <%= tabler_icon("sparkles", classes: "ta-action-icon-lg text-emerald-600") %>
              <span>Start fresh</span>
            </div>
            <p class="mt-1 text-sm text-slate-600">Go to the next step and enter the month, label, income, and notes yourself.</p>
          </div>
        </div>
      </label>
    </div>

    <div data-month-wizard-target="clonePanel" class="ta-wizard-panel">
      <div class="mb-3 flex items-center gap-2">
        <h4 class="text-sm font-semibold text-slate-900">Choose a month to clone</h4>
        <button type="button" class="ta-icon-btn" aria-label="Clone month help" title="Clone month help" data-action="click->help-modal#open" data-help-title="Clone Month Help" data-help-body="Pick an existing month to copy its entries into the next available month. Entry dates will be shifted into the new month, actual amounts will be cleared, and statuses will reset to planned."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
      </div>

      <%= select_tag :source_month_id,
        options_for_select(@cloneable_month_options.map { |option| ["#{option[:source_label]} → #{option[:target_label]}", option[:id], { "data-target-label": option[:target_label], "data-entry-count": option[:entry_count], "data-source-label": option[:source_label] }] }, @source_budget_month&.id),
        include_blank: "Choose a month",
        class: "fb-select",
        data: { month_wizard_target: "sourceSelect", action: "change->month-wizard#sourceChanged" } %>

      <p class="mt-3 text-sm text-slate-600" data-month-wizard-target="cloneSummary">
        <% if @clone_preview %>
          Next will create <strong><%= @clone_preview[:target_label] %></strong> by copying entries from <strong><%= @clone_preview[:source_label] %></strong>.
        <% else %>
          Pick a source month to enable the quick clone path.
        <% end %>
      </p>

      <div data-month-wizard-target="clonePreview" class="mt-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 <%= @clone_preview ? nil : 'hidden' %>">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Success preview</p>
            <p class="mt-1 text-sm font-semibold text-emerald-950">
              <span data-month-wizard-target="previewTargetLabel"><%= @clone_preview&.dig(:target_label) %></span>
              will be ready with copied starter entries.
            </p>
          </div>
          <div class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-emerald-700 shadow-sm">
            <span data-month-wizard-target="previewEntryCount"><%= @clone_preview&.dig(:entry_count) || 0 %></span>
            entries
          </div>
        </div>
        <p class="mt-2 text-sm text-emerald-800">
          Source: <strong data-month-wizard-target="previewSourceLabel"><%= @clone_preview&.dig(:source_label) %></strong>. Actual amounts will be cleared and statuses will reset to planned.
        </p>
      </div>
    </div>
  </section>

  <section data-month-wizard-target="step" class="mt-4 space-y-4">
    <div>
      <h3 class="text-lg font-semibold text-slate-900">2. Enter the month details</h3>
      <p class="ta-muted mt-1">Use this path when you want a clean month without copied entries.</p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      <div>
        <%= form.label :month_on, "Month", class: "fb-label" %>
        <%= form.date_field :month_on, class: "fb-input", data: { month_wizard_target: "monthOn" } %>
        <p class="ta-muted mt-1 text-xs">Select the first day of the month you want to budget for. For example, choose "2026-03-01" for March 2026.</p>
      </div>

      <div>
        <%= form.label :label, class: "fb-label" %>
        <%= form.text_field :label, placeholder: "March 2026", class: "fb-input", data: { month_wizard_target: "label" } %>
      </div>

      <!-- Removed planned_income and actual_income fields -->
    </div>

    <div class="rounded-2xl border border-emerald-200 bg-emerald-50/70 p-4">
      <%= hidden_field_tag :include_applicable_templates, "0" %>
      <div class="flex items-start gap-3">
        <%= check_box_tag :include_applicable_templates, "1", @include_applicable_templates, class: "mt-1 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" %>
        <div>
          <label for="include_applicable_templates" class="text-sm font-semibold text-slate-900">Import planning templates for this month</label>
          <p class="ta-muted mt-1 text-sm">
            Add matching paychecks, subscriptions, monthly bills, payment plans, and card payment estimates for the selected month.
          </p>
        </div>
      </div>
    </div>

    <div>
      <%= form.label :notes, class: "fb-label" %>
      <%= form.text_area :notes, rows: 3, class: "fb-textarea" %>
    </div>
  </section>

  <div class="ta-wizard-footer">
    <div class="flex items-center gap-2">
      <button type="button" class="fb-btn-secondary hidden" data-month-wizard-target="backButton" data-action="click->month-wizard#back">Back</button>
      <%= link_to "Cancel", budget_months_path, class: "fb-btn-secondary" %>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" class="fb-btn-secondary hidden" data-month-wizard-target="nextButton" data-action="click->month-wizard#next">Next</button>
      <%= form.submit "Create Month", class: "fb-btn-primary", data: { month_wizard_target: "submitButton" } %>
    </div>
  </div>
<% end %>
