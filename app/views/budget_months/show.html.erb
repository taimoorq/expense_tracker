<div class="space-y-6">
  <% has_generated_paychecks = @expense_entries.any? { |entry| entry.source_file == "pay_schedule" } %>
  <% has_generated_subscriptions = @expense_entries.any? { |entry| entry.source_file == "subscription" } %>
  <% has_generated_monthly_bills = @expense_entries.any? { |entry| entry.source_file == "monthly_bill" } %>
  <% has_generated_payment_plans = @expense_entries.any? { |entry| entry.source_file == "payment_plan" } %>
  <% generation_actions_hidden = @budget_month.complete_for_generation? %>
  <% default_tab = @expense_entries.empty? ? "entries" : "timeline" %>

  <% content_for :page_header do %>
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="text-2xl font-semibold"><%= @budget_month.label %></h2>
        <% if generation_actions_hidden %>
          <p class="ta-muted mt-1">This month looks complete, so template generation actions are hidden to avoid unnecessary changes.</p>
        <% end %>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to new_budget_month_path(source_month_id: @budget_month.id), class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("copy", classes: "ta-action-icon text-slate-600") %>
          <span>Clone Month</span>
        <% end %>
      </div>
    </div>
  <% end %>

  <section class="ta-card ta-surface-shell" data-controller="tabs" data-tabs-default-tab-value="<%= default_tab %>">
    <div class="mb-4 flex flex-wrap items-center gap-2" role="tablist" aria-label="Month view tabs">
      <button type="button" class="fb-btn-primary" role="tab" aria-selected="true" data-tabs-target="tab" data-tab-name="timeline" data-action="click->tabs#switch" data-tabs-name-param="timeline">
        <span class="inline-flex items-center gap-2"><%= tabler_icon("timeline", classes: "ta-action-icon-lg text-indigo-100") %> Timeline</span>
      </button>
      <button type="button" class="fb-btn-secondary" role="tab" aria-selected="false" data-tabs-target="tab" data-tab-name="breakdown" data-action="click->tabs#switch" data-tabs-name-param="breakdown">
        <span class="inline-flex items-center gap-2"><%= tabler_icon("chart-bar", classes: "ta-action-icon-lg text-indigo-600") %> Breakdown</span>
      </button>
      <button type="button" class="fb-btn-secondary" role="tab" aria-selected="false" data-tabs-target="tab" data-tab-name="calendar" data-action="click->tabs#switch" data-tabs-name-param="calendar">
        <span class="inline-flex items-center gap-2"><%= tabler_icon("calendar-month", classes: "ta-action-icon-lg text-sky-600") %> Calendar</span>
      </button>
      <button type="button" class="fb-btn-secondary" role="tab" aria-selected="false" data-tabs-target="tab" data-tab-name="entries" data-action="click->tabs#switch" data-tabs-name-param="entries">
        <span class="inline-flex items-center gap-2"><%= tabler_icon("list", classes: "ta-action-icon-lg text-slate-600") %> Plan and Edit</span>
      </button>
    </div>

    <div data-tabs-target="panel" data-panel-name="timeline" role="tabpanel" class="space-y-6">
      <%= render "summary_cards", budget_month: @budget_month, expense_entries: @expense_entries %>
      <%= render "expense_entries/timeline", expense_entries: @expense_entries, budget_month: @budget_month %>
    </div>

    <div data-tabs-target="panel" data-panel-name="breakdown" role="tabpanel" class="hidden space-y-4">
      <%= render "visual_dashboard", budget_month: @budget_month, expense_entries: @expense_entries %>
    </div>

    <div data-tabs-target="panel" data-panel-name="calendar" role="tabpanel" class="hidden space-y-4">
      <%= render "expense_entries/calendar", expense_entries: @expense_entries, budget_month: @budget_month %>
    </div>

    <div data-tabs-target="panel" data-panel-name="entries" role="tabpanel" class="hidden space-y-4">
      <section class="ta-card-tinted ta-surface-plan">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-3xl">
            <h3 class="text-base font-semibold text-slate-900">Plan and Edit This Month</h3>
            <p class="mt-1 text-sm leading-6 text-slate-600">
              Use this tab to build the month in three steps: add recurring items from templates, add one-off items manually,
              and then review or update everything in the month list below.
            </p>
          </div>
          <div class="grid gap-2 text-sm text-slate-600 sm:grid-cols-3 lg:min-w-[32rem]">
            <div class="rounded-lg border border-emerald-100 bg-white/80 p-3">
              <p class="font-medium text-slate-900">1. Add from templates</p>
              <p class="mt-1 text-xs leading-5">Pull in paychecks, bills, plans, and card estimates.</p>
            </div>
            <div class="rounded-lg border border-sky-100 bg-white/80 p-3">
              <p class="font-medium text-slate-900">2. Add manually</p>
              <p class="mt-1 text-xs leading-5">Capture one-off income, spending, and adjustments.</p>
            </div>
            <div class="rounded-lg border border-amber-100 bg-white/80 p-3">
              <p class="font-medium text-slate-900">3. Review and edit</p>
              <p class="mt-1 text-xs leading-5">Update statuses, amounts, and notes as the month changes.</p>
            </div>
          </div>
        </div>
      </section>

      <% unless generation_actions_hidden %>
        <section class="ta-card-tinted ta-surface-plan-soft">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-2xl">
              <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Step 1 · Add from planning templates</h3>
              <p class="mt-1 text-sm leading-6 text-slate-600">
                These actions add planned entries to this month from your saved templates and card settings.
                If nothing has been set up yet, start in
                <%= link_to "Planning Templates", planning_templates_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>.
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-2 lg:justify-end">
              <% unless has_generated_paychecks %>
                <%= button_to generate_paychecks_budget_month_path(@budget_month), method: :post, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-xs" do %>
                  <%= tabler_icon("cash", classes: "ta-action-icon text-emerald-600") %>
                  <span>Add Paychecks</span>
                <% end %>
              <% end %>
              <% unless has_generated_subscriptions %>
                <%= button_to generate_subscriptions_budget_month_path(@budget_month), method: :post, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-xs" do %>
                  <%= tabler_icon("repeat", classes: "ta-action-icon text-indigo-600") %>
                  <span>Add Subscriptions</span>
                <% end %>
              <% end %>
              <% unless has_generated_monthly_bills %>
                <%= button_to generate_monthly_bills_budget_month_path(@budget_month), method: :post, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-xs" do %>
                  <%= tabler_icon("calendar-plus", classes: "ta-action-icon text-sky-600") %>
                  <span>Add Monthly Bills</span>
                <% end %>
              <% end %>
              <% unless has_generated_payment_plans %>
                <%= button_to generate_payment_plans_budget_month_path(@budget_month), method: :post, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-xs" do %>
                  <%= tabler_icon("template", classes: "ta-action-icon text-violet-600") %>
                  <span>Add Payment Plans</span>
                <% end %>
              <% end %>
              <%= button_to estimate_credit_cards_budget_month_path(@budget_month), method: :post, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-xs" do %>
                <%= tabler_icon("chart-bar", classes: "ta-action-icon text-indigo-600") %>
                <span>Estimate Card Payments</span>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <section class="ta-card-tinted ta-surface-manual-soft">
        <div class="mb-2 px-1">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Step 2 · Add an item manually</h3>
          <p class="mt-1 text-sm text-slate-600">Use the quick form for one-off items, or open the wizard for a guided flow.</p>
        </div>
        <%= render "expense_entries/form", budget_month: @budget_month, expense_entry: @expense_entry %>
      </section>

      <section class="ta-card-tinted ta-surface-edit-soft">
        <div class="mb-2 px-1">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Step 3 · Review and edit this month</h3>
          <p class="mt-1 text-sm text-slate-600">Use the month list to update amounts, mark items paid, or clean up entries as plans change.</p>
        </div>
        <%= render "expense_entries/table", budget_month: @budget_month, expense_entries: @expense_entries %>
      </section>
    </div>
  </section>

  <%= render "expense_entries/template_editor_empty" %>
  <%= render "expense_entries/entry_editor_empty" %>
  <%= render "expense_entries/entry_wizard_empty" %>
</div>
