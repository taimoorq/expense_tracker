<%= turbo_frame_tag "plan_and_edit_panel", data: { controller: "plan-navigation" } do %>
  <% plan = Budgeting::PlanAndEditPresenter.new(budget_month: budget_month, expense_entries: expense_entries) %>
  <% plan_nav_data = { action: "plan-navigation#scroll", turbo: false } %>

  <section class="ta-card-tinted ta-surface-plan">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
      <div class="max-w-3xl">
        <h3 class="text-base font-semibold text-slate-900">Plan and Edit This Month</h3>
        <p class="mt-1 text-sm leading-6 text-slate-600">Set up the month, add anything unusual, and clean up items that need a second look.</p>
      </div>
      <div class="flex flex-wrap items-center gap-2 xl:justify-end">
        <%= link_to plan.next_recommended_anchor, class: "rounded-full px-3 py-1 text-xs font-semibold #{plan.next_recommended_classes}", data: plan_nav_data do %>
          Next: <%= plan.next_recommended_label %>
        <% end %>
        <%= link_to "Recurring", "#plan-recurring", class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", data: plan_nav_data %>
        <%= link_to "One-off", "#plan-one-off", class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", data: plan_nav_data %>
        <%= link_to "Review", "#plan-review", class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", data: plan_nav_data %>
      </div>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <%= link_to "#plan-recurring", class: "rounded-2xl border border-emerald-100 bg-white/85 p-4 transition hover:-translate-y-0.5 hover:border-emerald-200", data: plan_nav_data do %>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Recurring</p>
        <p class="mt-1 text-xl font-semibold text-slate-900"><%= plan.generation_actions_hidden? ? "Done" : "#{plan.template_actions_completed} / #{plan.recurring_actions_total}" %></p>
        <p class="mt-1 text-sm text-slate-600"><%= plan.generation_actions_hidden? ? "Actions hidden for this complete month." : "Paychecks, bills, plans, subscriptions, and cards." %></p>
      <% end %>
      <%= link_to "#plan-one-off", class: "rounded-2xl border border-sky-100 bg-white/85 p-4 transition hover:-translate-y-0.5 hover:border-sky-200", data: plan_nav_data do %>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">One-off</p>
        <p class="mt-1 text-xl font-semibold text-slate-900"><%= plan.manual_entries_count %></p>
        <p class="mt-1 text-sm text-slate-600">Irregular income, spending, or adjustments.</p>
      <% end %>
      <%= link_to "#plan-review", class: "rounded-2xl border border-amber-100 bg-white/85 p-4 transition hover:-translate-y-0.5 hover:border-amber-200", data: plan_nav_data do %>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Needs review</p>
        <p class="mt-1 text-xl font-semibold text-slate-900"><%= plan.review_attention_count %></p>
        <p class="mt-1 text-sm text-slate-600">Due, incomplete, or paid without actuals.</p>
      <% end %>
      <div class="rounded-2xl border border-slate-200 bg-white/85 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Month items</p>
        <p class="mt-1 text-xl font-semibold text-slate-900"><%= plan.month_items_count %></p>
        <p class="mt-1 text-sm text-slate-600">Everything planned or recorded here.</p>
      </div>
    </div>

    <div class="mt-4 rounded-2xl border border-slate-200 bg-white/80 p-4">
      <div class="grid gap-3 text-sm text-slate-700 md:grid-cols-3">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-semibold text-emerald-800">1</span>
          <span><strong class="text-slate-900">Add recurring</strong><br>Bring in the predictable items first.</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sky-100 text-xs font-semibold text-sky-800">2</span>
          <span><strong class="text-slate-900">Add one-offs</strong><br>Capture what does not repeat.</span>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-amber-100 text-xs font-semibold text-amber-800">3</span>
          <span><strong class="text-slate-900">Review cleanup</strong><br>Fix items that need attention.</span>
        </div>
      </div>
    </div>
  </section>
  <br>

  <section id="plan-recurring" class="ta-card-tinted ta-surface-plan-soft scroll-mt-24">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-2xl">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Add recurring items</h3>
        <p class="mt-1 text-sm leading-6 text-slate-600">Use saved recurring transactions to fill in the predictable parts of the month.</p>
      </div>

      <div class="flex flex-wrap items-center gap-2 lg:justify-end">
        <%= link_to planning_templates_path, class: "fb-btn-secondary ta-action-btn", data: { turbo_frame: "_top" } do %>
          <%= tabler_icon("repeat", classes: "ta-action-icon") %>
          <span>Open Recurring</span>
        <% end %>
      </div>
    </div>

    <% if plan.generation_actions_hidden? %>
      <div class="mt-4 rounded-[22px] border border-emerald-200 bg-white/85 p-4 text-sm text-slate-700">
        <div class="flex items-start gap-3">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-800">
            <%= tabler_icon("check", classes: "h-4 w-4") %>
          </span>
          <div>
            <p class="font-medium text-slate-900">Recurring actions are hidden for this month</p>
            <p class="mt-1 leading-6">This month appears complete enough that generation actions were hidden to avoid unnecessary duplicate items. You can still review and edit everything below.</p>
          </div>
        </div>
      </div>
    <% else %>
      <div class="mt-4 grid gap-3 xl:grid-cols-2 2xl:grid-cols-3">
        <% plan.recurring_actions.each do |action| %>
          <div class="rounded-[22px] border border-slate-200 bg-white/85 p-4 <%= "xl:col-span-2 2xl:col-span-1" if action.key == :credit_cards %>">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-slate-900"><%= action.title %></p>
                <p class="mt-1 text-xs leading-5 text-slate-600"><%= action.description %></p>
                <p class="mt-3 inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-700">
                  <%= action.status_summary %>
                </p>
              </div>
              <% if action.complete? %>
                <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-emerald-800"><%= action.status_label %></span>
              <% end %>
            </div>

            <% if action.alternate? %>
              <div class="mt-4 rounded-2xl border border-sky-200 bg-sky-50/80 p-3">
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-sky-800">Found on different dates</p>
                <ul class="mt-2 space-y-2 text-xs text-slate-700">
                  <% action.alternate_items.each do |preview| %>
                    <li>
                      <span class="font-medium text-slate-900"><%= preview[:payee] %></span> ·
                      due <%= preview[:occurred_on]&.strftime("%b %-d") %>,
                      found <%= preview[:matched_on]&.strftime("%b %-d") %> ·
                      <%= number_to_currency(preview[:planned_amount]) %>
                    </li>
                  <% end %>
                </ul>
                <% if action.alternate_more_summary.present? %>
                  <p class="mt-2 text-xs text-slate-500"><%= action.alternate_more_summary %></p>
                <% end %>
                <p class="mt-2 text-xs text-slate-500">Counted for this month, so these will not be added again.</p>
              </div>
            <% end %>

            <% if action.remaining? %>
              <div class="mt-4 rounded-2xl border border-amber-200 bg-amber-50/80 p-3">
                <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-amber-800"><%= action.missing_heading %></p>
                <ul class="mt-2 space-y-2 text-xs text-slate-700">
                  <% action.preview_items.each do |preview| %>
                    <li>
                      <span class="font-medium text-slate-900"><%= preview[:payee] %></span> ·
                      <%= preview[:occurred_on]&.strftime("%b %-d") %> ·
                      <% if preview[:amount_prefix].present? %>
                        <%= preview[:amount_prefix] %> <%= number_to_currency(preview[:planned_amount]) %>
                      <% else %>
                        <%= number_to_currency(preview[:planned_amount]) %>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
                <% if action.more_summary.present? %>
                  <p class="mt-2 text-xs text-slate-500"><%= action.more_summary %></p>
                <% end %>
              </div>
            <% end %>

            <div class="mt-4">
              <% if action.action_available? %>
                <%= button_to action.button_path, method: :post, class: action.button_classes do %>
                  <%= tabler_icon(action.button_icon, classes: action.button_icon_classes) %>
                  <span><%= action.current_button_label %></span>
                <% end %>
              <% else %>
                <p class="text-sm text-slate-600"><%= action.complete_message %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
  <br>

  <section id="plan-one-off" class="ta-card-tinted ta-surface-manual-soft scroll-mt-24">
    <div class="mb-2 px-1">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Add one-off items</h3>
      <p class="mt-1 text-sm text-slate-600">Use this for anything that does not already live in recurring transactions.</p>
    </div>
    <%= render "expense_entries/form", budget_month: budget_month, expense_entry: expense_entry %>
  </section>
  <br>

  <section id="plan-review" class="ta-card-tinted ta-surface-edit-soft scroll-mt-24">
    <div class="mb-2 px-1">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-700">Review cleanup</h3>
      <p class="mt-1 text-sm text-slate-600">These counts point to entries worth checking before you call the month current.</p>
    </div>

    <div class="mb-4 grid gap-3 lg:grid-cols-3 xl:grid-cols-4">
      <div class="rounded-[22px] border border-amber-200 bg-white/85 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Still planned and due</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= plan.due_planned_count %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Items due today or earlier that are still marked planned.</p>
      </div>
      <div class="rounded-[22px] border border-sky-200 bg-white/85 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Missing key details</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= plan.missing_details_count %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Items missing a date, category, or payee and likely worth cleaning up.</p>
      </div>
      <div class="rounded-[22px] border border-rose-200 bg-white/85 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Paid without actual</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= plan.paid_missing_actual_count %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Items marked paid that still do not have an actual amount.</p>
      </div>
      <div class="rounded-[22px] border border-violet-200 bg-white/85 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Auto-completed</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= plan.auto_completed_count %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Recurring items marked paid automatically and ready for a quick check.</p>
      </div>
    </div>
  </section>
<% end %>
