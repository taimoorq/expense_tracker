<% content_for :head do %>
  <%= chart_library_tags %>
<% end %>

<%= turbo_frame_tag "visual_dashboard" do %>
  <% compact = local_assigns.fetch(:compact, false) %>
  <% entries = expense_entries.to_a %>
  <% outflow_entries = entries.reject(&:income?) %>
  <% sankey_payload = Budgeting::MonthCashflowSankey.cached_payload(budget_month: budget_month, expense_entries: budget_month.expense_entries) %>
  <% account_flow_payload = Budgeting::MonthAccountFlowSummary.cached_payload(budget_month: budget_month, expense_entries: expense_entries) %>

  <% section_totals = outflow_entries.group_by(&:section).transform_values { |items| items.sum { |item| item.effective_amount.to_f } }.sort_by { |_k, v| -v } %>
  <% section_labels = section_totals.map { |k, _v| k.humanize } %>
  <% section_values = section_totals.map { |_k, v| v.round(2) } %>

  <% running = 0.0 %>
  <% ordered_entries = entries.sort_by { |entry| [entry.occurred_on || Date.new(9999, 12, 31), entry.created_at] } %>
  <% line_labels = [] %>
  <% line_values = [] %>
  <% ordered_entries.each do |entry| %>
    <% running += entry.cashflow_amount.to_f %>
    <% line_labels << (entry.occurred_on&.strftime("%b %-d") || "No Date") %>
    <% line_values << running.round(2) %>
  <% end %>

  <% spending_entries = outflow_entries.select { |entry| entry.occurred_on.present? } %>

  <% running_outflow = 0.0 %>
  <% cumulative_outflow_labels = [] %>
  <% cumulative_outflow_values = [] %>
  <% spending_entries.sort_by { |entry| [entry.occurred_on, entry.created_at] }.each do |entry| %>
    <% running_outflow += entry.effective_amount.to_f %>
    <% cumulative_outflow_labels << entry.occurred_on.strftime("%b %-d") %>
    <% cumulative_outflow_values << running_outflow.round(2) %>
  <% end %>

  <% category_totals = outflow_entries.group_by { |entry| entry.category.presence || "Uncategorized" }.map do |category, items| %>
    <% planned_total = items.sum { |item| item.planned_amount.to_f } %>
    <% actual_total = items.sum { |item| item.actual_amount.to_f } %>
    <% [category, planned_total.round(2), actual_total.round(2), (actual_total - planned_total).round(2)] %>
  <% end %>
  <% over_budget_categories = category_totals.select { |_category, _planned, _actual, variance| variance.positive? }.sort_by { |_category, _planned, _actual, variance| -variance }.first(8) %>
  <% over_budget_labels = over_budget_categories.map(&:first) %>
  <% over_budget_values = over_budget_categories.map(&:last) %>

  <% income = budget_month.income_total.to_f %>
  <% leftover = budget_month.calculated_leftover.to_f %>
  <% savings_pct = income.positive? ? ((leftover / income) * 100).round(1) : 0 %>
  <% top_category = section_totals.first %>

  <section class="ta-card ta-surface-breakdown">
    <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <h3 class="ta-section-title inline-flex items-center gap-2"><%= tabler_icon("chart-bar") %> Visual Budget Breakdown</h3>
      <p class="ta-muted"><%= compact ? "Compact chart view" : "" %></p>
    </div>

    <% unless compact %>
      <div class="mb-4 grid gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-emerald-100 bg-white/80 p-3">
          <p class="text-xs uppercase tracking-wide text-slate-500">Budget Health</p>
          <p class="mt-1 text-lg font-semibold <%= leftover >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
            <%= leftover >= 0 ? "On Track" : "Over Budget" %>
          </p>
        </div>
        <div class="rounded-lg border border-indigo-100 bg-white/80 p-3">
          <p class="text-xs uppercase tracking-wide text-slate-500">Savings Rate</p>
          <p class="mt-1 text-lg font-semibold"><%= savings_pct %>%</p>
        </div>
        <div class="rounded-lg border border-fuchsia-100 bg-white/80 p-3">
          <p class="text-xs uppercase tracking-wide text-slate-500">Top Outflow Bucket</p>
          <p class="mt-1 text-lg font-semibold">
            <%= top_category ? "#{top_category[0].humanize} (#{number_to_currency(top_category[1])})" : "—" %>
          </p>
        </div>
      </div>

      <div class="mb-4 rounded-lg border border-emerald-100 bg-white/90 p-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Cash Flow</p>
            <h4 class="mt-2 text-lg font-semibold text-slate-900">Monthly flow graph</h4>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">This visual uses current-month entry payees and categories to show how income fans out into spending buckets and leftover cash.</p>
          </div>
          <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(sankey_payload[:links].count, "flow") %>
          </div>
        </div>

        <div
          class="mt-4 rounded-2xl border border-slate-200 bg-slate-50/80 p-3"
          data-controller="sankey-chart"
          data-sankey-chart-title-value="Monthly Cash Flow"
          data-sankey-chart-timeout-ms-value="4000"
          data-sankey-chart-nodes-value="<%= sankey_payload[:nodes].to_json %>"
          data-sankey-chart-links-value="<%= sankey_payload[:links].to_json %>">
          <div data-sankey-chart-target="loading" class="flex h-[25rem] flex-col items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white/80 px-6 text-center">
            <div class="h-12 w-12 animate-spin rounded-full border-4 border-slate-200 border-t-indigo-500"></div>
            <p class="mt-4 text-sm font-semibold text-slate-900" data-loading-text>Loading the monthly flow graph…</p>
            <p class="mt-2 max-w-md text-sm leading-6 text-slate-500">We are preparing the visual and loading the chart library for this month.</p>
          </div>
          <div data-sankey-chart-target="error" class="hidden h-[25rem] rounded-xl border border-rose-200 bg-rose-50/80 px-6 py-8">
            <div class="flex h-full flex-col items-center justify-center text-center">
              <div class="rounded-full bg-white p-3 text-rose-600 shadow-sm">
                <%= tabler_icon("alert-circle", classes: "h-7 w-7") %>
              </div>
              <h5 class="mt-4 text-lg font-semibold text-rose-900">The monthly flow graph could not load</h5>
              <p class="mt-2 max-w-lg text-sm leading-6 text-rose-800" data-sankey-chart-target="errorMessage">Something went wrong while rendering this graph.</p>
            </div>
          </div>
          <div data-sankey-chart-target="chart" class="hidden h-[25rem] rounded-xl bg-white/70"></div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-3">
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Income</p>
            <p class="mt-2 text-xl font-semibold text-emerald-700"><%= number_to_currency(sankey_payload[:income_total]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Outflow</p>
            <p class="mt-2 text-xl font-semibold text-rose-700"><%= number_to_currency(sankey_payload[:outflow_total]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Leftover</p>
            <p class="mt-2 text-xl font-semibold <%= sankey_payload[:leftover_total] >= 0 ? 'text-emerald-700' : 'text-slate-900' %>"><%= number_to_currency(sankey_payload[:leftover_total]) %></p>
          </div>
        </div>

        <div class="mt-4 rounded-xl border border-amber-100 bg-amber-50/80 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-800">What Would Make This Richer</p>
          <ul class="mt-2 space-y-2 text-sm leading-6 text-amber-900">
            <% sankey_payload[:limitations].each do |item| %>
              <li><%= item %></li>
            <% end %>
          </ul>
        </div>
      </div>

      <div class="mb-4 rounded-lg border border-sky-100 bg-white/90 p-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Accounts</p>
            <h4 class="mt-2 text-lg font-semibold text-slate-900">Charged vs paid to by account</h4>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">
              Charges come from outflows tied to each account. Payments combine income deposited into an account and credit-card payments sent to a linked card.
            </p>
          </div>
          <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(account_flow_payload[:account_count], "tracked account") %>
          </div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-3">
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Charged</p>
            <p class="mt-2 text-xl font-semibold text-rose-700"><%= number_to_currency(account_flow_payload[:charged_total]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Paid To</p>
            <p class="mt-2 text-xl font-semibold text-emerald-700"><%= number_to_currency(account_flow_payload[:paid_total]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Tracked Entries</p>
            <p class="mt-2 text-xl font-semibold text-slate-900"><%= account_flow_payload[:tracked_entries_count] %></p>
          </div>
        </div>

        <% if account_flow_payload[:account_count].positive? %>
          <div class="mt-4 h-80 rounded-xl border border-slate-200 bg-white/70 p-3">
            <canvas
              data-controller="chart"
              data-chart-type-value="bar"
              data-chart-title-value="Charged vs Paid To by Account"
              data-chart-labels-value="<%= account_flow_payload[:labels].to_json %>"
              data-chart-datasets-value="<%= [
                {
                  label: 'Charged',
                  data: account_flow_payload[:charged_values],
                  backgroundColor: 'rgba(244, 63, 94, 0.55)'
                },
                {
                  label: 'Paid To',
                  data: account_flow_payload[:paid_values],
                  backgroundColor: 'rgba(16, 185, 129, 0.55)'
                }
              ].to_json %>"
              data-chart-options-value="<%= {
                indexAxis: 'y',
                scales: { x: { beginAtZero: true } }
              }.to_json %>"></canvas>
          </div>
        <% else %>
          <div class="mt-4 rounded-xl border border-dashed border-slate-300 bg-slate-50/80 px-4 py-6 text-sm text-slate-600">
            Add or link accounts on entries to see which accounts are being charged and which ones are receiving payments this month.
          </div>
        <% end %>

        <% if account_flow_payload[:top_account].present? || account_flow_payload[:untracked_entries_count].positive? %>
          <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-slate-600">
            <% if account_flow_payload[:top_account].present? %>
              <span class="rounded-full bg-sky-50 px-3 py-1 font-medium text-sky-700">
                Top activity: <%= account_flow_payload[:top_account][:name] %>
              </span>
            <% end %>
            <% if account_flow_payload[:untracked_entries_count].positive? %>
              <span class="rounded-full bg-amber-50 px-3 py-1 font-medium text-amber-800">
                <%= pluralize(account_flow_payload[:untracked_entries_count], "entry") %> missing account detail
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="grid gap-4 xl:grid-cols-2">
        <div class="rounded-lg border border-indigo-100 bg-white/90 p-3">
          <div class="h-72">
            <canvas
              data-controller="chart"
              data-chart-type-value="doughnut"
              data-chart-title-value="Outflow by Section"
              data-chart-labels-value="<%= section_labels.to_json %>"
              data-chart-data-value="<%= section_values.to_json %>"></canvas>
          </div>
        </div>

        <div class="rounded-lg border border-violet-100 bg-white/90 p-3">
          <div class="h-72">
            <canvas
              data-controller="chart"
              data-chart-type-value="line"
              data-chart-title-value="Running Net Cashflow"
              data-chart-labels-value="<%= line_labels.to_json %>"
              data-chart-data-value="<%= line_values.to_json %>"></canvas>
          </div>
        </div>
      </div>

      <div class="mt-4 grid gap-4 xl:grid-cols-1">
        <div class="rounded-lg border border-indigo-100 bg-white/90 p-3">
          <div class="h-72">
            <canvas
              data-controller="chart"
              data-chart-type-value="radar"
              data-chart-title-value="Spending Profile by Section"
              data-chart-labels-value="<%= section_labels.to_json %>"
              data-chart-datasets-value="<%= [
                {
                  label: 'Spent',
                  data: section_values,
                  backgroundColor: 'rgba(79, 70, 229, 0.2)',
                  borderColor: 'rgba(79, 70, 229, 0.9)',
                  borderWidth: 2,
                  pointBackgroundColor: 'rgba(79, 70, 229, 1)'
                }
              ].to_json %>"></canvas>
          </div>
        </div>
      </div>

      <div class="mt-4 grid gap-4 xl:grid-cols-2">
        <div class="rounded-lg border border-amber-100 bg-white/90 p-3">
          <div class="h-72">
            <canvas
              data-controller="chart"
              data-chart-type-value="bar"
              data-chart-title-value="Top Over-Budget Categories"
              data-chart-labels-value="<%= over_budget_labels.to_json %>"
              data-chart-data-value="<%= over_budget_values.to_json %>"
              data-chart-options-value="<%= {
                indexAxis: 'y',
                scales: { x: { beginAtZero: true } },
                plugins: { legend: { display: false } }
              }.to_json %>"></canvas>
          </div>
        </div>

        <div class="rounded-lg border border-emerald-100 bg-white/90 p-3">
          <div class="h-72">
            <canvas
              data-controller="chart"
              data-chart-type-value="line"
              data-chart-title-value="Cumulative Outflow Through Month"
              data-chart-labels-value="<%= cumulative_outflow_labels.to_json %>"
              data-chart-datasets-value="<%= [
                {
                  label: 'Outflow',
                  data: cumulative_outflow_values,
                  borderColor: 'rgba(16, 185, 129, 0.9)',
                  backgroundColor: 'rgba(16, 185, 129, 0.2)',
                  fill: true,
                  tension: 0.25
                }
              ].to_json %>"
              data-chart-options-value="<%= { scales: { y: { beginAtZero: true } } }.to_json %>"></canvas>
          </div>
        </div>
      </div>

    <% else %>
      <div class="space-y-4">
        <div class="rounded-lg border border-emerald-100 bg-white/80 p-3">
          <p class="text-xs uppercase tracking-wide text-slate-500">Budget Health</p>
          <p class="mt-1 text-base font-semibold <%= leftover >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
            <%= leftover >= 0 ? "On Track" : "Over Budget" %>
          </p>
          <p class="mt-1 text-xs text-slate-500">Savings rate: <%= savings_pct %>%</p>
        </div>

        <div class="rounded-lg border border-indigo-100 bg-white/90 p-3">
          <div class="h-56">
            <canvas
              data-controller="chart"
              data-chart-type-value="doughnut"
              data-chart-title-value="Outflow by Section"
              data-chart-labels-value="<%= section_labels.to_json %>"
              data-chart-data-value="<%= section_values.to_json %>"></canvas>
          </div>
        </div>

        <div class="rounded-lg border border-violet-100 bg-white/90 p-3">
          <div class="h-56">
            <canvas
              data-controller="chart"
              data-chart-type-value="line"
              data-chart-title-value="Running Net"
              data-chart-labels-value="<%= line_labels.to_json %>"
              data-chart-data-value="<%= line_values.to_json %>"></canvas>
          </div>
        </div>

        <div class="rounded-lg border border-amber-100 bg-white/90 p-3">
          <div class="h-56">
            <canvas
              data-controller="chart"
              data-chart-type-value="bar"
              data-chart-title-value="Top Over-Budget Categories"
              data-chart-labels-value="<%= over_budget_labels.to_json %>"
              data-chart-data-value="<%= over_budget_values.to_json %>"
              data-chart-options-value="<%= {
                indexAxis: 'y',
                scales: { x: { beginAtZero: true } },
                plugins: { legend: { display: false } }
              }.to_json %>"></canvas>
          </div>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
