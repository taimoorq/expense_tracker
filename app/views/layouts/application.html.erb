<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Expense Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Expense Tracker">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="<%= current_theme_meta_color %>">
    <meta name="turbo-view-transition" content="true">

    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png">
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png">
    <link rel="icon" href="/icon.png" sizes="512x512" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="ta-shell ta-shell-collapsed <%= current_theme_class %>" style="<%= current_theme_css_variables %>" data-rails-env="<%= Rails.env %>" data-controller="help-modal sidebar" data-action="keydown.esc->help-modal#closeOnEsc keydown.esc->sidebar#close click@window->sidebar#closeFromOutside resize@window->sidebar#syncMode" data-sidebar-target="shell">
    <% overview_active = controller_name == "overview" %>
    <% months_active = controller_name == "budget_months" || controller_name == "expense_entries" || controller_name == "imports" %>
    <% templates_active = controller_name == "planning_templates" || %w[pay_schedules subscriptions monthly_bills payment_plans credit_cards].include?(controller_name) %>
    <% accounts_active = controller_name == "accounts" || controller_name == "account_snapshots" %>
    <% backup_restore_active = controller_name == "backup_restores" %>
    <% settings_active = controller_name == "settings" %>
    <% new_month_active = controller_name == "budget_months" && action_name == "new" %>
    <% help_active = controller_name == "help" %>
    <% months_section_active = months_active || new_month_active %>
    <% show_back_nav = !((controller_name == "budget_months" && action_name == "index") || controller_name == "overview") %>

    <button type="button" class="ta-sidebar-overlay" aria-label="Close navigation" data-sidebar-target="overlay" data-action="click->sidebar#close"></button>

    <aside class="ta-sidebar" data-sidebar-target="sidebar">
      <div class="ta-sidebar-brand">
        <%= link_to(user_signed_in? ? root_path : new_user_session_path, class: "inline-flex items-center gap-2.5 text-slate-900", title: "Expense Tracker") do %>
          <%= image_tag "/logo.svg", alt: "Expense Tracker logo", class: "h-7 w-7 rounded" %>
          <span class="ta-sidebar-brand-text">Expense Tracker</span>
          <span class="ta-sidebar-brand-mini">ET</span>
        <% end %>
      </div>
      <% if user_signed_in? %>
        <div class="ta-sidebar-body">
          <nav class="ta-sidebar-nav">
            <%= link_to root_path, class: ["ta-sidebar-link", (overview_active ? "ta-sidebar-link-active" : nil)], title: "Overview", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("home", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Home</span>
            <% end %>

            <div class="ta-sidebar-group">
              <%= link_to budget_months_path, class: ["ta-sidebar-link", (months_section_active ? "ta-sidebar-link-active" : nil)], title: "Months", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
                <%= tabler_icon("calendar-month", classes: "ta-sidebar-link-icon") %>
                <span class="ta-sidebar-label">Months</span>
              <% end %>

              <div class="ta-sidebar-sublinks">
                <%= link_to new_budget_month_path, class: ["ta-sidebar-sublink", (new_month_active ? "ta-sidebar-sublink-active" : nil)], title: "Add Month", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
                  <%= tabler_icon("calendar-plus", classes: "ta-sidebar-sublink-icon") %>
                  <span class="ta-sidebar-label">Add Month</span>
                <% end %>
              </div>
            </div>

            <%= link_to planning_templates_path, class: ["ta-sidebar-link", (templates_active ? "ta-sidebar-link-active" : nil)], title: "Recurring Transactions", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("repeat", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Recurring</span>
            <% end %>

            <%= link_to accounts_path, class: ["ta-sidebar-link", (accounts_active ? "ta-sidebar-link-active" : nil)], title: "Accounts & Net Worth", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("credit-card", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Accounts & Net Worth</span>
            <% end %>

            <%= link_to backup_restore_path, class: ["ta-sidebar-link", (backup_restore_active ? "ta-sidebar-link-active" : nil)], title: "Backup & Restore", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("shield-lock", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Backup & Restore</span>
            <% end %>

            <%= link_to help_path, class: ["ta-sidebar-link", (help_active ? "ta-sidebar-link-active" : nil)], title: "Help & Documentation", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("help", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Help & Documentation</span>
              <% if unread_release_count.positive? %>
                <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-indigo-600 px-2 py-0.5 text-[11px] font-semibold text-white">
                  <%= unread_release_count %>
                </span>
              <% end %>
            <% end %>
          </nav>

          <div class="ta-sidebar-footer">
            <%= link_to settings_path, class: ["ta-sidebar-link", (settings_active ? "ta-sidebar-link-active" : nil)], title: "Settings", data: { action: "click->sidebar#closeOnMobile", turbo_frame: "_top" } do %>
              <%= tabler_icon("adjustments", classes: "ta-sidebar-link-icon") %>
              <span class="ta-sidebar-label">Settings</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>

    <main class="ta-main">
      <header class="ta-topbar">
        <div class="ta-topbar-row flex-wrap sm:flex-nowrap">
          <% if user_signed_in? %>
            <div class="flex w-full items-center justify-between gap-3 sm:hidden">
              <button type="button" class="ta-icon-btn" title="Toggle navigation" aria-label="Toggle navigation" aria-expanded="false" data-sidebar-target="toggleButton" data-action="click->sidebar#toggle">
                <span class="ta-mobile-toggle-icon" data-sidebar-target="mobileOpenIcon"><%= tabler_icon("menu-2", classes: "ta-action-icon-lg") %></span>
                <span class="ta-mobile-toggle-icon hidden" data-sidebar-target="mobileCloseIcon"><%= tabler_icon("x", classes: "ta-action-icon-lg") %></span>
                <span class="ta-desktop-toggle-icon hidden" data-sidebar-target="expandIcon"><%= tabler_icon("layout-sidebar-left-expand", classes: "ta-action-icon-lg") %></span>
                <span class="ta-desktop-toggle-icon hidden" data-sidebar-target="collapseIcon"><%= tabler_icon("layout-sidebar-left-collapse", classes: "ta-action-icon-lg") %></span>
              </button>

              <div class="ta-topbar-user-actions">
                <%= render "shared/user_menu" %>
              </div>
            </div>
          <% end %>

          <div class="ta-topbar-heading-group">
          <% if user_signed_in? %>
            <button type="button" class="ta-icon-btn hidden sm:inline-flex" title="Toggle navigation" aria-label="Toggle navigation" aria-expanded="false" data-sidebar-target="toggleButton" data-action="click->sidebar#toggle">
              <span class="ta-mobile-toggle-icon" data-sidebar-target="mobileOpenIcon"><%= tabler_icon("menu-2", classes: "ta-action-icon-lg") %></span>
              <span class="ta-mobile-toggle-icon hidden" data-sidebar-target="mobileCloseIcon"><%= tabler_icon("x", classes: "ta-action-icon-lg") %></span>
              <span class="ta-desktop-toggle-icon hidden" data-sidebar-target="expandIcon"><%= tabler_icon("layout-sidebar-left-expand", classes: "ta-action-icon-lg") %></span>
              <span class="ta-desktop-toggle-icon hidden" data-sidebar-target="collapseIcon"><%= tabler_icon("layout-sidebar-left-collapse", classes: "ta-action-icon-lg") %></span>
            </button>
          <% end %>
          <div class="min-w-0 flex-1">
            <% if content_for?(:page_header) %>
              <div class="ta-page-header">
                <%= yield :page_header %>
              </div>
            <% else %>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <h1 class="text-xl font-semibold tracking-tight text-slate-900"><%= content_for(:title) || "Expense Tracker" %></h1>
                <% if show_back_nav %>
                  <%= link_to root_path, class: "fb-btn-secondary ta-action-btn" do %>
                    <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
                    <span>Back to Home</span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
          </div>

          <% if user_signed_in? %>
            <div class="w-full sm:order-none sm:w-auto sm:flex-none lg:mx-4">
              <%= render "shared/month_jump" %>
            </div>

            <div class="hidden sm:flex ta-topbar-user-actions">
              <%= render "shared/user_menu" %>
            </div>
          <% else %>
            <div class="flex items-center gap-2">
              <%= link_to new_user_session_path, class: "fb-btn-secondary ta-action-btn" do %>
                <%= tabler_icon("login", classes: "ta-action-icon") %>
                <span>Sign in</span>
              <% end %>
              <%= link_to new_user_registration_path, class: "fb-btn-primary ta-action-btn" do %>
                <%= tabler_icon("user-plus", classes: "ta-action-icon") %>
                <span>Create account</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </header>

      <section class="ta-content">
        <%= render "shared/flash" %>

        <% if latest_unread_release.present? %>
          <section class="mb-4 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-4 shadow-sm">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-600">New update available</p>
                <h2 class="mt-1 text-lg font-semibold text-slate-900">
                  <%= latest_unread_release.label %>: <%= latest_unread_release.title %>
                </h2>
                <p class="mt-1 text-sm leading-6 text-slate-600"><%= latest_unread_release.summary %></p>
              </div>
              <div class="flex flex-wrap gap-2">
                <%= link_to help_releases_path, class: "fb-btn-secondary ta-action-btn border-indigo-200 bg-white text-indigo-700 hover:bg-indigo-100" do %>
                  <%= tabler_icon("sparkles", classes: "ta-action-icon") %>
                  <span>See what changed</span>
                <% end %>
                <%= button_to acknowledge_help_release_notes_path, method: :patch, params: { version: latest_unread_release.version }, class: "fb-btn-primary ta-action-btn" do %>
                  <%= tabler_icon("check", classes: "ta-action-icon") %>
                  <span>Mark as read</span>
                <% end %>
              </div>
            </div>
          </section>
        <% end %>

        <div class="mt-4">
          <%= yield %>
        </div>
      </section>
    </main>

    <%= render "shared/help_modal" %>
  </body>
</html>
