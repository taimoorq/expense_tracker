<%= form_with model: account, class: "space-y-6", data: { controller: "account-form" } do |form| %>
  <% if account.errors.any? %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
      <p class="font-semibold">Fix the highlighted account details.</p>
      <ul class="mt-2 space-y-1">
        <% account.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= form.label :name, class: "fb-label" %>
      <%= form.text_field :name, class: "fb-input", placeholder: "Emergency Savings" %>
    </div>

    <div>
      <%= form.label :institution_name, "Institution", class: "fb-label" %>
      <%= form.text_field :institution_name, class: "fb-input", placeholder: "Ally, Vanguard, Chase..." %>
    </div>

    <div>
      <%= form.label :kind, "Account type", class: "fb-label" %>
      <%= form.select :kind, Account.kinds.keys.map { |kind| [kind.humanize, kind] }, {}, class: "fb-select", data: { account_form_target: "kind", action: "account-form#kindChanged" } %>
    </div>

    <div class="flex items-center gap-6 pt-7">
      <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        <%= form.check_box :active, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
        <span>Active account</span>
      </label>
      <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        <%= form.check_box :include_in_net_worth, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
        <span>Include in net worth</span>
      </label>
      <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        <%= form.check_box :include_in_cash, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
        <span>Include in cash totals</span>
      </label>
    </div>
  </div>

  <div>
    <%= form.label :notes, class: "fb-label" %>
    <%= form.text_area :notes, rows: 3, class: "fb-input", placeholder: "Optional notes about this account" %>
  </div>

  <% if local_assigns[:credit_card_payment_schedule] %>
    <% schedule_enabled = local_assigns.fetch(:credit_card_payment_schedule_enabled, false) %>
    <% payment_accounts = current_user.accounts.assets.active_first %>
    <section class="<%= account.credit_card? ? '' : 'hidden' %> rounded-2xl border border-slate-200 bg-slate-50/80 p-5" data-account-form-target="schedulePanel">
      <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
        <div>
          <h3 class="text-base font-semibold text-slate-900">Monthly card payment</h3>
          <p class="mt-1 text-sm text-slate-500">Create the recurring payment estimate linked to this card account.</p>
        </div>
        <label class="inline-flex items-center gap-2 text-sm font-medium text-slate-700">
          <%= hidden_field_tag "account[credit_card_payment_schedule][enabled]", "0" %>
          <%= check_box_tag "account[credit_card_payment_schedule][enabled]", "1", schedule_enabled, class: "fb-checkbox", data: { account_form_target: "scheduleToggle", action: "account-form#scheduleToggled" } %>
          <span>Schedule monthly payment</span>
        </label>
      </div>

      <% if credit_card_payment_schedule.errors.any? %>
        <div class="mb-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
          <p class="font-semibold">Fix the card payment details.</p>
          <ul class="mt-2 space-y-1">
            <% credit_card_payment_schedule.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= fields_for "account[credit_card_payment_schedule]", credit_card_payment_schedule do |schedule_fields| %>
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <%= schedule_fields.label :payment_account_id, "Money leaves account", class: "fb-label" %>
            <%= schedule_fields.collection_select :payment_account_id, payment_accounts, :id, :name, { include_blank: "Select checking, savings, or cash" }, class: "fb-select", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } %>
            <p class="mt-1 text-xs text-slate-500">Choose the account that will make the monthly card payment.</p>
          </div>

          <div>
            <%= schedule_fields.label :minimum_payment, "Monthly payment amount", class: "fb-label" %>
            <%= schedule_fields.number_field :minimum_payment, step: "0.01", min: "0", class: "fb-input", placeholder: "45.00", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } %>
          </div>

          <div>
            <%= schedule_fields.label :due_day, "Due day", class: "fb-label" %>
            <%= schedule_fields.number_field :due_day, min: 1, max: 31, class: "fb-input", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } %>
          </div>

          <div>
            <%= schedule_fields.label :priority, class: "fb-label" %>
            <%= schedule_fields.number_field :priority, min: 1, class: "fb-input", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } %>
          </div>

          <label class="inline-flex items-center gap-2 text-sm text-slate-700">
            <%= schedule_fields.check_box :active, { class: "fb-checkbox", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } }, "1", "0" %>
            <span>Active schedule</span>
          </label>

          <div class="md:col-span-2">
            <%= schedule_fields.label :notes, "Schedule notes", class: "fb-label" %>
            <%= schedule_fields.text_area :notes, rows: 2, class: "fb-input", placeholder: "Optional note about this payment", disabled: !schedule_enabled, data: { account_form_target: "scheduleInput" } %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if local_assigns[:initial_snapshot] %>
    <section class="rounded-3xl border border-slate-200 bg-slate-50/80 p-5">
      <div class="mb-4">
        <h3 class="text-base font-semibold text-slate-900">Optional first balance snapshot</h3>
        <p class="mt-1 text-sm text-slate-500">This is a reconciliation point you control. Leave the balance blank if you only want to create the account for now.</p>
      </div>

      <% if initial_snapshot.errors.any? %>
        <div class="mb-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
          <p class="font-semibold">Fix the initial balance details.</p>
          <ul class="mt-2 space-y-1">
            <% initial_snapshot.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form.fields_for :initial_snapshot, initial_snapshot do |snapshot_fields| %>
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <%= snapshot_fields.label :recorded_on, class: "fb-label" %>
            <%= snapshot_fields.date_field :recorded_on, class: "fb-input" %>
          </div>

          <div>
            <%= snapshot_fields.label :balance, class: "fb-label" %>
            <%= snapshot_fields.number_field :balance, step: "0.01", class: "fb-input", placeholder: account.liability? ? "-4500.00" : "15000.00" %>
          </div>

          <div>
            <%= snapshot_fields.label :available_balance, class: "fb-label" %>
            <%= snapshot_fields.number_field :available_balance, step: "0.01", class: "fb-input", placeholder: "Optional" %>
          </div>
        </div>

        <div class="mt-4">
          <%= snapshot_fields.label :notes, "Opening balance notes", class: "fb-label" %>
          <%= snapshot_fields.text_area :notes, rows: 2, class: "fb-input", placeholder: "Optional note about the opening balance" %>
        </div>
      <% end %>
    </section>
  <% end %>

  <div class="flex flex-wrap items-center gap-3">
    <%= form.submit class: "fb-btn-primary" %>
    <% if account.persisted? %>
      <%= link_to account_path(account), class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Back to Account</span>
      <% end %>
    <% else %>
      <%= link_to accounts_path, class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Back to Accounts</span>
      <% end %>
    <% end %>
  </div>
<% end %>
