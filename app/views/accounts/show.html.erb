<% content_for :title, @account.name %>
<% persisted_snapshots = @account.account_snapshots.select(&:persisted?).sort_by { |snapshot| [snapshot.recorded_on, snapshot.created_at] }.reverse %>

<% content_for :page_header do %>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= @account.kind.humanize %></p>
      <h2 class="text-2xl font-semibold"><%= @account.name %></h2>
      <p class="mt-1 text-sm text-slate-600"><%= @account.institution_name.presence || "Manual account" %></p>
    </div>
    <div class="flex w-full flex-wrap gap-2 sm:w-auto sm:justify-end">
      <%= link_to edit_account_path(@account), class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("edit", classes: "ta-action-icon text-slate-600") %>
        <span>Edit Account</span>
      <% end %>
      <%= link_to accounts_path, class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Back to Accounts</span>
      <% end %>
    </div>
  </div>
<% end %>

<div class="grid gap-6 xl:grid-cols-[minmax(0,1.7fr)_360px]">
  <section class="space-y-6">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Latest Balance</p>
        <p class="mt-2 text-3xl font-semibold <%= (@account.latest_balance || 0) >= 0 ? 'text-slate-900' : 'text-rose-700' %>"><%= @account.latest_snapshot ? number_to_currency(@account.latest_snapshot.balance) : "No balance yet" %></p>
      </article>
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Latest Snapshot</p>
        <p class="mt-2 text-3xl font-semibold text-slate-900"><%= @account.latest_snapshot ? l(@account.latest_snapshot.recorded_on, format: :long) : "-" %></p>
      </article>
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Net Worth Setting</p>
        <p class="mt-2 text-3xl font-semibold text-slate-900"><%= @account.include_in_net_worth? ? "Included" : "Excluded" %></p>
      </article>
    </div>

    <section class="ta-card min-w-0">
      <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
        <div>
          <h2 class="ta-section-title">Balance history</h2>
          <p class="ta-muted mt-1">Each manual snapshot captures the account value for a specific date.</p>
        </div>
        <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
          <%= pluralize(persisted_snapshots.count, "snapshot") %>
        </div>
      </div>

      <% if persisted_snapshots.any? %>
        <div class="space-y-3 md:hidden">
          <% persisted_snapshots.each do |snapshot| %>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Recorded On</p>
                  <p class="mt-1 text-sm font-semibold text-slate-900"><%= l(snapshot.recorded_on, format: :long) %></p>
                </div>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= number_to_currency(snapshot.balance) %></span>
              </div>

              <dl class="mt-4 grid gap-3 sm:grid-cols-2">
                <div class="rounded-xl bg-slate-50 px-3 py-2.5">
                  <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Available</dt>
                  <dd class="mt-1 text-sm font-medium text-slate-900"><%= snapshot.available_balance.present? ? number_to_currency(snapshot.available_balance) : "-" %></dd>
                </div>
                <div class="rounded-xl bg-slate-50 px-3 py-2.5 sm:col-span-2">
                  <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Notes</dt>
                  <dd class="mt-1 text-sm font-medium text-slate-900"><%= snapshot.notes.presence || "-" %></dd>
                </div>
              </dl>

              <div class="mt-4 flex flex-wrap gap-2">
                <%= link_to edit_account_account_snapshot_path(@account, snapshot), class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm" do %>
                  <%= tabler_icon("edit", classes: "ta-action-icon text-slate-600") %>
                  <span>Edit</span>
                <% end %>
                <%= button_to account_account_snapshot_path(@account, snapshot), method: :delete, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", form: { data: { turbo_confirm: "Delete this snapshot?" } } do %>
                  <%= tabler_icon("trash", classes: "ta-action-icon text-rose-600") %>
                  <span>Delete</span>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>

        <div class="hidden overflow-x-auto md:block">
          <table class="ta-table">
            <thead class="ta-table-head">
              <tr>
                <th class="ta-th">Recorded On</th>
                <th class="ta-th text-right">Balance</th>
                <th class="ta-th text-right">Available</th>
                <th class="ta-th">Notes</th>
                <th class="ta-th text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% persisted_snapshots.each do |snapshot| %>
                <tr>
                  <td class="ta-td"><%= l(snapshot.recorded_on, format: :long) %></td>
                  <td class="ta-td text-right"><%= number_to_currency(snapshot.balance) %></td>
                  <td class="ta-td text-right"><%= snapshot.available_balance.present? ? number_to_currency(snapshot.available_balance) : "-" %></td>
                  <td class="ta-td"><%= snapshot.notes.presence || "-" %></td>
                  <td class="ta-td">
                    <div class="flex justify-end gap-2">
                      <%= link_to edit_account_account_snapshot_path(@account, snapshot), class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs" do %>
                        <%= tabler_icon("edit", classes: "ta-action-icon text-slate-600") %>
                        <span>Edit</span>
                      <% end %>
                      <%= button_to account_account_snapshot_path(@account, snapshot), method: :delete, class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs" do %>
                        <%= tabler_icon("trash", classes: "ta-action-icon text-rose-600") %>
                        <span>Delete</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center">
          <p class="text-lg font-semibold text-slate-900">No snapshots yet</p>
          <p class="mt-2 text-sm text-slate-500">Record the current balance to start tracking this account over time.</p>
        </div>
      <% end %>
    </section>
  </section>

  <aside class="space-y-6">
    <section class="ta-card h-fit xl:sticky xl:top-6">
      <div class="mb-4">
        <h2 class="ta-section-title inline-flex items-center gap-2">
          <%= tabler_icon("plus", classes: "ta-action-icon-lg text-indigo-600") %>
          Record balance
        </h2>
        <p class="ta-muted mt-1">Add a manual snapshot whenever you review this account.</p>
      </div>

      <%= render "snapshot_form", account: @account, account_snapshot: @account_snapshot %>
    </section>
  </aside>
</div>