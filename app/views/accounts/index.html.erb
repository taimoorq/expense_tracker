<% content_for :title, "Accounts" %>
<% breadcrumb "Accounts" %>

<% content_for :head do %>
  <%= chart_library_tags %>
<% end %>

<% content_for :page_header do %>
  <div class="flex flex-wrap items-center gap-3">
    <div>
      <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
        <%= tabler_icon("credit-card", classes: "h-6 w-6 text-indigo-600") %>
        <span>Accounts</span>
      </h2>
      <p class="mt-1 text-sm text-slate-600">Track savings, investment, cash, and debt balances from the latest trusted source: institution imports when available, otherwise manual snapshots.</p>
    </div>
  </div>
<% end %>

<div class="grid gap-6 xl:grid-cols-[minmax(0,1.7fr)_360px]">
  <section class="space-y-6">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Assets</p>
        <p class="mt-2 text-3xl font-semibold text-emerald-700"><%= number_to_currency(@assets_total) %></p>
        <p class="mt-1 text-sm text-slate-500">Final current balances from accounts included in net worth.</p>
      </article>
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Liabilities</p>
        <p class="mt-2 text-3xl font-semibold text-rose-700"><%= number_to_currency(@liabilities_total) %></p>
        <p class="mt-1 text-sm text-slate-500">Shown as positive total debt for readability.</p>
      </article>
      <article class="ta-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Net Worth</p>
        <p class="mt-2 text-3xl font-semibold <%= @net_worth_total >= 0 ? 'text-slate-900' : 'text-rose-700' %>"><%= number_to_currency(@net_worth_total) %></p>
        <p class="mt-1 text-sm text-slate-500"><%= pluralize(@net_worth_accounts.count, "account") %> included. Imports and paid linked entries are reflected from their trusted sources.</p>
      </article>
    </div>

    <section class="rounded-2xl border border-emerald-100 bg-emerald-50/70 px-5 py-4 text-sm leading-6 text-emerald-900">
      <div class="flex items-start gap-3">
        <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl bg-white text-emerald-700">
          <%= tabler_icon("shield-lock", classes: "h-5 w-5") %>
        </span>
        <div>
          <p class="font-semibold">Account tracking stays under your control.</p>
          <p class="mt-1">The app does not need bank credentials. CSV imports can refresh institution-reported balances, and manual snapshots remain the fallback trusted source.</p>
        </div>
      </div>
    </section>

    <div class="grid gap-4 xl:grid-cols-[minmax(0,1.6fr)_300px]">
      <section class="ta-card min-w-0">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="ta-section-title inline-flex items-center gap-2">
              <%= tabler_icon("chart-pie", classes: "h-5 w-5 text-indigo-600") %>
              <span>Net worth trend</span>
            </h2>
            <p class="ta-muted mt-1">Snapshot-based trend for included accounts. Current totals above use imports when available.</p>
          </div>
          <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(@trend_labels.count, "point") %>
          </div>
        </div>

        <% if @trend_labels.any? %>
          <div class="h-80 rounded-2xl border border-slate-200 bg-white p-3">
            <canvas
              data-controller="chart"
              data-chart-type-value="line"
              data-chart-title-value="Net Worth History"
              data-chart-labels-value="<%= @trend_labels.to_json %>"
              data-chart-data-value="<%= @trend_values.to_json %>"></canvas>
          </div>
        <% else %>
          <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center">
            <p class="text-lg font-semibold text-slate-900">No trend yet</p>
            <p class="mt-2 text-sm text-slate-500">Record balance snapshots to build a net worth history chart.</p>
          </div>
        <% end %>
      </section>

      <section class="ta-card h-fit">
        <div class="mb-4">
          <h2 class="ta-section-title inline-flex items-center gap-2">
            <%= tabler_icon("calendar-month", classes: "ta-action-icon-lg text-indigo-600") %>
            Latest updated
          </h2>
          <p class="ta-muted mt-1">A quick read on how fresh your imported or manual balance sources are.</p>
        </div>

        <div class="space-y-4">
          <% latest_balance_source_date = @latest_balance_source&.activity_through_on || @latest_balance_source&.balance_source_recorded_on %>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Latest trusted source</p>
            <p class="mt-2 text-xl font-semibold text-slate-900"><%= latest_balance_source_date ? l(latest_balance_source_date, format: :long) : "No balance source yet" %></p>
            <p class="mt-1 text-sm text-slate-500"><%= @latest_balance_source ? "#{@latest_balance_source.account.name} · #{@latest_balance_source.balance_source_label}" : "Import activity or add a balance snapshot to start tracking updates." %></p>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Coverage</p>
            <p class="mt-2 text-xl font-semibold text-slate-900"><%= @accounts_with_balance_sources_count %> of <%= @accounts.count %></p>
            <p class="mt-1 text-sm text-slate-500"><%= pluralize(@accounts_missing_balance_sources_count, "account") %> still missing a trusted balance source.</p>
          </div>
        </div>
      </section>
    </div>

    <section class="ta-card min-w-0">
      <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
        <div>
          <h2 class="ta-section-title inline-flex items-center gap-2">
            <%= tabler_icon("building-library", classes: "h-5 w-5 text-indigo-600") %>
            <span>Tracked accounts</span>
          </h2>
          <p class="ta-muted mt-1">Create accounts once, then use CSV imports or manual snapshots whenever you want an updated view of cash, debt, and net worth.</p>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-2">
          <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(@accounts.count, "account") %>
          </div>
          <%= link_to new_account_path, class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("plus", classes: "ta-action-icon text-indigo-100") %>
            <span>New Account</span>
          <% end %>
        </div>
      </div>

      <% if @accounts.any? %>
        <div class="space-y-3 md:hidden">
          <% @account_balance_rows.each do |row| %>
            <% account = row.fetch(:account) %>
            <article id="<%= dom_id(account) %>" class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <%= link_to account.name, account_path(account), class: "text-base font-semibold text-indigo-600 hover:text-indigo-500" %>
                  <p class="mt-1 text-xs text-slate-500">
                    <%= account.active? ? "Active" : "Inactive" %>
                    <% unless account.include_in_net_worth? %>
                      <span class="ml-2 rounded-full bg-amber-100 px-2 py-0.5 text-amber-800">Excluded from net worth</span>
                    <% end %>
                  </p>
                </div>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= account.kind.humanize %></span>
              </div>

              <dl class="mt-4 grid gap-3 sm:grid-cols-2">
                <div class="rounded-xl bg-slate-50 px-3 py-2.5">
                  <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Institution</dt>
                  <dd class="mt-1 text-sm font-medium text-slate-900"><%= account.institution_name.presence || "-" %></dd>
                </div>
                <div class="rounded-xl bg-slate-50 px-3 py-2.5">
                  <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Current Balance</dt>
                  <dd class="mt-1 text-sm font-medium text-slate-900">
                    <% if row.fetch(:balance_available) %>
                      <%= number_to_currency(row.fetch(:current_balance)) %>
                    <% else %>
                      Needs source
                    <% end %>
                  </dd>
                </div>
                <div class="rounded-xl bg-slate-50 px-3 py-2.5 sm:col-span-2">
                  <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Balance Source</dt>
                  <dd class="mt-1 text-sm font-medium text-slate-900">
                    <%= row.fetch(:source_label) %><%= row.fetch(:source_date) ? " on #{l(row.fetch(:source_date), format: :long)}" : "" %>
                  </dd>
                  <% if row.fetch(:activity_through_on).present? %>
                    <dd class="mt-1 text-xs text-slate-500">Activity through <%= l(row.fetch(:activity_through_on), format: :long) %></dd>
                  <% elsif !row.fetch(:balance_available) && row.fetch(:imported_activity_count).positive? %>
                    <dd class="mt-1 text-xs text-slate-500">Imported rows need a balance source before this can be resolved.</dd>
                  <% end %>
                </div>
              </dl>

              <div class="mt-4 flex flex-wrap gap-2">
                <%= link_to account_path(account), class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm" do %>
                  <%= tabler_icon("cash", classes: "ta-action-icon text-emerald-600") %>
                  <span>View</span>
                <% end %>
                <%= link_to new_account_account_activity_import_path(account), class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm" do %>
                  <%= tabler_icon("upload", classes: "ta-action-icon text-indigo-600") %>
                  <span>Import</span>
                <% end %>
                <%= link_to edit_account_path(account), class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm" do %>
                  <%= tabler_icon("edit", classes: "ta-action-icon text-slate-600") %>
                  <span>Edit</span>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>

        <div class="hidden overflow-x-auto md:block">
          <table class="ta-table">
            <thead class="ta-table-head">
              <tr>
                <th class="ta-th">Account</th>
                <th class="ta-th">Institution</th>
                <th class="ta-th">Type</th>
                <th class="ta-th text-right">Latest Balance</th>
                <th class="ta-th text-right">Last Updated</th>
                <th class="ta-th text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% @account_balance_rows.each do |row| %>
                <% account = row.fetch(:account) %>
                <tr id="<%= dom_id(account) %>">
                  <td class="ta-td">
                    <div>
                      <%= link_to account.name, account_path(account), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                      <p class="mt-1 text-xs text-slate-500">
                        <%= account.active? ? "Active" : "Inactive" %>
                        <% unless account.include_in_net_worth? %>
                          <span class="ml-2 rounded-full bg-amber-100 px-2 py-0.5 text-amber-800">Excluded from net worth</span>
                        <% end %>
                      </p>
                    </div>
                  </td>
                  <td class="ta-td"><%= account.institution_name.presence || "-" %></td>
                  <td class="ta-td"><%= account.kind.humanize %></td>
                  <td class="ta-td text-right">
                    <% if row.fetch(:balance_available) %>
                      <div class="font-medium text-slate-900"><%= number_to_currency(row.fetch(:current_balance)) %></div>
                    <% else %>
                      <div class="font-medium text-slate-900">Needs source</div>
                    <% end %>
                    <% if row.fetch(:balance_available) && row.fetch(:activity_count).positive? %>
                      <div class="mt-1 text-xs text-slate-500"><%= pluralize(row.fetch(:activity_count), "activity row") %> included</div>
                    <% elsif !row.fetch(:balance_available) && row.fetch(:imported_activity_count).positive? %>
                      <div class="mt-1 text-xs text-slate-500">Imported rows need a balance source</div>
                    <% end %>
                  </td>
                  <td class="ta-td text-right">
                    <div><%= row.fetch(:last_updated_on) ? l(row.fetch(:last_updated_on), format: :long) : "Never" %></div>
                    <div class="mt-1 text-xs font-semibold text-indigo-700"><%= row.fetch(:source_label) %></div>
                    <% if row.fetch(:activity_through_on).present? && row.fetch(:source_date).present? && row.fetch(:activity_through_on) != row.fetch(:source_date) %>
                      <div class="mt-1 text-xs text-slate-500">Source: <%= l(row.fetch(:source_date), format: :long) %></div>
                    <% end %>
                  </td>
                  <td class="ta-td">
                    <div class="flex justify-end gap-2">
                      <%= link_to account_path(account), class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs" do %>
                        <%= tabler_icon("cash", classes: "ta-action-icon text-emerald-600") %>
                        <span>View</span>
                      <% end %>
                      <%= link_to new_account_account_activity_import_path(account), class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs" do %>
                        <%= tabler_icon("upload", classes: "ta-action-icon text-indigo-600") %>
                        <span>Import</span>
                      <% end %>
                      <%= link_to edit_account_path(account), class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs" do %>
                        <%= tabler_icon("edit", classes: "ta-action-icon text-slate-600") %>
                        <span>Edit</span>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-6 py-10 text-center">
          <p class="text-lg font-semibold text-slate-900">No accounts yet</p>
          <p class="mx-auto mt-2 max-w-xl text-sm leading-6 text-slate-500">Start by adding one real account you check often, such as checking or savings. Record a snapshot after that so current and projected balances have a trusted starting point.</p>
          <div class="mt-5 flex justify-center">
            <%= link_to new_account_path, class: "fb-btn-primary ta-action-btn" do %>
              <%= tabler_icon("plus", classes: "ta-action-icon text-indigo-100") %>
              <span>Add First Account</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  </section>

  <aside class="space-y-6">
    <section class="ta-card h-fit xl:sticky xl:top-6">
      <div class="mb-4">
        <h2 class="ta-section-title inline-flex items-center gap-2">
          <%= tabler_icon("document-text", classes: "ta-action-icon-lg text-indigo-600") %>
          Manual tracking
        </h2>
        <p class="ta-muted mt-1">No bank connection required. Add the accounts you care about, then refresh balances with institution CSV imports or manual snapshots.</p>
      </div>

      <div class="space-y-3 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
        <ol class="list-none space-y-3 p-0">
          <li class="flex gap-3">
            <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-xs font-semibold text-indigo-700">1</span>
            <span>Create one account per real-world account or balance bucket.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-semibold text-emerald-700">2</span>
            <span>Import institution activity or record a snapshot whenever you want a fresh trusted starting point.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-rose-100 text-xs font-semibold text-rose-700">3</span>
            <span>Use negative balances for debts like loans and credit cards.</span>
          </li>
        </ol>
      </div>

      <div class="mt-4">
        <%= link_to new_account_path, class: "fb-btn-secondary ta-action-btn w-full justify-center" do %>
          <%= tabler_icon("plus", classes: "ta-action-icon text-slate-600") %>
          <span>Add Account</span>
        <% end %>
      </div>
    </section>
  </aside>
</div>
