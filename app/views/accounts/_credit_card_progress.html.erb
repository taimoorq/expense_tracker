<% progress_width = credit_card_progress[:progress_percent] || 0 %>

<section class="ta-card overflow-hidden">
  <div class="mb-5 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h2 class="ta-section-title inline-flex items-center gap-2">
        <%= tabler_icon("target-arrow", classes: "h-5 w-5 text-emerald-600") %>
        <span>Credit card payoff progress</span>
      </h2>
      <p class="ta-muted mt-1">Month-to-date movement for <%= credit_card_progress[:month_label] %>, based on linked card activity.</p>
    </div>
    <% if credit_card_progress[:snapshot].present? %>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
        Since <%= l(credit_card_progress[:snapshot].recorded_on, format: :long) %>
      </span>
    <% end %>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-2xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Paid down this month</p>
      <p class="mt-2 text-2xl font-semibold text-emerald-800"><%= number_to_currency(credit_card_progress[:paid_down_this_month]) %></p>
      <p class="mt-1 text-xs text-emerald-900/75">Payments linked to this card.</p>
    </article>

    <article class="rounded-2xl border border-rose-100 bg-rose-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-rose-700">Added this month</p>
      <p class="mt-2 text-2xl font-semibold text-rose-800"><%= number_to_currency(credit_card_progress[:added_this_month]) %></p>
      <p class="mt-1 text-xs text-rose-900/75">Paid purchases recorded on this card.</p>
    </article>

    <article class="rounded-2xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Remaining balance</p>
      <p class="mt-2 text-2xl font-semibold text-sky-900"><%= number_to_currency(credit_card_progress[:current_debt]) %></p>
      <p class="mt-1 text-xs text-sky-900/75">Projected after planned payments: <%= number_to_currency(credit_card_progress[:projected_debt]) %></p>
    </article>
  </div>

  <div class="mt-5 rounded-2xl border border-slate-200 bg-white p-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-sm font-semibold text-slate-900">Progress toward payoff</p>
        <% if credit_card_progress[:snapshot_needed?] %>
          <p class="mt-1 text-sm text-slate-500">Record a credit card balance snapshot to start measuring payoff progress.</p>
        <% else %>
          <p class="mt-1 text-sm text-slate-500">
            Started at <%= number_to_currency(credit_card_progress[:starting_debt]) %>;
            <%= number_to_currency(credit_card_progress[:current_debt]) %> remains.
          </p>
        <% end %>
      </div>

      <% if credit_card_progress[:progress_percent].present? %>
        <span class="rounded-full bg-emerald-100 px-3 py-1 text-sm font-semibold text-emerald-800"><%= credit_card_progress[:progress_percent] %>%</span>
      <% else %>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-sm font-semibold text-slate-600">No snapshot</span>
      <% end %>
    </div>

    <div class="mt-4 h-3 overflow-hidden rounded-full bg-slate-100"
         role="progressbar"
         aria-label="Credit card payoff progress"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-valuenow="<%= progress_width %>">
      <div class="h-full rounded-full bg-emerald-500 transition-all duration-300" style="width: <%= progress_width %>%"></div>
    </div>

    <div class="mt-3 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
      <span class="<%= credit_card_progress[:net_paydown_this_month] >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
        Net payoff movement this month:
        <%= credit_card_progress[:net_paydown_this_month] >= 0 ? "+" : "-" %><%= number_to_currency(credit_card_progress[:net_paydown_this_month].abs) %>
      </span>
      <% if credit_card_progress[:planned_payment_remaining_this_month].positive? %>
        <span>Still planned this month: <%= number_to_currency(credit_card_progress[:planned_payment_remaining_this_month]) %></span>
      <% else %>
        <span>Planned payments appear here once scheduled for the rest of the month.</span>
      <% end %>
    </div>
  </div>
</section>
