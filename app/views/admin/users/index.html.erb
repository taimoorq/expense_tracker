<% content_for :title, "User Access" %>

<div class="space-y-6">
  <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5 text-sm leading-6 text-slate-600">
    This directory intentionally exposes only user identity and access-state metadata. Budget months, entries, templates, and account balances are not available in the admin surface.
  </div>

  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50">
        <tr class="text-left text-slate-500">
          <th class="px-6 py-4 font-medium">Email</th>
          <th class="px-6 py-4 font-medium">Status</th>
          <th class="px-6 py-4 font-medium">Created</th>
          <th class="px-6 py-4 font-medium"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each do |user| %>
          <tr>
            <td class="px-6 py-4 font-medium text-slate-900"><%= user.email %></td>
            <td class="px-6 py-4">
              <span class="rounded-full px-3 py-1 text-xs font-semibold <%= user.access_state_active? ? "bg-emerald-100 text-emerald-800" : "bg-amber-100 text-amber-800" %>">
                <%= user.access_state.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 text-slate-600"><%= user.created_at.to_date %></td>
            <td class="px-6 py-4 text-right"><%= link_to "Manage", admin_user_path(user), class: "font-semibold text-cyan-700 hover:text-cyan-900" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>