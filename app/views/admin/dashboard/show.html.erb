<% content_for :title, "Admin Overview" %>

<div class="space-y-6">
  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Active users</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @active_users_count %></p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Suspended users</p>
      <p class="mt-3 text-3xl font-semibold text-slate-950"><%= @suspended_users_count %></p>
    </div>

    <div class="rounded-3xl border border-cyan-200 bg-cyan-50 p-5 text-cyan-950">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-700">Boundary</p>
      <p class="mt-3 text-sm leading-6">This console can change access state and record admin actions. It does not expose budget months, entries, templates, or account balances.</p>
    </div>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-white p-6">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h3 class="text-lg font-semibold text-slate-950">Recent admin audit activity</h3>
        <p class="mt-1 text-sm text-slate-500">Most recent administrator actions captured by the app.</p>
      </div>
      <%= link_to "Manage users", admin_users_path, class: "fb-btn-secondary" %>
    </div>

    <div class="mt-5 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead>
          <tr class="text-left text-slate-500">
            <th class="py-3 pr-4 font-medium">When</th>
            <th class="py-3 pr-4 font-medium">Admin</th>
            <th class="py-3 pr-4 font-medium">Action</th>
            <th class="py-3 pr-4 font-medium">Target user</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @recent_audit_logs.each do |audit_log| %>
            <tr>
              <td class="py-3 pr-4 text-slate-600"><%= audit_log.created_at.strftime("%Y-%m-%d %H:%M") %></td>
              <td class="py-3 pr-4 text-slate-900"><%= audit_log.admin_user.email %></td>
              <td class="py-3 pr-4 text-slate-600"><%= audit_log.action %></td>
              <td class="py-3 pr-4 text-slate-900"><%= audit_log.target_user&.email || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>