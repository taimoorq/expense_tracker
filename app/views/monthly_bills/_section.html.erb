<%= turbo_frame_tag "monthly_bills_section" do %>
  <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h3 class="mb-3 text-lg font-semibold">3) Monthly Bills (fixed + variable)</h3>
    <%= form_with model: monthly_bill, url: monthly_bills_path, class: "grid gap-2 sm:grid-cols-2 lg:grid-cols-6" do |form| %>
      <%= hidden_field_tag :budget_month_id, budget_month.id %>
      <%= form.text_field :name, placeholder: "Mortgage, Pepco, Car payment...", required: true, class: "fb-input" %>
      <%= form.select :kind, MonthlyBill.kinds.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
      <%= form.number_field :default_amount, step: 0.01, placeholder: "Default/Estimated Amount", class: "fb-input" %>
      <%= form.number_field :due_day, min: 1, max: 31, placeholder: "Due day", required: true, class: "fb-input" %>
      <%= form.text_field :account, placeholder: "Account", class: "fb-input" %>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.submit "Save", class: "fb-btn-primary" %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= button_to "Generate Monthly Bills for #{budget_month.label}", generate_monthly_bills_budget_month_path(budget_month), method: :post, class: "rounded-md bg-slate-800 px-3 py-2 text-white hover:bg-slate-700" %>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Name</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Type</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Default</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Due Day</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% monthly_bills.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2"><%= item.kind.humanize %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.default_amount || 0) %></td>
              <td class="px-3 py-2 text-right"><%= item.due_day %></td>
              <td class="px-3 py-2">
                <%= button_to "Delete", monthly_bill_path(item, budget_month_id: budget_month.id), method: :delete, class: "rounded-md border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this monthly bill?" } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
