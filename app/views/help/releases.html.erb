<div class="space-y-6">
  <% content_for :page_header do %>
    <div class="flex flex-wrap items-center gap-3">
      <div>
        <h2 class="inline-flex items-center gap-2 text-2xl font-semibold text-slate-900">
          <%= tabler_icon("sparkles", classes: "h-6 w-6 text-emerald-600") %>
          <span>Release Notes</span>
        </h2>
        <p class="mt-1 text-sm text-slate-500">Version history and update details for this self-hosted app.</p>
      </div>
    </div>
  <% end %>

  <section class="rounded-xl border border-emerald-100 bg-emerald-50 p-5 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-2xl">
        <h3 class="inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
          <%= tabler_icon("sparkles", classes: "h-5 w-5 text-emerald-600") %>
          <span>What's new</span>
        </h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">Release notes ship with the app, so self-hosted deployments can show exactly what changed after each update.</p>
      </div>
      <div class="rounded-2xl border border-emerald-200 bg-white px-4 py-3 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">Current release</p>
        <p class="mt-1"><%= @latest_release&.label || "Unavailable" %></p>
      </div>
    </div>

    <% if @latest_unread_release.present? %>
      <div class="mt-4 rounded-xl border border-emerald-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600">Unread update</p>
        <h4 class="mt-2 text-base font-semibold text-slate-900"><%= @latest_unread_release.label %>: <%= @latest_unread_release.title %></h4>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= @latest_unread_release.summary %></p>
        <%= button_to acknowledge_help_release_notes_path, method: :patch, params: { version: @latest_unread_release.version }, class: "mt-4 fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon("check", classes: "ta-action-icon") %>
          <span>Mark latest release as read</span>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="space-y-4">
    <% @releases.each do |release| %>
      <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-lg font-semibold text-slate-900"><%= release.label %></h3>
              <% if release_unread?(release) %>
                <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-700">New to you</span>
              <% end %>
            </div>
            <p class="mt-1 text-sm font-medium text-slate-700"><%= release.title %></p>
          </div>
          <p class="text-sm text-slate-500"><%= formatted_release_date(release.released_on) %></p>
        </div>
        <p class="mt-3 text-sm leading-6 text-slate-600"><%= release.summary %></p>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-600">
          <% release.changes.each do |change| %>
            <li><strong class="text-slate-900">Change:</strong> <%= change %></li>
          <% end %>
        </ul>
      </article>
    <% end %>
  </section>
</div>
