<% breadcrumb "Months", budget_months_path(anchor: "quick-import") %>
<% breadcrumb "CSV Import Preview" %>

<% content_for :page_header do %>
  <div class="flex flex-wrap items-center gap-3">
    <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
      <%= tabler_icon("upload", classes: "h-6 w-6 text-indigo-600") %>
      <span>CSV Import Preview</span>
    </h2>
  </div>
<% end %>

<div class="mx-auto max-w-4xl space-y-6">
  <section class="ta-card">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <h3 class="text-lg font-semibold text-slate-900">Review before importing</h3>
        <p class="mt-1 text-sm leading-6 text-slate-600">CSV import now previews row issues first. Confirming imports valid rows inside one transaction and skips exact duplicates.</p>
      </div>
      <%= link_to budget_months_path(anchor: "quick-import"), class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Back to Months</span>
      <% end %>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Months</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:months].to_i %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Entries</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:entries].to_i %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Duplicates</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:duplicates].to_i %></p>
      </div>
    </div>
  </section>

  <% if Array(@preview[:errors]).any? %>
    <section class="rounded-2xl border border-rose-200 bg-rose-50 p-5 text-sm text-rose-900">
      <p class="font-semibold">Fix these row errors before importing</p>
      <ul class="mt-3 list-disc space-y-1 pl-5">
        <% Array(@preview[:errors]).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <p class="mt-3 text-rose-800">No data was changed.</p>
    </section>
  <% end %>

  <% if Array(@preview[:warnings]).any? %>
    <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-900">
      <p class="font-semibold">Warnings</p>
      <ul class="mt-3 list-disc space-y-1 pl-5">
        <% Array(@preview[:warnings]).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @preview[:ok] %>
    <section class="ta-card">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="text-base font-semibold text-slate-900">Ready to import</h3>
          <p class="mt-1 text-sm text-slate-600">Confirm when the counts and warnings look right.</p>
        </div>
        <%= form_with url: import_csv_path, method: :post, data: { turbo: false } do %>
          <%= hidden_field_tag :preview_token, @preview_token %>
          <%= button_tag type: :submit, class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("upload", classes: "ta-action-icon text-indigo-100") %>
            <span>Import CSV</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
