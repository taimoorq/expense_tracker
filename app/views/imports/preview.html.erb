<% breadcrumb "Months", budget_months_path(anchor: "quick-import") %>
<% breadcrumb "CSV Import Preview" %>

<% page_header title: "CSV Import Preview",
  eyebrow: "Import ledger",
  subtitle: "Nothing has been written. Review the exact scope before confirming.",
  icon: "upload" %>

<% rows = Array(@preview[:rows]) %>
<% errors = Array(@preview[:errors]) %>
<% warnings = Array(@preview[:warnings]) %>
<% duplicate_rows = rows.select { |row| row[:duplicate] || row["duplicate"] } %>
<% importable_rows = rows - duplicate_rows %>

<div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
  <div class="min-w-0 space-y-5">
    <section class="ta-section-frame" aria-labelledby="import-scope-title">
      <div class="ta-section-header flex flex-wrap items-start justify-between gap-3">
        <div class="ta-ledger-rail"><p class="ta-page-eyebrow">Proposed change</p><h2 id="import-scope-title" class="ta-section-title mt-1">Rows that will be considered</h2><p class="mt-1 text-sm leading-6 text-slate-600">Valid rows import in one transaction. Exact duplicates are skipped, and any row error blocks the entire import.</p></div>
        <%= link_to budget_months_path(anchor: "quick-import"), class: "fb-btn-secondary ta-action-btn" do %><%= tabler_icon("arrow-left", classes: "ta-action-icon") %><span>Choose another file</span><% end %>
      </div>
      <dl class="grid divide-y divide-slate-200 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
        <% [["Months", @preview[:months].to_i, "text-slate-900"], ["Importable", @preview[:entries].to_i, "text-emerald-700"], ["Duplicates", @preview[:duplicates].to_i, "text-amber-700"], ["Row errors", errors.size, errors.any? ? "text-rose-700" : "text-emerald-700"]].each do |label, value, tone| %>
          <div class="px-4 py-4"><dt class="ta-ledger-label"><%= label %></dt><dd class="ta-number mt-1 text-2xl font-semibold <%= tone %>"><%= value %></dd></div>
        <% end %>
      </dl>
    </section>

    <% if errors.any? %>
      <section class="overflow-hidden rounded-[var(--ta-radius-md)] border border-rose-200 bg-rose-50" role="alert" aria-labelledby="import-errors-title">
        <div class="border-l-4 border-rose-500 px-4 py-3"><h2 id="import-errors-title" class="font-semibold text-rose-950">Fix these row errors before importing</h2><p class="mt-1 text-sm text-rose-800">No data was changed.</p></div>
        <ol class="max-h-72 list-decimal space-y-2 overflow-y-auto border-t border-rose-200 px-8 py-4 text-sm text-rose-900">
          <% errors.each do |message| %><li><%= message %></li><% end %>
        </ol>
      </section>
    <% end %>

    <% if warnings.any? %>
      <details class="group overflow-hidden rounded-[var(--ta-radius-md)] border border-amber-200 bg-amber-50" open>
        <summary class="flex min-h-12 cursor-pointer list-none items-center justify-between gap-3 px-4 py-3"><span class="font-semibold text-amber-950"><%= pluralize(warnings.size, "warning") %></span><%= tabler_icon("chevron-down", classes: "h-5 w-5 transition group-open:rotate-180") %></summary>
        <ul class="max-h-72 list-disc space-y-2 overflow-y-auto border-t border-amber-200 px-8 py-4 text-sm text-amber-900"><% warnings.each do |message| %><li><%= message %></li><% end %></ul>
      </details>
    <% end %>

    <section class="ta-section-frame" aria-labelledby="preview-rows-title">
      <div class="ta-section-header"><div class="ta-ledger-rail"><p class="ta-page-eyebrow">Bounded preview</p><h2 id="preview-rows-title" class="ta-section-title mt-1">Importable and duplicate rows</h2><p class="mt-1 text-sm text-slate-600">Showing the first <%= [rows.size, 100].min %> of <%= pluralize(rows.size, "parsed row") %>.</p></div></div>
      <% if rows.any? %>
        <div class="max-h-[34rem] overflow-auto">
          <table class="ta-table">
            <thead class="ta-table-head sticky top-0 z-10 bg-white"><tr><th class="ta-th">Row</th><th class="ta-th">Month / date</th><th class="ta-th">Description</th><th class="ta-th text-right">Planned</th><th class="ta-th">Result</th></tr></thead>
            <tbody class="divide-y divide-slate-200">
              <% rows.first(100).each do |row| %>
                <% duplicate = row[:duplicate] || row["duplicate"] %>
                <tr class="<%= duplicate ? 'bg-amber-50/60' : nil %>">
                  <td class="ta-td ta-number"><%= row[:row_number] || row["row_number"] %></td>
                  <td class="ta-td"><span class="block"><%= row[:month_on] || row["month_on"] %></span><span class="text-xs text-slate-500"><%= row[:occurred_on] || row["occurred_on"] %></span></td>
                  <td class="ta-td"><span class="block font-medium text-slate-900"><%= row[:payee] || row["payee"] || "Month summary" %></span><span class="text-xs text-slate-500"><%= row[:category] || row["category"] %></span></td>
                  <td class="ta-td ta-money text-right"><%= number_to_currency(row[:planned_amount] || row["planned_amount"] || row[:leftover] || row["leftover"] || 0) %></td>
                  <td class="ta-td"><span class="ta-status-badge <%= duplicate ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' %>"><%= duplicate ? "Skip duplicate" : "Import" %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="ta-section-body text-sm text-slate-600">No valid rows were parsed from this file.</div>
      <% end %>
    </section>
  </div>

  <aside class="h-fit space-y-4 xl:sticky xl:top-6">
    <section class="ta-section-frame">
      <div class="ta-section-header"><div class="ta-ledger-rail"><p class="ta-page-eyebrow">Trust check</p><h2 class="ta-section-title mt-1"><%= @preview[:ok] ? "Ready to import" : "Import blocked" %></h2></div></div>
      <div class="ta-section-body space-y-3 text-sm leading-6 text-slate-600">
        <p><strong class="text-slate-900">Writes:</strong> <%= pluralize(@preview[:entries].to_i, "entry") %> across <%= pluralize(@preview[:months].to_i, "month") %>.</p>
        <p><strong class="text-slate-900">Skips:</strong> <%= pluralize(@preview[:duplicates].to_i, "exact duplicate") %>.</p>
        <p><strong class="text-slate-900">Transaction:</strong> either every importable row succeeds or none are saved.</p>
      </div>
      <% if @preview[:ok] %>
        <div class="border-t border-slate-200 p-4">
          <%= form_with url: import_csv_path, method: :post, data: { turbo: false } do %>
            <%= hidden_field_tag :preview_token, @preview_token %>
            <%= button_tag type: :submit, class: "fb-btn-primary ta-action-btn w-full justify-center" do %><%= tabler_icon("upload", classes: "ta-action-icon") %><span>Import <%= pluralize(@preview[:entries].to_i, "entry") %></span><% end %>
          <% end %>
        </div>
      <% end %>
    </section>
  </aside>
</div>
