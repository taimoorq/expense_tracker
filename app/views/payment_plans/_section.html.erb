<%= turbo_frame_tag "payment_plans_section" do %>
  <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h3 class="mb-3 text-lg font-semibold">4) Payment Plans (total due + custom monthly)</h3>
    <%= form_with model: payment_plan, url: payment_plans_path, class: "grid gap-2 sm:grid-cols-2 lg:grid-cols-7" do |form| %>
      <%= hidden_field_tag :budget_month_id, budget_month.id %>
      <%= form.text_field :name, placeholder: "Plan name", required: true, class: "fb-input" %>
      <%= form.number_field :total_due, step: 0.01, placeholder: "Total Due", required: true, class: "fb-input" %>
      <%= form.number_field :amount_paid, step: 0.01, placeholder: "Amount Paid", class: "fb-input" %>
      <%= form.number_field :monthly_target, step: 0.01, placeholder: "Custom Monthly", class: "fb-input" %>
      <%= form.number_field :due_day, min: 1, max: 31, placeholder: "Due day", required: true, class: "fb-input" %>
      <%= form.text_field :account, placeholder: "Account", class: "fb-input" %>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.submit "Save", class: "fb-btn-primary" %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= button_to "Add Payment Plans to #{budget_month.label}", generate_payment_plans_budget_month_path(budget_month), method: :post, class: "rounded-md bg-slate-800 px-3 py-2 text-white hover:bg-slate-700" %>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Name</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Total Due</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Paid</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Remaining</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Monthly</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% payment_plans.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.total_due) %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.amount_paid) %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.remaining_balance) %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.monthly_amount) %></td>
              <td class="px-3 py-2">
                <%= button_to "Delete", payment_plan_path(item, budget_month_id: budget_month.id), method: :delete, class: "rounded-md border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this payment plan?" } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
