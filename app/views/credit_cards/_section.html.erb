<%= turbo_frame_tag "credit_cards_section" do %>
  <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h3 class="mb-3 text-lg font-semibold">5) Credit Cards (estimate from leftover)</h3>
    <%= form_with model: credit_card, url: credit_cards_path, class: "grid gap-2 sm:grid-cols-2 lg:grid-cols-5" do |form| %>
      <%= hidden_field_tag :budget_month_id, budget_month.id %>
      <%= form.text_field :name, placeholder: "Card name", required: true, class: "fb-input" %>
      <%= form.number_field :minimum_payment, step: 0.01, placeholder: "Minimum", class: "fb-input" %>
      <%= form.number_field :priority, min: 1, placeholder: "Priority", required: true, class: "fb-input" %>
      <%= form.text_field :account, placeholder: "Account", class: "fb-input" %>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <%= form.submit "Save", class: "fb-btn-primary" %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= button_to "Estimate Credit Card Payments", estimate_credit_cards_budget_month_path(budget_month), method: :post, class: "rounded-md bg-slate-800 px-3 py-2 text-white hover:bg-slate-700" %>
    </div>

    <div class="mt-4 overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Card</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Minimum</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Priority</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% credit_cards.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.minimum_payment) %></td>
              <td class="px-3 py-2 text-right"><%= item.priority %></td>
              <td class="px-3 py-2">
                <%= button_to "Delete", credit_card_path(item, budget_month_id: budget_month.id), method: :delete, class: "rounded-md border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this card?" } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
