<% content_for :title, "Profile" %>

<div class="space-y-6">
  <section class="ta-card ta-surface-shell">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Account</p>
        <h2 class="mt-2 inline-flex items-center gap-2 text-2xl font-semibold text-slate-900">
          <%= tabler_icon("user-circle", classes: "h-6 w-6 text-indigo-600") %>
          <span>Your profile</span>
        </h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">Review your account details and current app preferences here, then jump into the right edit screen when you want to make a change.</p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to edit_user_registration_path, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon("pencil", classes: "ta-action-icon") %>
          <span>Edit profile</span>
        <% end %>

        <%= link_to settings_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("adjustments", classes: "ta-action-icon") %>
          <span>Edit settings</span>
        <% end %>
      </div>
    </div>
  </section>

  <section class="ta-card">
    <div class="flex items-start gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-100 text-slate-600">
        <%= tabler_icon("mail", classes: "h-5 w-5") %>
      </span>
      <div class="min-w-0">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Sign-in details</p>
        <h3 class="mt-2 text-lg font-semibold text-slate-900"><%= current_user.email %></h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">This is the email address you use to sign in. Password changes and account closure stay on the secure account edit page.</p>
      </div>
    </div>

    <dl class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Account status</dt>
        <dd class="mt-2 text-base font-semibold text-slate-900"><%= current_user.access_state.humanize %></dd>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Security</dt>
        <dd class="mt-2 text-base font-semibold text-slate-900">Password managed separately</dd>
      </div>
    </dl>
  </section>

  <section class="ta-card">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Preferences</p>
        <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
          <%= tabler_icon("settings", classes: "h-5 w-5 text-indigo-600") %>
          <span>Current settings</span>
        </h3>
        <p class="mt-2 text-sm leading-6 text-slate-600">Your workflow defaults and app appearance are managed in Settings. This summary gives you a quick snapshot without dropping straight into edit mode.</p>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">Current theme</p>
        <p class="mt-1"><%= current_theme.name %></p>
      </div>
    </div>

    <dl class="mt-5 grid gap-4 lg:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Default landing page</dt>
        <dd class="mt-2 text-base font-semibold text-slate-900"><%= landing_page_label(current_user.default_landing_page) %></dd>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Preferred month view</dt>
        <dd class="mt-2 text-base font-semibold text-slate-900"><%= preferred_month_view_label(current_user.preferred_month_view) %></dd>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Release notes</dt>
        <dd class="mt-2 text-base font-semibold text-slate-900">
          <%= unread_release_count.positive? ? "#{pluralize(unread_release_count, "update")} unread" : "Up to date" %>
        </dd>
      </div>
    </dl>
  </section>
</div>
