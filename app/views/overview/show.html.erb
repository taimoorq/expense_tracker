<% content_for :page_header do %>
  <div>
    <h2 class="text-2xl font-semibold">Overview</h2>
    <p class="ta-muted mt-1 hidden sm:block">Start here when you want the fastest path back into your budget workflow.</p>
  </div>
<% end %>

<div class="space-y-6">
  <% if @onboarding_visible %>
    <% step1_done = @accounts.any? %>
    <% step2_done = @template_total.positive? && @linked_template_total == @template_total %>
    <% step2_started = @template_total.positive? || @linked_template_total.positive? %>
    <% step3_done = @linked_entries_count.positive? %>
    <% step3_started = @current_month.present? || @current_month_entries.any? %>
    <% onboarding_complete = step1_done && step2_done && step3_done %>
    <section class="ta-card ta-surface-plan-soft">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">New User Onboarding</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-900">Build a linked monthly workflow</h3>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">Set up accounts first, link planning templates to those accounts, then generate or add entries so monthly views include clear account context.</p>
        </div>
        <span class="rounded-full px-3 py-1 text-xs font-semibold <%= onboarding_complete ? 'bg-emerald-100 text-emerald-800' : ((step1_done || step2_started || step3_started) ? 'bg-indigo-100 text-indigo-800' : 'bg-slate-100 text-slate-700') %>">
          <%= onboarding_complete ? "Complete" : ((step1_done || step2_started || step3_started) ? "In progress" : "Start here") %>
        </span>
      </div>

      <div class="mt-4 grid gap-3 md:grid-cols-3">
        <article class="rounded-2xl border bg-white/90 p-4 <%= step1_done ? 'border-emerald-200' : 'border-slate-200' %>">
          <div class="flex items-center justify-between gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Step 1</p>
            <span class="rounded-full px-2 py-0.5 text-[11px] font-semibold <%= step1_done ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>"><%= step1_done ? "Done" : "Next" %></span>
          </div>
          <h4 class="mt-2 text-sm font-semibold text-slate-900">Add accounts</h4>
          <p class="mt-1 text-xs leading-5 text-slate-600">Create checking, savings, card, or debt accounts first to establish linkage targets.</p>
          <p class="mt-3 text-xs font-semibold text-slate-700"><%= pluralize(@accounts.count, "account") %> set up</p>
        </article>
        <article class="rounded-2xl border bg-white/90 p-4 <%= step2_done ? 'border-emerald-200' : (step2_started ? 'border-indigo-200' : 'border-slate-200') %>">
          <div class="flex items-center justify-between gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Step 2</p>
            <span class="rounded-full px-2 py-0.5 text-[11px] font-semibold <%= step2_done ? 'bg-emerald-100 text-emerald-700' : (step2_started ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100 text-slate-600') %>"><%= step2_done ? "Done" : (step2_started ? "In progress" : "Next") %></span>
          </div>
          <h4 class="mt-2 text-sm font-semibold text-slate-900">Link planning templates</h4>
          <p class="mt-1 text-xs leading-5 text-slate-600">Attach paychecks, bills, subscriptions, plans, and cards to accounts where possible.</p>
          <p class="mt-3 text-xs font-semibold text-slate-700"><%= @linked_template_total %> of <%= @template_total %> templates linked</p>
        </article>
        <article class="rounded-2xl border bg-white/90 p-4 <%= step3_done ? 'border-emerald-200' : (step3_started ? 'border-indigo-200' : 'border-slate-200') %>">
          <div class="flex items-center justify-between gap-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Step 3</p>
            <span class="rounded-full px-2 py-0.5 text-[11px] font-semibold <%= step3_done ? 'bg-emerald-100 text-emerald-700' : (step3_started ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100 text-slate-600') %>"><%= step3_done ? "Done" : (step3_started ? "In progress" : "Next") %></span>
          </div>
          <h4 class="mt-2 text-sm font-semibold text-slate-900">Review linked month entries</h4>
          <p class="mt-1 text-xs leading-5 text-slate-600">Use monthly Budget and Plan and Edit views to verify entry status, amounts, and account alignment.</p>
          <p class="mt-3 text-xs font-semibold text-slate-700"><%= @linked_entries_count %> linked entries in <%= @current_month&.label || "current month" %></p>
        </article>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <%= link_to accounts_path, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon("credit-card", classes: "ta-action-icon text-indigo-100") %>
          <span>Set up Accounts</span>
        <% end %>
        <%= link_to planning_templates_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("template", classes: "ta-action-icon text-slate-600") %>
          <span>Manage and Link Templates</span>
        <% end %>
        <% if @current_month %>
          <%= link_to budget_month_path(@current_month, tab: "timeline"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("timeline", classes: "ta-action-icon text-slate-600") %>
            <span>Review Monthly Budget</span>
          <% end %>
        <% else %>
          <%= link_to new_budget_month_path, class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-plus", classes: "ta-action-icon text-slate-600") %>
            <span>Create First Month</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section>
    <details class="ta-card group">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
        <div>
          <h3 class="inline-flex items-center gap-2 text-base font-semibold text-slate-900">
            <%= tabler_icon("sparkles", classes: "h-4 w-4 text-indigo-600") %>
            <span>Quick Actions</span>
          </h3>
        </div>
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 transition group-open:rotate-180">
          <%= tabler_icon("chevron-down", classes: "ta-action-icon") %>
        </span>
      </summary>

      <div class="mt-3 grid gap-2 md:grid-cols-2 xl:grid-cols-5">
        <%= link_to new_budget_month_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">New Month</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Start a fresh month or clone from the latest one.</p>
        <% end %>

        <%= link_to(@current_month ? new_budget_month_path(source_month_id: @current_month.id) : budget_months_path(anchor: "existing-months"), class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50") do %>
          <p class="text-[13px] font-semibold text-slate-900">Clone Latest Month</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Reuse the most recent setup for the next available month.</p>
        <% end %>

        <%= link_to(@current_month ? new_wizard_budget_month_expense_entries_path(@current_month) : new_budget_month_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50", data: (@current_month ? { turbo_frame: "entry_wizard_modal" } : {})) do %>
          <p class="text-[13px] font-semibold text-slate-900">Add Entry with Wizard</p>
          <p class="mt-1 text-xs leading-5 text-slate-600"><%= @current_month ? "Open the guided wizard directly for the active month." : "Create a month first, then use the guided wizard for one-off items." %></p>
        <% end %>

        <%= link_to budget_months_path(anchor: "quick-import"), class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">Import CSV</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Jump to the upload card for a month import.</p>
        <% end %>

        <%= link_to accounts_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">Accounts & Net Worth</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Review balances, snapshots, and net worth history.</p>
        <% end %>
      </div>
    </details>
  </section>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,0.95fr)]">
    <article class="ta-card ta-surface-shell min-w-0">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Continue</p>
          <h3 class="mt-2 text-2xl font-semibold text-slate-900"><%= @current_month ? @current_month.label : "No active month yet" %></h3>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
            <%= @current_month ? "Jump back into the month most likely to need attention right now." : "Create a month first, then return here for faster shortcuts and review widgets." %>
          </p>
        </div>
        <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
          <%= @current_month&.month_on == Date.current.beginning_of_month ? "Current month" : (@current_month ? "Most recent month" : "Setup needed") %>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white/85 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Leftover</p>
          <p class="mt-2 text-2xl font-semibold <%= @current_month && @current_month.calculated_leftover >= 0 ? 'text-emerald-700' : 'text-slate-900' %>"><%= @current_month ? number_to_currency(@current_month.calculated_leftover) : "-" %></p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white/85 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Entries</p>
          <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @current_month ? @current_month_entries.count : 0 %></p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white/85 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Needs review</p>
          <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @current_month ? @review_attention_count : 0 %></p>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <% if @current_month %>
          <%= link_to budget_month_path(@current_month, tab: "timeline"), class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("timeline", classes: "ta-action-icon text-indigo-100") %>
            <span>Open Budget</span>
          <% end %>
          <%= link_to budget_month_path(@current_month, tab: "entries"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("list", classes: "ta-action-icon text-slate-600") %>
            <span>Open Plan and Edit</span>
          <% end %>
          <%= link_to budget_month_path(@current_month, tab: "calendar"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-month", classes: "ta-action-icon text-slate-600") %>
            <span>Open Calendar</span>
          <% end %>
        <% else %>
          <%= link_to new_budget_month_path, class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("calendar-plus", classes: "ta-action-icon text-indigo-100") %>
            <span>Create Month</span>
          <% end %>
          <%= link_to budget_months_path, class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-month", classes: "ta-action-icon text-slate-600") %>
            <span>Open Months</span>
          <% end %>
        <% end %>
      </div>

      <% if @recent_months.any? %>
        <div class="mt-5 border-t border-slate-200 pt-4">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Recent months</p>
          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            <% @recent_months.each do |month| %>
              <%= link_to budget_month_path(month), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white px-3 py-3 text-sm text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
                <span><%= month.label %></span>
                <span class="font-semibold"><%= number_to_currency(month.calculated_leftover) %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </article>

    <article class="ta-card ta-surface-plan-soft h-fit">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= @next_step[:badge] %></p>
      <h3 class="mt-3 text-xl font-semibold text-slate-900"><%= @next_step[:title] %></h3>
      <p class="mt-2 text-sm leading-6 text-slate-600"><%= @next_step[:description] %></p>

      <div class="mt-5 space-y-3">
        <%= link_to @next_step[:primary_path], class: "fb-btn-primary ta-action-btn w-full justify-center", data: (@next_step[:primary_turbo_frame] ? { turbo_frame: @next_step[:primary_turbo_frame] } : {}) do %>
          <%= tabler_icon("arrow-right", classes: "ta-action-icon text-indigo-100") %>
          <span><%= @next_step[:primary_label] %></span>
        <% end %>
        <%= link_to @next_step[:secondary_path], class: "fb-btn-secondary ta-action-btn w-full justify-center", data: (@next_step[:secondary_turbo_frame] ? { turbo_frame: @next_step[:secondary_turbo_frame] } : {}) do %>
          <%= tabler_icon("sparkles", classes: "ta-action-icon text-slate-600") %>
          <span><%= @next_step[:secondary_label] %></span>
        <% end %>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-200 bg-white/80 p-4 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">How this is chosen</p>
        <p class="mt-2 leading-6">The next-step card looks at whether you have a current month, saved templates, month entries, and unresolved attention items.</p>
      </div>
    </article>
  </section>

  <section class="grid gap-6 xl:grid-cols-3">
    <article class="ta-card ta-surface-edit-soft">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Attention Queue</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("check-circle", classes: "h-5 w-5 text-amber-600") %>
            <span>What needs review</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= @current_month ? "Counts are based on #{@current_month.label}." : "Create a month to start surfacing review items here." %></p>
        </div>
        <div class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800"><%= @current_month ? @review_attention_count : 0 %></div>
      </div>

      <div class="mt-4 space-y-3">
        <% [
          ["Still planned and due", @due_planned_count],
          ["Missing key details", @missing_details_count],
          ["Paid without actual", @paid_missing_actual_count]
        ].each do |label, count| %>
          <% if @current_month %>
            <%= link_to budget_month_path(@current_month, tab: "entries"), class: "flex items-center justify-between rounded-2xl border border-slate-200 bg-white/85 px-4 py-3 text-sm text-slate-700 transition hover:border-amber-200 hover:bg-amber-50" do %>
              <span><%= label %></span>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 font-semibold text-slate-700"><%= count %></span>
            <% end %>
          <% else %>
            <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white/70 px-4 py-3 text-sm text-slate-500">
              <span><%= label %></span>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 font-semibold text-slate-600">0</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </article>

    <article class="ta-card ta-surface-plan-soft">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Planning Templates</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("template", classes: "h-5 w-5 text-emerald-600") %>
            <span>Recurring setup status</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Saved templates reduce rebuilding each month, and linked templates carry account context into entries.</p>
        </div>
        <div class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800"><%= @template_total %> total</div>
      </div>

      <div class="mt-4 grid gap-2 sm:grid-cols-2">
        <%= link_to planning_templates_path(anchor: "pay-schedules"), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white/85 px-3 py-3 text-sm text-slate-700 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700" do %>
          <span>Pay schedules</span>
          <span class="font-semibold"><%= @template_counts[:pay_schedules] %></span>
        <% end %>
        <%= link_to planning_templates_path(anchor: "subscriptions"), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white/85 px-3 py-3 text-sm text-slate-700 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700" do %>
          <span>Subscriptions</span>
          <span class="font-semibold"><%= @template_counts[:subscriptions] %></span>
        <% end %>
        <%= link_to planning_templates_path(anchor: "monthly-bills"), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white/85 px-3 py-3 text-sm text-slate-700 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700" do %>
          <span>Monthly bills</span>
          <span class="font-semibold"><%= @template_counts[:monthly_bills] %></span>
        <% end %>
        <%= link_to planning_templates_path(anchor: "payment-plans"), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white/85 px-3 py-3 text-sm text-slate-700 transition hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700" do %>
          <span>Payment plans</span>
          <span class="font-semibold"><%= @template_counts[:payment_plans] %></span>
        <% end %>
      </div>

      <div class="mt-3 rounded-xl border border-slate-200 bg-white/80 px-3 py-2 text-xs text-slate-600">
        <span class="font-semibold text-slate-800"><%= @linked_template_total %></span> linked template<%= @linked_template_total == 1 ? "" : "s" %> currently connected to accounts.
      </div>

      <%= link_to planning_templates_path, class: "fb-btn-secondary ta-action-btn mt-4 w-full justify-center" do %>
        <%= tabler_icon("template", classes: "ta-action-icon text-slate-600") %>
        <span>Manage and Link Templates</span>
      <% end %>
    </article>

    <article class="ta-card ta-surface-shell">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Accounts Snapshot</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("cash", classes: "h-5 w-5 text-emerald-600") %>
            <span>Manual balance tracking</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Keep balances visible without bank sync, while linked entries keep account activity current in monthly workflows.</p>
        </div>
        <div class="rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-800"><%= pluralize(@accounts.count, "account") %></div>
      </div>

      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white/85 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Net worth</p>
          <p class="mt-2 text-2xl font-semibold <%= @net_worth_total >= 0 ? 'text-slate-900' : 'text-rose-700' %>"><%= number_to_currency(@net_worth_total) %></p>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white/85 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Latest snapshot</p>
          <p class="mt-2 text-sm font-semibold text-slate-900"><%= @latest_snapshot ? l(@latest_snapshot.recorded_on, format: :long) : "No snapshots yet" %></p>
          <p class="mt-1 text-xs text-slate-500"><%= @latest_snapshot ? @latest_snapshot.account.name : "Add an account balance to start tracking." %></p>
        </div>
      </div>

      <div class="mt-3 rounded-xl border border-slate-200 bg-white/80 px-3 py-2 text-xs text-slate-600">
        <span class="font-semibold text-slate-800"><%= @linked_entries_count %></span> linked month entr<%= @linked_entries_count == 1 ? "y" : "ies" %> in <%= @current_month&.label || "the active month" %> (<%= @linked_paid_entries_count %> paid).
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <%= link_to accounts_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("cash", classes: "ta-action-icon text-slate-600") %>
          <span>Open Accounts</span>
        <% end %>
        <%= link_to new_account_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("plus", classes: "ta-action-icon text-slate-600") %>
          <span>New Account</span>
        <% end %>
      </div>
    </article>
  </section>

  <%= render "expense_entries/entry_wizard_empty" if @current_month %>
</div>
