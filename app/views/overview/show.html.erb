<% content_for :head do %>
  <%= chart_library_tags %>
<% end %>

<% content_for :page_header do %>
  <div>
    <h2 class="text-2xl font-semibold">Overview</h2>
    <p class="ta-muted mt-1 hidden sm:block">Start here when you want the fastest path back into your budget workflow.</p>
  </div>
<% end %>

<% overview = @overview %>

<div class="space-y-6">
  <% if overview.onboarding_visible %>
    <section class="ta-card ta-surface-plan-soft">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">New User Onboarding</p>
          <h3 class="mt-2 text-xl font-semibold text-slate-900">Set up the month in the right order</h3>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">Start with accounts, then save the recurring transactions you expect, create a month and import them into it, and finally make manual updates as the real month unfolds.</p>
        </div>
        <span class="rounded-full px-3 py-1 text-xs font-semibold <%= overview.onboarding_status[:classes] %>">
          <%= overview.onboarding_status[:label] %>
        </span>
      </div>

      <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        <% overview.onboarding_steps.each do |step| %>
          <article class="rounded-2xl border bg-white/90 p-4 <%= step[:card_classes] %>">
            <div class="flex items-center justify-between gap-2">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Step <%= step[:number] %></p>
              <span class="rounded-full px-2 py-0.5 text-[11px] font-semibold <%= step[:badge_classes] %>"><%= step[:badge_label] %></span>
            </div>
            <h4 class="mt-2 text-sm font-semibold text-slate-900"><%= step[:title] %></h4>
            <p class="mt-1 text-xs leading-5 text-slate-600"><%= step[:description] %></p>
            <p class="mt-3 text-xs font-semibold text-slate-700"><%= step[:metric] %></p>
          </article>
        <% end %>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <%= link_to accounts_path, class: "fb-btn-primary ta-action-btn" do %>
          <%= tabler_icon("credit-card", classes: "ta-action-icon text-indigo-100") %>
          <span>Set up Accounts</span>
        <% end %>
        <%= link_to planning_templates_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("repeat", classes: "ta-action-icon text-slate-600") %>
          <span>Set Up Recurring</span>
        <% end %>
        <% if overview.current_month %>
          <%= link_to budget_month_tab_path(overview.current_month, "entries"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("list", classes: "ta-action-icon text-slate-600") %>
            <span>Import Recurring into Month</span>
          <% end %>
        <% else %>
          <%= link_to new_budget_month_path, class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-plus", classes: "ta-action-icon text-slate-600") %>
            <span>Create First Month</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section>
    <details class="ta-card group">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
        <div>
          <h3 class="inline-flex items-center gap-2 text-base font-semibold text-slate-900">
            <%= tabler_icon("sparkles", classes: "h-4 w-4 text-indigo-600") %>
            <span>Quick Actions</span>
          </h3>
        </div>
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 transition group-open:rotate-180">
          <%= tabler_icon("chevron-down", classes: "ta-action-icon") %>
        </span>
      </summary>

      <div class="mt-3 grid gap-2 md:grid-cols-2 xl:grid-cols-5">
        <%= link_to new_budget_month_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">New Month</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Start a fresh month or clone from the latest one.</p>
        <% end %>

        <%= link_to(overview.current_month ? new_budget_month_from_path(overview.current_month) : budget_months_path(anchor: "existing-months"), class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50") do %>
          <p class="text-[13px] font-semibold text-slate-900">Clone Latest Month</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Reuse the most recent setup for the next available month.</p>
        <% end %>

        <%= link_to(overview.current_month ? new_wizard_budget_month_expense_entries_path(overview.current_month) : new_budget_month_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50", data: (overview.current_month ? { turbo_frame: "entry_wizard_modal" } : {})) do %>
          <p class="text-[13px] font-semibold text-slate-900">Add Entry with Wizard</p>
          <p class="mt-1 text-xs leading-5 text-slate-600"><%= overview.current_month ? "Open the guided wizard directly for the active month." : "Create a month first, then use the guided wizard for one-off items." %></p>
        <% end %>

        <%= link_to budget_months_path(anchor: "quick-import"), class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">Import CSV</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Jump to the upload card for a month import.</p>
        <% end %>

        <%= link_to accounts_path, class: "rounded-xl border border-slate-200 bg-white px-3 py-3 text-left transition hover:-translate-y-0.5 hover:border-indigo-200 hover:bg-indigo-50" do %>
          <p class="text-[13px] font-semibold text-slate-900">Accounts & Net Worth</p>
          <p class="mt-1 text-xs leading-5 text-slate-600">Review balances, snapshots, and net worth history.</p>
        <% end %>
      </div>
    </details>
  </section>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,0.95fr)]">
    <article class="ta-card ta-surface-shell min-w-0">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Continue</p>
          <h3 class="mt-2 text-2xl font-semibold text-slate-900"><%= overview.continue_title %></h3>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600"><%= overview.continue_description %></p>
        </div>
        <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
          <%= overview.continue_badge_label %>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <% overview.continue_stats.each do |item| %>
          <%= render "overview/stat_card", item: item %>
        <% end %>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-2">
        <% if overview.current_month %>
          <%= link_to budget_month_tab_path(overview.current_month, "timeline"), class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("timeline", classes: "ta-action-icon text-indigo-100") %>
            <span>Open Budget</span>
          <% end %>
          <%= link_to budget_month_tab_path(overview.current_month, "entries"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("list", classes: "ta-action-icon text-slate-600") %>
            <span>Open Plan and Edit</span>
          <% end %>
          <%= link_to budget_month_tab_path(overview.current_month, "calendar"), class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-month", classes: "ta-action-icon text-slate-600") %>
            <span>Open Calendar</span>
          <% end %>
        <% else %>
          <%= link_to new_budget_month_path, class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon("calendar-plus", classes: "ta-action-icon text-indigo-100") %>
            <span>Create Month</span>
          <% end %>
          <%= link_to budget_months_path, class: "fb-btn-secondary ta-action-btn" do %>
            <%= tabler_icon("calendar-month", classes: "ta-action-icon text-slate-600") %>
            <span>Open Months</span>
          <% end %>
        <% end %>
      </div>

      <% if overview.recent_months.any? %>
        <div class="mt-5 border-t border-slate-200 pt-4">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Recent months</p>
          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            <% overview.recent_months.each do |month| %>
              <%= link_to budget_month_path(month), class: "flex items-center justify-between rounded-xl border border-slate-200 bg-white px-3 py-3 text-sm text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
                <span><%= month.label %></span>
                <span class="font-semibold"><%= number_to_currency(month.calculated_leftover) %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </article>

    <article class="ta-card ta-surface-plan-soft h-fit">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= overview.next_step_badge %></p>
      <h3 class="mt-3 text-xl font-semibold text-slate-900"><%= overview.next_step_title %></h3>
      <p class="mt-2 text-sm leading-6 text-slate-600"><%= overview.next_step_description %></p>

      <div class="mt-5 space-y-3">
        <%= link_to overview.next_step_primary_action[:path], class: "fb-btn-primary ta-action-btn w-full justify-center", data: (overview.next_step_primary_action[:turbo_frame] ? { turbo_frame: overview.next_step_primary_action[:turbo_frame] } : {}) do %>
          <%= tabler_icon("arrow-right", classes: "ta-action-icon text-indigo-100") %>
          <span><%= overview.next_step_primary_action[:label] %></span>
        <% end %>
        <%= link_to overview.next_step_secondary_action[:path], class: "fb-btn-secondary ta-action-btn w-full justify-center", data: (overview.next_step_secondary_action[:turbo_frame] ? { turbo_frame: overview.next_step_secondary_action[:turbo_frame] } : {}) do %>
          <%= tabler_icon("sparkles", classes: "ta-action-icon text-slate-600") %>
          <span><%= overview.next_step_secondary_action[:label] %></span>
        <% end %>
      </div>

      <div class="mt-5 rounded-2xl border border-slate-200 bg-white/80 p-4 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">How this is chosen</p>
        <p class="mt-2 leading-6">The next-step card looks at whether you have a current month, saved recurring transactions, month entries, and unresolved attention items.</p>
      </div>
    </article>
  </section>

  <section class="ta-card ta-surface-shell">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Cash Flow</p>
        <h3 class="mt-2 text-xl font-semibold text-slate-900"><%= overview.overview_cashflow_year %> money flow</h3>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">This visual combines all saved months in <%= overview.overview_cashflow_year %> so you can see how income has flowed into spending buckets and leftover cash across the year so far.</p>
      </div>
      <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
        <%= pluralize(overview.year_budget_months.count, "month") %>
      </div>
    </div>

    <% if overview.cashflow_available? %>
      <div
        class="mt-4 rounded-2xl border border-slate-200 bg-slate-50/80 p-3"
        data-controller="sankey-chart"
        data-sankey-chart-title-value="<%= overview.cashflow_chart_title %>"
        data-sankey-chart-loading-label-value="<%= overview.cashflow_chart_title %>"
        data-sankey-chart-timeout-ms-value="4000"
        data-sankey-chart-nodes-value="<%= overview.year_cashflow_payload[:nodes].to_json %>"
        data-sankey-chart-links-value="<%= overview.year_cashflow_payload[:links].to_json %>">
        <div data-sankey-chart-target="loading" class="flex h-[24rem] flex-col items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white/80 px-6 text-center">
          <div class="h-12 w-12 animate-spin rounded-full border-4 border-slate-200 border-t-indigo-500"></div>
          <p class="mt-4 text-sm font-semibold text-slate-900" data-loading-text>Loading the <%= overview.overview_cashflow_year %> cash flow graph…</p>
          <p class="mt-2 max-w-md text-sm leading-6 text-slate-500">We are preparing a year-to-date view of income, outflow buckets, and leftover cash.</p>
        </div>
        <div data-sankey-chart-target="error" class="hidden h-[24rem] rounded-xl border border-rose-200 bg-rose-50/80 px-6 py-8">
          <div class="flex h-full flex-col items-center justify-center text-center">
            <div class="rounded-full bg-white p-3 text-rose-600 shadow-sm">
              <%= tabler_icon("alert-circle", classes: "h-7 w-7") %>
            </div>
            <h4 class="mt-4 text-lg font-semibold text-rose-900">The <%= overview.overview_cashflow_year %> cash flow graph could not load</h4>
            <p class="mt-2 max-w-lg text-sm leading-6 text-rose-800" data-sankey-chart-target="errorMessage">Something went wrong while rendering this graph.</p>
          </div>
        </div>
        <div data-sankey-chart-target="chart" class="hidden h-[24rem] rounded-xl bg-white/70"></div>
      </div>

      <div class="mt-4 grid gap-3 lg:grid-cols-4">
        <% overview.cashflow_stat_cards.each do |item| %>
          <%= render "overview/stat_card", item: item %>
        <% end %>
      </div>

      <div class="mt-4 rounded-xl border border-amber-100 bg-amber-50/80 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-800">How to read this</p>
        <ul class="mt-2 space-y-2 text-sm leading-6 text-amber-900">
          <% overview.year_cashflow_payload[:limitations].each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50/80 px-6 py-8">
        <h4 class="text-lg font-semibold text-slate-900">No <%= overview.overview_cashflow_year %> cash flow to chart yet</h4>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">Once you have saved months with income and spending entries this year, this section will show how money has moved through the year so far.</p>
      </div>
    <% end %>
  </section>

  <%= render "overview/account_flow_panel", overview: overview %>

  <section class="grid gap-6 xl:grid-cols-3">
    <article class="ta-card ta-surface-edit-soft">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Attention Queue</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("check-circle", classes: "h-5 w-5 text-amber-600") %>
            <span>What needs review</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= overview.attention_queue_description %></p>
        </div>
        <div class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800"><%= overview.attention_queue_total %></div>
      </div>

      <div class="mt-4 space-y-3">
        <% overview.attention_items.each do |item| %>
          <% if overview.current_month %>
            <%= link_to budget_month_tab_path(overview.current_month, "entries"), class: "flex items-center justify-between rounded-2xl border border-slate-200 bg-white/85 px-4 py-3 text-sm text-slate-700 transition hover:border-amber-200 hover:bg-amber-50" do %>
              <span><%= item[:label] %></span>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 font-semibold text-slate-700"><%= item[:count] %></span>
            <% end %>
          <% else %>
            <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white/70 px-4 py-3 text-sm text-slate-500">
              <span><%= item[:label] %></span>
              <span class="rounded-full bg-slate-100 px-2.5 py-1 font-semibold text-slate-600">0</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </article>

    <article class="ta-card ta-surface-plan-soft">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Recurring</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("repeat", classes: "h-5 w-5 text-emerald-600") %>
            <span>Recurring setup status</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Saved recurring transactions reduce rebuilding each month, and linked recurring items carry account context into entries.</p>
        </div>
        <div class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800"><%= overview.template_total %> total</div>
      </div>

      <div class="mt-4 grid gap-2 sm:grid-cols-2">
        <% overview.recurring_breakdown_items.each do |item| %>
          <%= render "overview/linked_summary_item", item: item %>
        <% end %>
      </div>

      <div class="mt-3 rounded-xl border border-slate-200 bg-white/80 px-3 py-2 text-xs text-slate-600">
        <%= overview.recurring_linked_summary %>
      </div>

      <%= link_to planning_templates_path, class: "fb-btn-secondary ta-action-btn mt-4 w-full justify-center" do %>
        <%= tabler_icon("repeat", classes: "ta-action-icon text-slate-600") %>
        <span>Set Up Recurring</span>
      <% end %>
    </article>

    <article class="ta-card ta-surface-shell">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Accounts Snapshot</p>
          <h3 class="mt-2 inline-flex items-center gap-2 text-lg font-semibold text-slate-900">
            <%= tabler_icon("cash", classes: "h-5 w-5 text-emerald-600") %>
            <span>Manual balance tracking</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Keep balances visible without bank sync, then use the account activity row above to compare where linked month activity is landing.</p>
        </div>
        <div class="rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-800"><%= overview.accounts_badge_label %></div>
      </div>

      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <% overview.account_snapshot_cards.each do |item| %>
          <%= render "overview/stat_card", item: item %>
        <% end %>
      </div>

      <div class="mt-3 rounded-xl border border-slate-200 bg-white/80 px-3 py-2 text-xs text-slate-600">
        <%= overview.linked_entries_summary %>
      </div>

      <div class="mt-3 rounded-xl border border-slate-200 bg-white/80 px-3 py-2 text-xs text-slate-600">
        <span class="font-semibold text-slate-800">Auto-completion:</span> recurring-generated entries can automatically mark themselves paid when they become due.
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <%= link_to accounts_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("cash", classes: "ta-action-icon text-slate-600") %>
          <span>Open Accounts</span>
        <% end %>
        <%= link_to new_account_path, class: "fb-btn-secondary ta-action-btn" do %>
          <%= tabler_icon("plus", classes: "ta-action-icon text-slate-600") %>
          <span>New Account</span>
        <% end %>
      </div>
    </article>
  </section>

</div>
