<%= turbo_frame_tag "overview_account_flow", class: "block" do %>
  <% account_flow_payload = overview.fetch(:account_flow_payload) %>
  <% account_movement_payload = overview.fetch(:account_movement_payload) %>

  <section class="ta-card ta-surface-shell">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Account Movement</p>
        <h3 class="mt-2 text-xl font-semibold text-slate-900"><%= overview.account_flow_summary_title %></h3>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600"><%= overview.account_flow_summary_description %></p>
      </div>

      <%= form_with url: root_path,
                    method: :get,
                    class: "flex flex-wrap items-end justify-end gap-2",
                    data: {
                      turbo_frame: "overview_account_flow",
                      controller: "turbo-submit",
                      action: "turbo:submit-start->turbo-submit#submitStart turbo:submit-end->turbo-submit#submitEnd",
                      turbo_submit_default_label_value: "Apply",
                      turbo_submit_pending_label_value: "Updating..."
                    } do |form| %>
        <div>
          <label for="overview-account-flow-months" class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Months included</label>
          <%= form.select :account_flow_months,
                          options_for_select(overview.account_flow_month_window_options, overview.account_flow_month_window),
                          {},
                          {
                            id: "overview-account-flow-months",
                            class: "fb-select mt-2 min-w-[11rem]"
                          } %>
        </div>

        <%= form.button type: :submit,
                        class: "fb-btn-secondary inline-flex items-center gap-2 whitespace-nowrap",
                        data: { turbo_submit_target: "submitButton" } do %>
          <span class="hidden h-4 w-4 animate-spin rounded-full border-2 border-slate-300 border-t-slate-600" data-turbo-submit-target="submitSpinner"></span>
          <span data-turbo-submit-target="submitLabel">Apply</span>
        <% end %>
      <% end %>
    </div>

    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <% overview.account_flow_stat_cards.each do |item| %>
        <%= render "overview/stat_card", item: item %>
      <% end %>
    </div>

    <% if overview.account_flow_available? %>
      <div class="mt-4 h-80 rounded-2xl border border-slate-200 bg-slate-50/80 p-3">
        <canvas
          data-controller="chart"
          data-chart-type-value="bar"
          data-chart-title-value="<%= overview.account_flow_chart_title %>"
          data-chart-labels-value="<%= account_flow_payload[:labels].to_json %>"
          data-chart-datasets-value="<%= [
            {
              label: "Charged",
              data: account_flow_payload[:charged_values],
              backgroundColor: "rgba(244, 63, 94, 0.55)"
            },
            {
              label: "Paid To",
              data: account_flow_payload[:paid_values],
              backgroundColor: "rgba(16, 185, 129, 0.55)"
            }
          ].to_json %>"
          data-chart-options-value="<%= {
            indexAxis: "y",
            scales: { x: { beginAtZero: true } }
          }.to_json %>"></canvas>
      </div>
    <% else %>
      <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-slate-50/80 px-4 py-6 text-sm text-slate-600">
        Create months and link account details on entries to compare activity accounts, payments, and deposits here.
      </div>
    <% end %>

    <% if overview.account_flow_top_account_summary || overview.account_flow_untracked_entries_summary %>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-slate-600">
        <% if overview.account_flow_top_account_summary %>
          <span class="rounded-full bg-sky-50 px-3 py-1 font-medium text-sky-700"><%= overview.account_flow_top_account_summary %></span>
        <% end %>
        <% if overview.account_flow_untracked_entries_summary %>
          <span class="rounded-full bg-amber-50 px-3 py-1 font-medium text-amber-800"><%= overview.account_flow_untracked_entries_summary %></span>
        <% end %>
      </div>
    <% end %>

    <div class="mt-6 grid gap-4 xl:grid-cols-2">
      <section class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Credit Cards</p>
            <h4 class="mt-2 text-base font-semibold text-slate-900">Added vs paid off by month</h4>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(account_movement_payload[:credit_card][:account_count], "card") %>
          </span>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Added</p>
            <p class="mt-1 text-lg font-semibold text-rose-700"><%= number_to_currency(account_movement_payload[:credit_card][:added_total]) %></p>
          </div>
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Paid off</p>
            <p class="mt-1 text-lg font-semibold text-emerald-700"><%= number_to_currency(account_movement_payload[:credit_card][:paid_total]) %></p>
          </div>
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Planned</p>
            <p class="mt-1 text-lg font-semibold text-sky-700"><%= number_to_currency(account_movement_payload[:credit_card][:planned_payment_total]) %></p>
          </div>
        </div>

        <% if account_movement_payload[:credit_card][:datasets].any? %>
          <div class="mt-4 h-80 rounded-xl border border-slate-200 bg-white p-3">
            <canvas
              data-controller="chart"
              data-chart-type-value="bar"
              data-chart-title-value="Credit Card Monthly Movement"
              data-chart-labels-value="<%= account_movement_payload[:month_labels].to_json %>"
              data-chart-datasets-value="<%= account_movement_payload[:credit_card][:datasets].to_json %>"
              data-chart-options-value="<%= {
                scales: { x: { stacked: false }, y: { beginAtZero: true } }
              }.to_json %>"></canvas>
          </div>
          <details class="mt-4 rounded-xl border border-slate-200 bg-white">
            <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800">Review card movement entries</summary>
            <div class="border-t border-slate-100 px-4 py-3">
              <div class="space-y-2">
                <% account_movement_payload[:credit_card][:drilldowns].each do |item| %>
                  <%= link_to budget_month_account_movement_path(item.fetch(:budget_month_id), account_id: item.fetch(:account_id), movement_type: item.fetch(:movement_type)),
                              data: { turbo_frame: "_top" },
                              class: "flex flex-wrap items-center justify-between gap-2 rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 text-sm transition hover:border-indigo-200 hover:bg-indigo-50" do %>
                    <span class="font-medium text-slate-900"><%= item.fetch(:month_label) %> · <%= item.fetch(:account_name) %> · <%= item.fetch(:movement_label) %></span>
                    <span class="text-slate-600"><%= pluralize(item.fetch(:entry_count), "entry") %> · <%= number_to_currency(item.fetch(:amount)) %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </details>
        <% else %>
          <div class="mt-4 rounded-xl border border-dashed border-slate-300 bg-white/80 px-4 py-6 text-sm text-slate-600">
            Link credit card charges and card payments to accounts to see monthly card movement.
          </div>
        <% end %>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Bank Accounts</p>
            <h4 class="mt-2 text-base font-semibold text-slate-900">Money in, paid out, and left to pay</h4>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600">
            <%= pluralize(account_movement_payload[:bank_accounts][:account_count], "account") %>
          </span>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Money in</p>
            <p class="mt-1 text-lg font-semibold text-emerald-700"><%= number_to_currency(account_movement_payload[:bank_accounts][:money_in_total]) %></p>
          </div>
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Paid out</p>
            <p class="mt-1 text-lg font-semibold text-rose-700"><%= number_to_currency(account_movement_payload[:bank_accounts][:paid_out_total]) %></p>
          </div>
          <div class="rounded-xl border border-white bg-white px-3 py-2">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Left to pay</p>
            <p class="mt-1 text-lg font-semibold text-amber-700"><%= number_to_currency(account_movement_payload[:bank_accounts][:left_to_pay_total]) %></p>
          </div>
        </div>

        <% if account_movement_payload[:bank_accounts][:datasets].any? %>
          <div class="mt-4 h-80 rounded-xl border border-slate-200 bg-white p-3">
            <canvas
              data-controller="chart"
              data-chart-type-value="bar"
              data-chart-title-value="Bank Account Monthly Movement"
              data-chart-labels-value="<%= account_movement_payload[:month_labels].to_json %>"
              data-chart-datasets-value="<%= account_movement_payload[:bank_accounts][:datasets].to_json %>"
              data-chart-options-value="<%= {
                scales: { x: { stacked: false }, y: { beginAtZero: true } }
              }.to_json %>"></canvas>
          </div>
          <details class="mt-4 rounded-xl border border-slate-200 bg-white">
            <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-slate-800">Review bank movement entries</summary>
            <div class="border-t border-slate-100 px-4 py-3">
              <div class="space-y-2">
                <% account_movement_payload[:bank_accounts][:drilldowns].each do |item| %>
                  <%= link_to budget_month_account_movement_path(item.fetch(:budget_month_id), account_id: item.fetch(:account_id), movement_type: item.fetch(:movement_type)),
                              data: { turbo_frame: "_top" },
                              class: "flex flex-wrap items-center justify-between gap-2 rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 text-sm transition hover:border-indigo-200 hover:bg-indigo-50" do %>
                    <span class="font-medium text-slate-900"><%= item.fetch(:month_label) %> · <%= item.fetch(:account_name) %> · <%= item.fetch(:movement_label) %></span>
                    <span class="text-slate-600"><%= pluralize(item.fetch(:entry_count), "entry") %> · <%= number_to_currency(item.fetch(:amount)) %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </details>
        <% else %>
          <div class="mt-4 rounded-xl border border-dashed border-slate-300 bg-white/80 px-4 py-6 text-sm text-slate-600">
            Set a Money leaves / activity account on income and outflows to see monthly bank movement.
          </div>
        <% end %>
      </section>
    </div>
  </section>
<% end %>
