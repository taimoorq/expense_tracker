<% content_for :title, "Activity Import Preview" %>
<% breadcrumb "Accounts", accounts_path %>
<% breadcrumb @account.name, account_path(@account) %>
<% breadcrumb "Activity Import Preview" %>

<% content_for :page_header do %>
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= @account.name %></p>
    <h2 class="inline-flex items-center gap-2 text-2xl font-semibold">
      <%= tabler_icon("table-import", classes: "h-6 w-6 text-indigo-600") %>
      <span>Activity Import Preview</span>
    </h2>
  </div>
<% end %>

<div class="mx-auto max-w-5xl space-y-6">
  <section class="ta-card">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <h3 class="text-lg font-semibold text-slate-900">Review before importing</h3>
        <p class="mt-1 text-sm leading-6 text-slate-600"><%= @preview[:original_filename].presence || "Uploaded CSV" %> has been parsed into a temporary preview. No account activity rows have been saved yet.</p>
      </div>
      <%= link_to new_account_account_activity_import_path(@account), class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "ta-action-icon text-slate-600") %>
        <span>Choose Another File</span>
      <% end %>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-4">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Rows</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:rows_count].to_i %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Importable</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:imported_count].to_i %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Duplicates</p>
        <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @preview[:duplicate_count].to_i %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Direction</p>
        <p class="mt-2 break-words text-sm font-semibold text-slate-900"><%= @preview[:amount_strategy].to_s.humanize %></p>
      </div>
    </div>

    <% if @preview[:institution_balance].present? %>
      <div class="mt-5 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm leading-6 text-indigo-950">
        <p class="font-semibold text-slate-900">Institution balance found</p>
        <p class="mt-1">
          <%= @preview[:institution_name].presence || @account.institution_name.presence || @account.name %>
          reported <span class="font-semibold"><%= number_to_currency(@preview[:institution_balance]) %></span><%= @preview[:institution_balance_as_of].present? ? " on #{l(Date.parse(@preview[:institution_balance_as_of].to_s), format: :long)}" : "" %>.
          This will become the trusted current account balance after import.
        </p>
      </div>
    <% else %>
      <div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-950">
        <p class="font-semibold text-slate-900">Activity-only import</p>
        <p class="mt-1">This file did not include a reported institution balance. Imported rows will be saved first, but the account needs an existing manual snapshot or future institution balance before those rows can resolve a displayed balance.</p>
      </div>
    <% end %>
  </section>

  <% if Array(@preview[:errors]).any? %>
    <section class="rounded-2xl border border-rose-200 bg-rose-50 p-5 text-sm text-rose-900">
      <p class="font-semibold">Fix these row errors before importing</p>
      <ul class="mt-3 list-disc space-y-1 pl-5">
        <% Array(@preview[:errors]).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <p class="mt-3 text-rose-800">No data was changed.</p>
    </section>
  <% end %>

  <% if Array(@preview[:warnings]).any? %>
    <section class="rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-900">
      <p class="font-semibold">Warnings</p>
      <ul class="mt-3 list-disc space-y-1 pl-5">
        <% Array(@preview[:warnings]).each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if Array(@preview[:sample_rows]).any? %>
    <section class="ta-card">
      <div class="mb-4">
        <h3 class="text-base font-semibold text-slate-900">Sample rows</h3>
      </div>

      <div class="overflow-x-auto">
        <table class="ta-table">
          <thead class="ta-table-head">
            <tr>
              <th class="ta-th">Date</th>
              <th class="ta-th">Description</th>
              <th class="ta-th">Category</th>
              <th class="ta-th">Type</th>
              <th class="ta-th text-right">Amount</th>
              <th class="ta-th text-right">Impact</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @preview[:sample_rows].each do |row| %>
              <tr>
                <td class="ta-td"><%= row[:transaction_on] %></td>
                <td class="ta-td"><%= row[:description] %></td>
                <td class="ta-td"><%= row[:category].presence || "-" %></td>
                <td class="ta-td"><%= row[:activity_type].presence || "-" %></td>
                <td class="ta-td text-right"><%= number_to_currency(row[:amount]) %></td>
                <td class="ta-td text-right <%= row[:account_delta].to_d >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
                  <%= row[:account_delta].to_d >= 0 ? "+" : "" %><%= number_to_currency(row[:account_delta]) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>

  <% if @preview[:ok] %>
    <section class="ta-card">
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <h3 class="text-base font-semibold text-slate-900">Ready to import</h3>
          <% if @preview[:institution_balance].present? %>
            <p class="mt-1 text-sm leading-6 text-slate-600">Import runs after this confirmation. The saved rows update the account activity views, duplicates stay skipped, and the institution-reported account balance becomes the balance source shown on the account.</p>
          <% else %>
            <p class="mt-1 text-sm leading-6 text-slate-600">Import runs after this confirmation. The saved rows update account activity first; balances use those rows when this account has a trusted snapshot or institution balance to start from.</p>
          <% end %>
        </div>
        <%= form_with url: account_account_activity_imports_path(@account),
                      method: :post,
                      class: "w-full space-y-3 md:w-auto",
                      data: {
                        controller: "turbo-submit",
                        action: "submit->turbo-submit#submitStart turbo:submit-start->turbo-submit#submitStart turbo:submit-end->turbo-submit#submitEnd",
                        turbo_submit_default_label_value: "Import Activity",
                        turbo_submit_pending_label_value: "Importing activity..."
                      } do %>
          <%= hidden_field_tag :preview_token, @preview_token %>
          <div class="hidden rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm leading-6 text-indigo-950 md:w-80" data-turbo-submit-target="status" aria-live="polite" aria-hidden="true">
            <div class="flex items-start gap-3">
              <%= tabler_icon("loader-2", classes: "mt-0.5 h-4 w-4 animate-spin text-indigo-700") %>
              <div>
                <p class="font-semibold text-slate-900">Import submitted</p>
                <p>Rows are being saved and account balances will refresh from the best available trusted source when the import completes.</p>
              </div>
            </div>
          </div>
          <%= button_tag type: :submit,
                         class: "fb-btn-primary ta-action-btn justify-center",
                         data: { turbo_submit_target: "submitButton" } do %>
            <span class="hidden" data-turbo-submit-target="submitSpinner" aria-hidden="true">
              <%= tabler_icon("loader-2", classes: "ta-action-icon animate-spin") %>
            </span>
            <span data-turbo-submit-target="submitLabel">Import Activity</span>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
