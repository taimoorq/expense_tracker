<%= form_with url: theme_path, method: :patch, class: "ta-theme-picker", data: { turbo: false } do |form| %>
  <label for="theme-picker-select" class="sr-only">Color scheme</label>
  <div class="ta-theme-picker-shell">
    <div class="ta-theme-picker-field">
      <span class="ta-theme-picker-icon"><%= tabler_icon("adjustments", classes: "ta-action-icon") %></span>
      <%= form.select :theme,
                      options_for_select(available_theme_options, current_theme.key),
                      {},
                      {
                        id: "theme-picker-select",
                        class: "fb-select ta-theme-picker-select",
                        onchange: "this.form.requestSubmit()"
                      } %>
    </div>

    <div class="ta-theme-swatches" aria-label="<%= "#{current_theme.name} palette" %>">
      <% current_theme_colors.each_with_index do |color, index| %>
        <span class="ta-theme-swatch" style="background-color: <%= color %>" title="<%= "#{current_theme.name} color #{index + 1}: #{color}" %>"></span>
      <% end %>
    </div>
  </div>
<% end %>
