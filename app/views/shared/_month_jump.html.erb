<% months = month_jump_options %>
<div
  class="relative w-full sm:w-auto sm:max-w-[17rem] lg:max-w-[19rem]"
  data-controller="month-jump"
  data-month-jump-months-value="<%= json_escape(months.to_json) %>"
  data-action="click@window->month-jump#closeFromOutside"
>
  <form class="relative" role="search" data-action="submit->month-jump#submit">
    <label for="global-month-jump" class="sr-only">Jump to month</label>
    <div class="flex cursor-text items-center gap-2 rounded-2xl border border-slate-200 bg-white/90 px-3 py-2 shadow-sm shadow-slate-200/70 ring-1 ring-white/60 backdrop-blur" data-action="click->month-jump#activate">
      <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 sm:h-9 sm:w-9">
        <%= tabler_icon("search", classes: "h-4 w-4") %>
      </span>
      <div class="min-w-0 flex-1">
        <input
          id="global-month-jump"
          type="text"
          autocomplete="off"
          placeholder="<%= months.any? ? "Month or year" : "No months yet" %>"
          class="w-full border-0 bg-transparent px-0 py-0 text-sm font-medium text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-0"
          <%= "disabled" if months.empty? %>
          data-month-jump-target="input"
          data-action="focus->month-jump#open input->month-jump#search keydown->month-jump#keydown"
        >
        <p class="hidden text-xs text-slate-500 sm:block"><%= months.any? ? "Type a month name or year" : "Create a month to unlock quick jump" %></p>
      </div>
      <button type="submit" class="inline-flex rounded-xl bg-slate-900 px-2.5 py-2 text-xs font-semibold text-white transition hover:bg-slate-700 sm:px-3" data-month-jump-target="submitButton">
        Go
      </button>
    </div>
  </form>

  <div
    class="absolute left-0 right-0 top-[calc(100%+0.5rem)] z-40 hidden overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl shadow-slate-900/10"
    data-month-jump-target="panel"
  >
    <div class="border-b border-slate-100 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
      Matching months
    </div>
    <div class="max-h-72 overflow-y-auto py-2" data-month-jump-target="results"></div>
    <div class="hidden px-4 py-4 text-sm text-slate-500" data-month-jump-target="emptyState">
      No saved months match that search.
    </div>
  </div>
</div>
