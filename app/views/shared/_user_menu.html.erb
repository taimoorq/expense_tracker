<div class="ta-user-menu" data-controller="user-menu" data-action="click@window->user-menu#closeFromOutside keydown.esc->user-menu#closeOnEsc">
  <button
    type="button"
    class="ta-sidebar-link ta-user-menu-button"
    aria-label="Open profile menu"
    aria-expanded="false"
    data-user-menu-target="button"
    data-action="click->user-menu#toggle"
  >
    <span class="flex min-w-0 items-center gap-3">
      <%= tabler_icon("user-circle", classes: "ta-sidebar-link-icon") %>
      <span class="min-w-0 text-left">
        <span class="ta-user-menu-title">Profile</span>
        <span class="ta-user-menu-email block truncate text-xs"><%= current_user.email %></span>
      </span>
    </span>
    <%= tabler_icon("chevron-right", classes: "ta-user-menu-email h-4 w-4 shrink-0") %>
  </button>

  <div
    class="ta-user-menu-panel hidden"
    data-user-menu-target="menu"
  >
    <div class="ta-user-menu-header">
      <p class="ta-user-menu-eyebrow">Signed in as</p>
      <p class="ta-user-menu-account"><%= current_user.email %></p>
    </div>

    <div class="p-2">
      <%= link_to profile_path, class: "ta-user-menu-action" do %>
        <span class="ta-user-menu-action-icon">
          <%= tabler_icon("user-circle", classes: "h-4 w-4") %>
        </span>
        <span class="flex-1">Profile</span>
      <% end %>

      <%= button_to destroy_user_session_path, method: :delete, class: "ta-user-menu-action ta-user-menu-action-danger mt-1" do %>
        <span class="ta-user-menu-action-icon">
          <%= tabler_icon("logout", classes: "h-4 w-4") %>
        </span>
        <span class="flex-1">Sign out</span>
      <% end %>
    </div>
  </div>
</div>
