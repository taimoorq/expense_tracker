<div data-help-modal-target="backdrop" class="ta-dialog-backdrop hidden" data-action="click->help-modal#backdropClick keydown@window->help-modal#trapFocus">
  <div class="ta-dialog max-w-2xl" role="dialog" aria-modal="true" aria-labelledby="help-modal-title" aria-describedby="help-modal-content" tabindex="-1" data-help-modal-target="dialog">
    <div class="ta-dialog-header">
      <div class="ta-ledger-rail">
        <p class="ta-page-eyebrow">In-context guidance</p>
        <h2 id="help-modal-title" class="ta-dialog-title" data-help-modal-target="title">Help</h2>
      </div>
      <button type="button" class="ta-icon-btn" aria-label="Close help" data-help-modal-target="closeButton" data-action="click->help-modal#close">
        <%= tabler_icon("x", classes: "h-4 w-4") %>
      </button>
    </div>
    <div class="ta-dialog-body">
      <p id="help-modal-content" class="whitespace-pre-line text-sm leading-7" data-help-modal-target="content"></p>
    </div>
  </div>
</div>
