<%= turbo_frame_tag "subscriptions_section" do %>
  <% anchored_return_to = return_to.presence || planning_templates_path(anchor: "subscriptions") %>
  <% action_params = budget_month ? { budget_month_id: budget_month.id } : { return_to: anchored_return_to } %>
  <% show_collapsible_form = !budget_month && !subscription.persisted? %>
  <% form_open = budget_month || subscription.persisted? || subscription.errors.any? %>
  <section id="subscriptions" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center gap-2">
      <h3 class="inline-flex items-center gap-2 text-lg font-semibold">
        <%= tabler_icon("repeat", classes: "h-5 w-5 text-indigo-600") %>
        <span><%= budget_month ? "2) Subscriptions (monthly, no end date)" : "Subscriptions" %></span>
      </h3>
      <button type="button" class="ta-icon-btn" aria-label="Subscriptions Help" title="Subscriptions Help" data-action="click->help-modal#open" data-help-title="Subscriptions Help" data-help-body="For recurring monthly items with no fixed end date.

Amount: expected monthly amount.
Due day: day of month this usually charges.
    Keep Active checked unless this subscription has been cancelled."><%= tabler_icon("help", classes: "ta-action-icon") %></button>
    </div>
    <p class="mb-3 text-sm text-slate-500">Use for Netflix, phone plans, cloud storage, and other recurring charges.</p>
    <% if !budget_month && subscription.persisted? %>
      <div class="mb-3 flex items-center justify-between gap-3 rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm text-indigo-950">
        <span>Editing <span class="font-semibold"><%= subscription.name %></span></span>
        <%= link_to "Cancel", planning_templates_path(anchor: "subscriptions"), class: "font-semibold text-indigo-700 hover:text-indigo-900" %>
      </div>
    <% end %>
    <% if show_collapsible_form %>
      <details class="group mb-3 rounded-xl border border-dashed border-slate-300 bg-slate-50" <%= "open" if form_open %>>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-xl px-4 py-3 hover:bg-slate-100">
          <div>
            <p class="text-sm font-semibold text-slate-800">
              <span class="group-open:hidden inline-flex items-center gap-2">
                <%= tabler_icon("plus", classes: "h-4 w-4 text-emerald-600") %>
                <span>Add Subscription</span>
              </span>
              <span class="hidden group-open:inline-flex items-center gap-2">
                <%= tabler_icon("eye-off", classes: "h-4 w-4 text-slate-600") %>
                <span>Hide Subscription Form</span>
              </span>
            </p>
            <p class="text-xs text-slate-500">
              <span class="group-open:hidden">Click to open the new subscription form.</span>
              <span class="hidden group-open:inline">The new subscription form is open below.</span>
            </p>
          </div>
          <span class="flex h-9 w-9 items-center justify-center rounded-full border border-slate-300 bg-white text-slate-600 transition group-open:rotate-180 group-open:border-slate-900 group-open:text-slate-900">
            <%= tabler_icon("chevron-down", classes: "h-4 w-4") %>
          </span>
        </summary>
    <% end %>
    <%= form_with model: subscription, class: "mt-3 grid gap-3 md:grid-cols-2 xl:grid-cols-7" do |form| %>
      <% if budget_month %>
        <%= hidden_field_tag :budget_month_id, budget_month.id %>
      <% elsif return_to.present? %>
        <%= hidden_field_tag :return_to, anchored_return_to %>
      <% end %>
      <div>
        <%= form.label :name, class: "fb-label" %>
        <%= form.text_field :name, placeholder: "Netflix, Google Fi...", required: true, class: "fb-input" %>
      </div>
      <div>
        <%= form.label :amount, class: "fb-label" %>
        <%= form.number_field :amount, step: 0.01, placeholder: "0.00", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Expected monthly charge before any taxes or fees change.</p>
      </div>
      <div>
        <%= form.label :due_day, "Due Day", class: "fb-label" %>
        <%= form.number_field :due_day, min: 1, max: 31, placeholder: "1", required: true, class: "fb-input" %>
        <p class="mt-1 text-xs text-slate-500">Day of the month this usually charges.</p>
      </div>
      <div>
        <%= form.label :linked_account_id, "Linked Account", class: "fb-label" %>
        <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select account (optional)" }, class: "fb-select" %>
      </div>
      <div>
        <%= form.label :account, "Manual Account Label", class: "fb-label" %>
        <%= form.text_field :account, placeholder: "Credit Card (optional)", class: "fb-input" %>
      </div>
      <div>
        <%= form.label :notes, class: "fb-label" %>
        <%= form.text_field :notes, placeholder: "Optional notes", class: "fb-input" %>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, checked: true, class: "fb-checkbox" %> Active</label>
        <% if budget_month %>
          <%= form.submit "Save", class: "fb-btn-primary" %>
        <% else %>
          <%= form.button type: :submit, class: "fb-btn-primary ta-action-btn" do %>
            <%= tabler_icon(subscription.persisted? ? "pencil" : "save", classes: "ta-action-icon") %>
            <span><%= subscription.persisted? ? "Update Subscription" : "Save" %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <% if show_collapsible_form %>
      </details>
    <% end %>

    <% if budget_month %>
      <div class="mt-3">
        <%= button_to "Add Subscriptions to #{budget_month.label}", generate_subscriptions_budget_month_path(budget_month), method: :post, class: "rounded-md bg-slate-800 px-3 py-2 text-white hover:bg-slate-700" %>
      </div>
    <% end %>

    <div class="mt-4 space-y-3 md:hidden">
      <% subscriptions.each do |item| %>
        <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-sm font-semibold text-slate-900"><%= item.name %></p>
              <p class="mt-1 text-xs text-slate-500">Due day <%= item.due_day %></p>
              <% if item.account_name.present? %>
                <p class="mt-1 text-xs text-slate-500">Paid from <%= item.account_name %></p>
              <% end %>
            </div>
            <span class="rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-slate-600"><%= number_to_currency(item.amount) %></span>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            <% if budget_month %>
              <%= button_to subscription_path(item, action_params), method: :delete, class: "fb-btn-danger ta-action-btn !px-3 !py-2 !text-sm", form: { data: { turbo_confirm: "Delete this subscription?" } } do %>
                <%= tabler_icon("trash", classes: "ta-action-icon text-rose-600") %>
                <span>Delete</span>
              <% end %>
            <% else %>
              <%= link_to edit_subscription_planning_templates_path(item, anchor: "subscriptions"), class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm" do %>
                <%= tabler_icon("pencil", classes: "ta-action-icon text-slate-600") %>
                <span>Edit</span>
              <% end %>
              <%= button_to subscription_path(item, action_params), method: :delete, class: "fb-btn-danger ta-action-btn !px-3 !py-2 !text-sm", form: { data: { turbo_confirm: "Delete this subscription?" } } do %>
                <%= tabler_icon("trash", classes: "ta-action-icon text-rose-600") %>
                <span>Delete</span>
              <% end %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>

    <div class="mt-4 hidden overflow-x-auto md:block">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Name</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Amount</th>
            <th class="px-3 py-2 text-right font-medium text-slate-600">Due Day</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Account</th>
            <th class="px-3 py-2 text-left font-medium text-slate-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% subscriptions.each do |item| %>
            <tr>
              <td class="px-3 py-2"><%= item.name %></td>
              <td class="px-3 py-2 text-right"><%= number_to_currency(item.amount) %></td>
              <td class="px-3 py-2 text-right"><%= item.due_day %></td>
              <td class="px-3 py-2"><%= item.account_name.presence || "—" %></td>
              <td class="px-3 py-2">
                <% if budget_month %>
                  <%= button_to "Delete", subscription_path(item, action_params), method: :delete, class: "rounded-md border border-rose-300 px-2 py-1 text-rose-700 hover:bg-rose-50", form: { data: { turbo_confirm: "Delete this subscription?" } } %>
                <% else %>
                  <div class="flex items-center gap-2">
                    <%= link_to edit_subscription_planning_templates_path(item, anchor: "subscriptions"), class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs", title: "Edit subscription", aria: { label: "Edit subscription" } do %>
                      <%= tabler_icon("pencil", classes: "ta-action-icon-sm text-slate-600") %>
                    <% end %>
                    <%= button_to subscription_path(item, action_params), method: :delete, class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs", title: "Delete subscription", aria: { label: "Delete subscription" }, form: { data: { turbo_confirm: "Delete this subscription?" } } do %>
                      <%= tabler_icon("trash", classes: "ta-action-icon-sm text-rose-600") %>
                    <% end %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
