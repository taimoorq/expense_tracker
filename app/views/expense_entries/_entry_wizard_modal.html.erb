<%= turbo_frame_tag "entry_wizard_modal" do %>
  <% wizard = entry_wizard_presenter(budget_month: budget_month, expense_entry: expense_entry) %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/50 p-4" data-controller="template-modal" data-template-modal-allow-backdrop-close-value="false" data-action="keydown.esc@window->template-modal#close">
    <div class="w-full max-w-3xl rounded-xl border border-slate-200 bg-white p-4 shadow-xl flex flex-col max-h-[90vh]" data-template-modal-target="dialog">
      <div class="overflow-y-auto flex-1">
        <div class="mb-4 flex items-center justify-between gap-3">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-violet-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-violet-800">
              <%= tabler_icon("adjustments", classes: "h-3.5 w-3.5") %>
              <span>Guided entry flow</span>
            </div>
            <h3 class="mt-3 ta-section-title">Add Entry with Wizard</h3>
            <p class="ta-muted mt-1">This saves directly into <span class="font-semibold text-slate-700"><%= budget_month.label %></span> and can optionally create a recurring transaction while you enter it.</p>
          </div>
          <button type="button" class="ta-icon-btn" aria-label="Close entry wizard" title="Close" data-action="click->template-modal#close">
            <%= tabler_icon("x", classes: "h-4 w-4 text-slate-500") %>
          </button>
        </div>

      <%= form_with model: [budget_month, expense_entry], data: { controller: "entry-wizard entry-preview", action: "submit->entry-wizard#validateSubmit turbo:submit-start->entry-wizard#submitStart turbo:submit-end->entry-wizard#submitEnd" }, class: "space-y-4" do |form| %>
        <%= hidden_field_tag :wizard_flow, "1" %>

        <%= render "expense_entries/entry_wizard_progress", wizard_steps: wizard.wizard_steps %>

        <div class="flex items-center justify-between gap-3 border-b border-slate-200 pb-3">
          <div data-entry-wizard-target="error" class="hidden rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
        </div>

        <% if expense_entry.errors.any? %>
          <div class="rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700">
            <%= expense_entry.errors.full_messages.join(", ") %>
          </div>
        <% end %>

        <%= render "expense_entries/entry_wizard_step_one", form: form %>

        <%= render "expense_entries/entry_wizard_step_two",
            form: form,
            selected_recurring_link: wizard.selected_recurring_link %>

        <%= render "expense_entries/entry_wizard_step_three", form: form %>

        <%= render "expense_entries/entry_wizard_review_step",
            budget_month: budget_month,
            wizard: wizard %>

        <%= render "expense_entries/entry_wizard_footer", form: form %>
      <% end %>
    </div>
  </div>
<% end %>
