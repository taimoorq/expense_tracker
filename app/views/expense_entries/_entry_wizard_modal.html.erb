<%= turbo_frame_tag "entry_wizard_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/50 p-4" data-controller="template-modal" data-action="keydown.esc@window->template-modal#close click->template-modal#backdropClose">
    <div class="w-full max-w-3xl rounded-xl border border-slate-200 bg-white p-4 shadow-xl">
      <div class="mb-4 flex items-center justify-between gap-3">
        <div>
          <h3 class="ta-section-title inline-flex items-center gap-2"><%= tabler_icon("adjustments", classes: "h-4 w-4 text-violet-600") %> Add Entry with Wizard</h3>
          <p class="ta-muted mt-1">A guided flow for adding expenses or income step by step.</p>
        </div>
        <button type="button" class="ta-icon-btn" aria-label="Close entry wizard" title="Close" data-action="click->template-modal#close">
          <%= tabler_icon("x", classes: "h-4 w-4 text-slate-500") %>
        </button>
      </div>

      <%= form_with model: [budget_month, expense_entry], data: { controller: "entry-wizard entry-preview" }, class: "space-y-4" do |form| %>
        <%= hidden_field_tag :wizard_flow, "1" %>

        <div class="flex items-center justify-between gap-3 border-b border-slate-200 pb-3">
          <div class="text-sm font-medium text-slate-700" data-entry-wizard-target="progress"></div>
          <div data-entry-wizard-target="error" class="hidden rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>
        </div>

        <% if expense_entry.errors.any? %>
          <div class="rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-700">
            <%= expense_entry.errors.full_messages.join(", ") %>
          </div>
        <% end %>

        <section data-entry-wizard-target="step" class="space-y-4">
          <div>
            <h4 class="text-lg font-semibold text-slate-900">1. What kind of entry is this?</h4>
            <p class="ta-muted mt-1">Choose the broad type first. This helps organize timeline and reporting.</p>
          </div>

          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            <% [
              ["Income", "income", "cash", "text-emerald-600"],
              ["Recurring Bill", "fixed", "repeat", "text-sky-600"],
              ["Flexible Spending", "variable", "list", "text-amber-600"],
              ["Debt Payment", "debt", "chart-bar", "text-rose-600"],
              ["Manual Adjustment", "manual", "adjustments", "text-violet-600"],
              ["Auto / Vehicle", "auto", "calendar-plus", "text-slate-600"]
            ].each do |label, value, icon, color_class| %>
              <button type="button" class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-left transition hover:border-indigo-300 hover:bg-indigo-50" data-action="click->entry-wizard#chooseSection" data-section-value="<%= value %>">
                <div class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900">
                  <%= tabler_icon(icon, classes: "h-4 w-4 #{color_class}") %>
                  <span><%= label %></span>
                </div>
                <p class="mt-1 text-xs text-slate-500">Sets the section for this entry.</p>
              </button>
            <% end %>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            <div>
              <%= form.label :section, class: "fb-label" %>
              <%= form.select :section, ExpenseEntry.sections.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select", data: { entry_wizard_target: "section", action: "change->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :status, class: "fb-label" %>
              <%= form.select :status, ExpenseEntry.statuses.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select", data: { entry_wizard_target: "status", action: "change->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :need_or_want, "Need / Want", class: "fb-label" %>
              <%= form.select :need_or_want, [["Need", "Need"], ["Want", "Want"], ["Leave blank", ""]], {}, class: "fb-select", data: { entry_wizard_target: "need", action: "change->entry-wizard#updateSummary" } %>
            </div>
          </div>
        </section>

        <section data-entry-wizard-target="step" class="hidden space-y-4">
          <div>
            <h4 class="text-lg font-semibold text-slate-900">2. Who is it for and what is it?</h4>
            <p class="ta-muted mt-1">Add the payee/source, category, and account details.</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <%= form.label :category, class: "fb-label" %>
              <%= form.text_field :category, class: "fb-input", placeholder: "Groceries, Rent, Paycheck...", data: { entry_wizard_target: "category", action: "input->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :payee, class: "fb-label" %>
              <%= form.text_field :payee, class: "fb-input", placeholder: "Vendor or source", data: { entry_wizard_target: "payee", action: "input->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :account, class: "fb-label" %>
              <%= form.text_field :account, class: "fb-input", placeholder: "Checking, Card, Savings...", data: { entry_wizard_target: "account", action: "input->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :notes, class: "fb-label" %>
              <%= form.text_field :notes, class: "fb-input", placeholder: "Optional details", data: { entry_wizard_target: "notes", action: "input->entry-wizard#updateSummary" } %>
            </div>
          </div>
        </section>

        <section data-entry-wizard-target="step" class="hidden space-y-4">
          <div>
            <h4 class="text-lg font-semibold text-slate-900">3. When and how much?</h4>
            <p class="ta-muted mt-1">Add the date and at least one amount.</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            <div>
              <%= form.label :occurred_on, "Date", class: "fb-label" %>
              <%= form.date_field :occurred_on, class: "fb-input", data: { entry_wizard_target: "date", action: "change->entry-wizard#updateSummary" } %>
            </div>
            <div>
              <%= form.label :planned_amount, class: "fb-label" %>
              <%= form.number_field :planned_amount, step: 0.01, class: "fb-input", placeholder: "0.00", data: { entry_wizard_target: "planned", action: "input->entry-preview#update input->entry-wizard#updateSummary", entry_preview_target: "planned" } %>
            </div>
            <div>
              <%= form.label :actual_amount, class: "fb-label" %>
              <%= form.number_field :actual_amount, step: 0.01, class: "fb-input", placeholder: "0.00", data: { entry_wizard_target: "actual", action: "input->entry-preview#update input->entry-wizard#updateSummary", entry_preview_target: "actual" } %>
            </div>
          </div>

          <div class="rounded-lg bg-slate-100 px-4 py-3 text-sm text-slate-700">
            Effective amount: <span class="ml-1 font-semibold" data-entry-preview-target="effective">$0.00</span>
          </div>
        </section>

        <section data-entry-wizard-target="step" class="hidden space-y-4">
          <div>
            <h4 class="text-lg font-semibold text-slate-900">4. Review before saving</h4>
            <p class="ta-muted mt-1">Confirm the details below, then save your entry.</p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Type</p>
              <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summarySection">Not set</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Category / Payee / Account</p>
              <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryWho">Not set</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Date</p>
              <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryWhen">Not set</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Amounts</p>
              <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryAmounts">Planned: $0.00 • Actual: $0.00</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:col-span-2">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Notes</p>
              <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryNotes">No notes</p>
            </div>
          </div>
        </section>

        <div class="flex items-center justify-between gap-3 border-t border-slate-200 pt-4">
          <div class="flex items-center gap-2">
            <button type="button" class="fb-btn-secondary hidden" data-entry-wizard-target="backButton" data-action="click->entry-wizard#back">Back</button>
            <button type="button" class="fb-btn-secondary" data-action="click->template-modal#close">Cancel</button>
          </div>
          <div class="flex items-center gap-2">
            <button type="button" class="fb-btn-secondary" data-entry-wizard-target="nextButton" data-action="click->entry-wizard#next">Next</button>
            <%= form.submit "Save Entry", class: "fb-btn-primary hidden", data: { entry_wizard_target: "submitButton" } %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
