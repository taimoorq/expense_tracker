<tr id="<%= dom_id(entry) %>">
  <td class="px-3 py-2"><%= entry.occurred_on %></td>
  <td class="px-3 py-2"><%= entry.section.humanize %></td>
  <td class="px-3 py-2"><%= entry.category %></td>
  <td class="px-3 py-2"><%= entry.payee %></td>
  <td class="px-3 py-2 text-right"><%= number_to_currency(entry.planned_amount || 0) %></td>
  <td class="px-3 py-2 text-right"><%= number_to_currency(entry.actual_amount || 0) %></td>
  <td class="px-3 py-2"><%= entry.status.humanize %></td>
  <td class="px-3 py-2">
    <div class="flex items-center gap-2">
      <%= link_to edit_budget_month_expense_entry_path(budget_month, entry),
                  data: { turbo_frame: "entry_editor_modal" },
                  class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                  title: "Edit entry",
                  aria: { label: "Edit entry" } do %>
        <%= tabler_icon("pencil", classes: "h-4 w-4 text-indigo-600") %>
      <% end %>
      <%= button_to budget_month_expense_entry_path(budget_month, entry),
                    method: :delete,
                    class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                    title: "Delete entry",
                    aria: { label: "Delete entry" },
                    form: { data: { turbo_confirm: "Delete this entry?" } } do %>
        <%= tabler_icon("trash", classes: "h-4 w-4 text-rose-600") %>
      <% end %>
    </div>
  </td>
</tr>
