<%= turbo_frame_tag "template_editor_modal" do %>
  <div class="ta-dialog-backdrop" data-controller="template-modal" data-action="keydown.esc@window->template-modal#close keydown@window->template-modal#trapFocus click->template-modal#backdropClose">
    <div class="ta-dialog max-w-2xl" role="dialog" aria-modal="true" aria-labelledby="template-editor-title" tabindex="-1" data-template-modal-target="dialog">
      <% submit_state_data = {
        controller: "turbo-submit",
        action: "turbo:submit-start->turbo-submit#submitStart turbo:submit-end->turbo-submit#submitEnd",
        turbo_submit_default_label_value: "Save",
        turbo_submit_pending_label_value: "Saving recurring item..."
      } %>
      <div class="ta-dialog-header">
        <div class="ta-ledger-rail">
          <p class="ta-page-eyebrow">Future months</p>
          <h3 id="template-editor-title" class="ta-dialog-title inline-flex items-center gap-2"><%= tabler_icon("file-pencil", classes: "h-5 w-5 text-violet-600") %> Edit Recurring: <%= template_record.class.model_name.human %></h3>
          <p class="ta-dialog-description">Changes update the reusable recurring item. This month’s entry remains its own record.</p>
        </div>
        <button type="button" class="ta-icon-btn" aria-label="Close recurring editor" title="Close" data-modal-initial-focus data-action="click->template-modal#close">
          <%= tabler_icon("x", classes: "h-4 w-4") %>
        </button>
      </div>

      <div class="ta-dialog-body">
        <% if template_record.errors.any? %>
          <div class="ta-alert-danger mb-4" role="alert">
            <p class="font-semibold">Review the following before saving:</p>
            <p class="mt-1"><%= template_record.errors.full_messages.join(", ") %></p>
          </div>
        <% end %>

      <% if template_record.is_a?(PaySchedule) %>
        <%= form_with model: template_record, url: update_template_budget_month_expense_entry_path(budget_month, expense_entry), method: :patch, class: "grid gap-3 sm:grid-cols-2", data: submit_state_data do |form| %>
          <%= form.text_field :name, placeholder: "Employer/Source", required: true, class: "fb-input" %>
          <%= form.select :cadence, pay_schedule_cadence_options, {}, class: "fb-select" %>
          <%= form.number_field :amount, step: 0.01, required: true, class: "fb-input" %>
          <%= form.date_field :first_pay_on, required: true, class: "fb-input" %>
          <%= form.date_field :ends_on, class: "fb-input", placeholder: "Last pay date (optional)" %>
          <%= form.number_field :day_of_month_one, class: "fb-input", placeholder: "Day #1" %>
          <%= form.number_field :day_of_month_two, class: "fb-input", placeholder: "Day #2" %>
          <%= form.select :weekend_adjustment, PaySchedule.weekend_adjustments.keys.map { |key| [key.humanize, key] }, {}, class: "fb-select" %>
          <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select account where money arrives (optional)" }, class: "fb-select" %>
          <%= form.text_field :account, class: "fb-input", placeholder: "Manual account label (optional)" %>
          <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, class: "fb-checkbox" %> Active</label>
          <%= render "expense_entries/template_editor_actions", form: form %>
        <% end %>
      <% elsif template_record.is_a?(Subscription) %>
        <%= form_with model: template_record, url: update_template_budget_month_expense_entry_path(budget_month, expense_entry), method: :patch, class: "grid gap-3 sm:grid-cols-2", data: submit_state_data do |form| %>
          <%= form.text_field :name, required: true, class: "fb-input", placeholder: "Subscription name" %>
          <%= form.number_field :amount, step: 0.01, required: true, class: "fb-input", placeholder: "Amount" %>
          <%= form.number_field :due_day, min: 1, max: 31, required: true, class: "fb-input", placeholder: "Due day" %>
          <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select money leaves account (optional)" }, class: "fb-select" %>
          <%= form.text_field :account, class: "fb-input", placeholder: "Manual account label (optional)" %>
          <div class="sm:col-span-2"><%= form.text_field :notes, class: "fb-input", placeholder: "Notes" %></div>
          <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, class: "fb-checkbox" %> Active</label>
          <%= render "expense_entries/template_editor_actions", form: form %>
        <% end %>
      <% elsif template_record.is_a?(MonthlyBill) %>
        <%= form_with model: template_record, url: update_template_budget_month_expense_entry_path(budget_month, expense_entry), method: :patch, class: "grid gap-3 sm:grid-cols-2", data: submit_state_data do |form| %>
          <%= form.text_field :name, required: true, class: "fb-input", placeholder: "Bill name" %>
          <%= form.select :kind, monthly_bill_kind_options, {}, class: "fb-select" %>
          <%= form.number_field :default_amount, step: 0.01, class: "fb-input", placeholder: "Default amount" %>
          <%= form.number_field :due_day, min: 1, max: 31, required: true, class: "fb-input", placeholder: "Due day" %>
          <%= form.select :billing_frequency, billing_frequency_options, {}, class: "fb-select" %>
          <div class="sm:col-span-2">
            <span class="fb-label">Billing Months</span>
            <%= hidden_field_tag "monthly_bill[billing_months][]", "" %>
            <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
              <% calendar_month_options.each do |label, value| %>
                <label class="flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700">
                  <%= check_box_tag "monthly_bill[billing_months][]", value, template_record.billing_months.include?(value), class: "fb-checkbox" %>
                  <span><%= label %></span>
                </label>
              <% end %>
            </div>
          </div>
          <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select money leaves account (optional)" }, class: "fb-select" %>
          <%= form.text_field :account, class: "fb-input", placeholder: "Manual account label (optional)" %>
          <div class="sm:col-span-2"><%= form.text_field :notes, class: "fb-input", placeholder: "Notes" %></div>
          <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, class: "fb-checkbox" %> Active</label>
          <%= render "expense_entries/template_editor_actions", form: form %>
        <% end %>
      <% elsif template_record.is_a?(PaymentPlan) %>
        <%= form_with model: template_record, url: update_template_budget_month_expense_entry_path(budget_month, expense_entry), method: :patch, class: "grid gap-3 sm:grid-cols-2", data: submit_state_data do |form| %>
          <%= form.text_field :name, required: true, class: "fb-input", placeholder: "Plan name" %>
          <%= form.number_field :total_due, step: 0.01, required: true, class: "fb-input", placeholder: "Total due" %>
          <%= form.number_field :amount_paid, step: 0.01, class: "fb-input", placeholder: "Amount paid" %>
          <%= form.number_field :monthly_target, step: 0.01, class: "fb-input", placeholder: "Monthly target" %>
          <%= form.number_field :due_day, min: 1, max: 31, required: true, class: "fb-input", placeholder: "Due day" %>
          <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select money leaves account (optional)" }, class: "fb-select" %>
          <%= form.text_field :account, class: "fb-input", placeholder: "Manual account label (optional)" %>
          <div class="sm:col-span-2"><%= form.text_field :notes, class: "fb-input", placeholder: "Notes" %></div>
          <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, class: "fb-checkbox" %> Active</label>
          <%= render "expense_entries/template_editor_actions", form: form %>
        <% end %>
      <% elsif template_record.is_a?(CreditCard) %>
        <%= form_with model: template_record, url: update_template_budget_month_expense_entry_path(budget_month, expense_entry), method: :patch, class: "grid gap-3 sm:grid-cols-2", data: submit_state_data do |form| %>
          <%= form.text_field :name, required: true, class: "fb-input", placeholder: "Card name" %>
          <%= form.number_field :minimum_payment, step: 0.01, class: "fb-input", placeholder: "Minimum payment" %>
          <%= form.number_field :due_day, min: 1, max: 31, required: true, class: "fb-input", placeholder: "Due day" %>
          <%= form.number_field :priority, min: 1, required: true, class: "fb-input", placeholder: "Priority" %>
          <div>
            <%= form.label :linked_account_id, "Card being paid down", class: "fb-label" %>
            <%= form.collection_select :linked_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select card account (optional)" }, class: "fb-select" %>
          </div>
          <div>
            <%= form.label :payment_account_id, "Money leaves account", class: "fb-label" %>
            <%= form.collection_select :payment_account_id, current_user.accounts.active_first, :id, :name, { include_blank: "Select payment account (optional)" }, class: "fb-select" %>
          </div>
          <%= form.text_field :account, class: "fb-input", placeholder: "Manual account label (optional)" %>
          <div class="sm:col-span-2"><%= form.text_field :notes, class: "fb-input", placeholder: "Notes" %></div>
          <label class="flex items-center gap-2 text-sm"><%= form.check_box :active, class: "fb-checkbox" %> Active</label>
          <%= render "expense_entries/template_editor_actions", form: form %>
        <% end %>
      <% else %>
        <p class="ta-muted">No editable recurring item found for this entry.</p>
        <div class="mt-3 flex justify-end">
          <button type="button" class="fb-btn-secondary" data-action="click->template-modal#close">Close</button>
        </div>
      <% end %>
      </div>
    </div>
  </div>
<% end %>
