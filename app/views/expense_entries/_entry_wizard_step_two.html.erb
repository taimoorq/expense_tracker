<section data-entry-wizard-target="step" class="hidden space-y-4">
  <div>
    <h4 class="text-lg font-semibold text-slate-900">2. Who is it for and what is it?</h4>
    <p class="ta-muted mt-1">Name the item in plain language so it is easy to recognize later.</p>
  </div>

  <div class="rounded-2xl border border-indigo-100 bg-indigo-50/70 px-4 py-3">
    <p class="text-sm font-semibold text-slate-900">Account flow examples</p>
    <div class="mt-3 grid gap-3 text-xs leading-5 text-slate-600 md:grid-cols-3">
      <div>
        <p class="font-semibold text-slate-900">Income</p>
        <p>Choose the account where money arrives. Leave Money goes to blank.</p>
      </div>
      <div>
        <p class="font-semibold text-slate-900">Spending</p>
        <p>Choose the card, checking, or cash account used for the purchase.</p>
      </div>
      <div>
        <p class="font-semibold text-slate-900">Card payment</p>
        <p>Money leaves checking. Money goes to the card being paid down.</p>
      </div>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <div>
      <%= form.label :category, class: "fb-label" %>
      <%= form.text_field :category, class: "fb-input", placeholder: "Groceries, mortgage, paycheck...", data: { entry_wizard_target: "category", action: "input->entry-wizard#updateSummary" } %>
    </div>
    <div>
      <%= form.label :payee, "Payee or source", class: "fb-label" %>
      <%= form.text_field :payee, class: "fb-input", placeholder: "Who you paid, or who paid you", data: { entry_wizard_target: "payee", action: "input->entry-wizard#updateSummary" } %>
    </div>
    <div>
      <%= form.label :source_account_id, "Money leaves / activity account", class: "fb-label" %>
      <%= form.collection_select :source_account_id,
                                 current_user.accounts.active_first,
                                 :id,
                                 :name,
                                 { include_blank: "Select where this happens" },
                                 class: "fb-select",
                                 data: { entry_wizard_target: "sourceAccount", action: "change->entry-wizard#syncAccountLabel change->entry-wizard#updateSummary" } %>
      <p class="mt-1 text-xs text-slate-500">For income, choose where money arrives. For spending, choose where the money leaves or card charges are added.</p>
      <% if current_user.accounts.active_first.any? %>
        <div class="mt-2 flex flex-wrap gap-2">
          <% current_user.accounts.active_first.each do |account| %>
            <button type="button"
                    class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700 transition hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700"
                    data-action="click->entry-wizard#chooseSourceAccount"
                    data-account-id-value="<%= account.id %>"
                    data-account-value="<%= account.name %>">
              <%= account.name %>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
    <div>
      <%= form.label :destination_account_id, "Money goes to", class: "fb-label" %>
      <%= form.collection_select :destination_account_id,
                                 current_user.accounts.active_first,
                                 :id,
                                 :name,
                                 { include_blank: "Only for transfers or card payments" },
                                 class: "fb-select",
                                 data: { entry_wizard_target: "destinationAccount", action: "change->entry-wizard#updateSummary" } %>
      <p class="mt-1 text-xs text-slate-500">Use this when the entry pays down or funds another account, like checking paying a credit card.</p>
    </div>
    <div>
      <%= form.label :account, "Manual account label", class: "fb-label" %>
      <%= form.text_field :account,
                          class: "fb-input",
                          placeholder: "Optional fallback label",
                          autocomplete: "off",
                          data: { entry_wizard_target: "account", action: "input->entry-wizard#updateSummary" } %>
      <p class="mt-1 text-xs text-slate-500">Use only when you want a label that is not one of your saved accounts.</p>
    </div>
    <div>
      <%= form.label :notes, class: "fb-label" %>
      <%= form.text_field :notes, class: "fb-input", placeholder: "Optional details", data: { entry_wizard_target: "notes", action: "input->entry-wizard#updateSummary" } %>
    </div>
    <div class="sm:col-span-2">
      <label for="recurring_link" class="fb-label">Connect to an existing recurring item</label>
      <%= select_tag :recurring_link,
                     grouped_options_for_select(recurring_link_options, selected_recurring_link),
                     include_blank: "No recurring link",
                     class: "fb-select",
                     id: "recurring_link",
                     data: { entry_wizard_target: "recurringLink", action: "change->entry-wizard#updateSummary" } %>
      <p class="mt-1 text-xs text-slate-500">Use this for an extra payment, off-schedule charge, or manual variation tied to something you already track.</p>
    </div>
  </div>
</section>
