<div class="mx-auto max-w-3xl space-y-4">
  <% content_for :page_header do %>
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-2xl font-semibold">Edit Entry</h2>
      <%= link_to budget_month_path(@budget_month), class: "fb-btn-secondary ta-action-btn" do %>
        <%= tabler_icon("arrow-left", classes: "h-4 w-4 text-slate-600") %>
        <span>Back to Month</span>
      <% end %>
    </div>
  <% end %>

  <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <%= form_with model: [@budget_month, @expense_entry], class: "grid gap-3 sm:grid-cols-2" do |form| %>
      <%= render "expense_entries/edit_fields", form: form, notes_input: :text_area, notes_rows: 4, notes_wrapper_class: "sm:col-span-2" %>
      <%= render "expense_entries/edit_actions",
                 form: form,
                 expense_entry: @expense_entry,
                 wrapper_class: "sm:col-span-2 flex items-center gap-2",
                 mark_paid_class: "fb-btn-secondary ta-action-btn",
                 submit_label: "Update Entry",
                 submit_class: "fb-btn-primary",
                 cancel_button: false,
                 cancel_label: "Cancel",
                 cancel_path: budget_month_path(@budget_month),
                 cancel_class: "fb-btn-secondary",
                 cancel_options: {} %>
    <% end %>
  </section>
</div>
