<tr id="<%= dom_id(expense_entry) %>" class="bg-indigo-50/40">
  <td colspan="9" class="px-3 py-2">
    <%= form_with model: [budget_month, expense_entry], class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-4" do |form| %>
      <%= render "expense_entries/edit_fields", form: form, notes_input: :text_field, notes_rows: nil, notes_wrapper_class: "" %>
      <%= render "expense_entries/edit_actions",
                 form: form,
                 expense_entry: expense_entry,
                 wrapper_class: "flex items-center gap-2",
                 mark_paid_class: "fb-btn-secondary",
                 submit_label: "Save",
                 submit_class: "fb-btn-primary",
                 cancel_button: false,
                 cancel_label: "Cancel",
                 cancel_path: budget_month_expense_entry_path(budget_month, expense_entry),
                 cancel_class: "fb-btn-secondary",
                 cancel_options: { data: { turbo_stream: true } } %>
    <% end %>

    <% if expense_entry.errors.any? %>
      <p class="mt-2 text-sm text-rose-700"><%= expense_entry.errors.full_messages.join(", ") %></p>
    <% end %>
  </td>
</tr>
