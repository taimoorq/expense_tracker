<% reason_for_entry = entry.category.presence || entry.section.humanize %>
<% selected_review = local_assigns[:selected_review] %>
<article id="mobile_<%= dom_id(entry) %>"
         class="ta-ledger-row ta-ledger-rail bg-white"
         data-expense-entries-filter-target="row"
         data-date="<%= entry.occurred_on&.iso8601 %>"
         data-payee="<%= entry.payee.to_s %>"
         data-reason="<%= reason_for_entry.to_s %>"
         data-value="<%= reason_for_entry.to_s.downcase %>"
         data-account="<%= entry.account_name.to_s %>"
         data-status="<%= entry.status %>">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="truncate text-sm font-semibold text-slate-900"><%= entry.payee.presence || entry.category.presence || entry.section.humanize %></p>
      <p class="mt-1 text-xs text-slate-500"><%= entry.occurred_on || "No date" %> · <%= entry.section.humanize %><% if entry.account_name.present? %> · <%= entry.account_name %><% end %></p>
    </div>
    <span class="ta-status-badge bg-slate-100 text-slate-700"><%= entry.status.humanize %></span>
  </div>

  <dl class="mt-4 grid grid-cols-2 divide-x divide-slate-200 border-y border-slate-200 py-3">
    <div class="pr-3"><dt class="ta-ledger-label">Planned</dt><dd class="ta-money mt-1 text-sm font-semibold text-slate-900"><%= number_to_currency(entry.planned_amount || 0) %></dd></div>
    <div class="pl-3"><dt class="ta-ledger-label">Actual</dt><dd class="ta-money mt-1 text-sm font-semibold text-slate-900"><%= entry.actual_amount.present? ? number_to_currency(entry.actual_amount) : "Not set" %></dd></div>
  </dl>

  <div class="mt-3 flex flex-wrap gap-2">
    <% unless entry.paid? %>
      <%= button_to budget_month_expense_entry_path(budget_month, entry), method: :patch, params: { mark_as_paid: "1", timeline_view: timeline_view, review: selected_review, expense_entry: { actual_amount: entry.actual_amount.presence || entry.planned_amount } }, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", title: "Mark as paid", aria: { label: "Mark as paid" } do %>
        <%= tabler_icon("check-circle", classes: "h-4 w-4 text-emerald-600") %><span>Mark Paid</span>
      <% end %>
    <% end %>
    <%= link_to edit_budget_month_expense_entry_path(budget_month, entry, timeline_view: timeline_view, review: selected_review), data: { turbo_frame: "entry_editor_modal" }, class: "fb-btn-secondary ta-action-btn !px-3 !py-2 !text-sm", title: "Edit entry", aria: { label: "Edit entry" } do %>
      <%= tabler_icon("pencil", classes: "h-4 w-4 text-indigo-600") %><span>Edit</span>
    <% end %>
    <%= button_to budget_month_expense_entry_path(budget_month, entry), method: :delete, params: { timeline_view: timeline_view, review: selected_review }, class: "fb-btn-danger ta-action-btn !px-3 !py-2 !text-sm", title: "Delete entry", aria: { label: "Delete entry" }, form: { data: { turbo_confirm: "Delete this entry?" } } do %>
      <%= tabler_icon("trash", classes: "h-4 w-4 text-rose-600") %><span>Delete</span>
    <% end %>
  </div>
</article>
