<div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
  <div class="flex items-center justify-between gap-3">
    <div class="text-sm font-medium text-slate-700" data-entry-wizard-target="progress"></div>
    <div class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-sm">
      <%= pluralize(wizard_steps.length, "step") %>
    </div>
  </div>
  <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-200">
    <div class="h-full rounded-full bg-gradient-to-r from-indigo-500 via-violet-500 to-sky-500 transition-all duration-300" style="width: 25%" data-entry-wizard-target="progressBar"></div>
  </div>
  <div class="mt-4 grid gap-2 md:grid-cols-4">
    <% wizard_steps.each do |step| %>
      <div class="rounded-2xl border border-slate-200 bg-white px-3 py-3 text-slate-500 transition-all" data-entry-wizard-target="stepIndicator">
        <div class="text-[11px] font-semibold uppercase tracking-[0.18em]">Step <%= step[:number] %></div>
        <div class="mt-1 text-sm font-semibold"><%= step[:title] %></div>
        <div class="mt-1 text-xs leading-5"><%= step[:description] %></div>
      </div>
    <% end %>
  </div>
</div>
