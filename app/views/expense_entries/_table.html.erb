<%= turbo_frame_tag "entries_table" do %>
  <% show_header = local_assigns.fetch(:show_header, true) %>
  <% wrapper_classes = local_assigns.fetch(:wrapper_classes, "ta-card") %>
  <section class="<%= wrapper_classes %>">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
      <% if show_header %>
        <div>
          <h3 class="ta-section-title inline-flex items-center gap-2"><%= tabler_icon("list") %> Full Month List</h3>
          <p class="mt-1 text-sm text-slate-500">Everything currently planned or recorded for this month, with quick actions for editing and status updates after reviewing the guidance above.</p>
        </div>
      <% end %>
    </div>
    <%= render "expense_entries/table_content", budget_month: budget_month, expense_entries: expense_entries %>
  </section>
<% end %>
