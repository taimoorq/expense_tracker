<div>
  <%= form.label :occurred_on, "Date", class: "fb-label" %>
  <%= form.date_field :occurred_on, class: "fb-input" %>
</div>

<div>
  <%= form.label :section, class: "fb-label" %>
  <%= form.select :section, expense_entry_section_options, {}, class: "fb-select" %>
</div>

<div>
  <%= form.label :category, class: "fb-label" %>
  <%= form.text_field :category, class: "fb-input" %>
</div>

<div>
  <%= form.label :payee, class: "fb-label" %>
  <%= form.text_field :payee, class: "fb-input" %>
</div>

<div>
  <%= form.label :planned_amount, class: "fb-label" %>
  <%= form.number_field :planned_amount, step: 0.01, class: "fb-input" %>
</div>

<div>
  <%= form.label :actual_amount, class: "fb-label" %>
  <%= form.number_field :actual_amount, step: 0.01, class: "fb-input" %>
</div>

<div>
  <%= form.label :source_account_id, "Money leaves / activity account", class: "fb-label" %>
  <%= form.collection_select :source_account_id,
                             current_user.accounts.active_first,
                             :id,
                             :name,
                             { include_blank: "Select where this happens (optional)" },
                             class: "fb-select" %>
  <p class="mt-1 text-xs text-slate-500">For income, this is where money arrives. For spending or charges, this is where money leaves or where the charge is added.</p>
</div>

<div>
  <%= form.label :destination_account_id, "Money goes to", class: "fb-label" %>
  <%= form.collection_select :destination_account_id,
                             current_user.accounts.active_first,
                             :id,
                             :name,
                             { include_blank: "Only for transfers or card payments" },
                             class: "fb-select" %>
  <p class="mt-1 text-xs text-slate-500">Use this when one account pays down or funds another, such as checking paying a credit card.</p>
</div>

<div>
  <% account_options_list_id = "expense-entry-account-options-#{form.object.id || form.object.object_id}" %>
  <%= form.label :account, "Manual account label", class: "fb-label" %>
  <%= form.text_field :account,
                      class: "fb-input",
                      list: account_options_list_id,
                      placeholder: "Optional fallback label" %>
  <datalist id="<%= account_options_list_id %>">
    <% active_account_names.each do |account_name| %>
      <option value="<%= account_name %>"></option>
    <% end %>
  </datalist>
</div>

<div>
  <%= form.label :status, class: "fb-label" %>
  <%= form.select :status, expense_entry_status_options, {}, class: "fb-select" %>
</div>

<div>
  <%= form.label :need_or_want, "Need / Want", class: "fb-label" %>
  <%= form.text_field :need_or_want, class: "fb-input" %>
</div>

<div class="<%= notes_wrapper_class %>">
  <%= form.label :notes, class: "fb-label" %>
  <% if notes_input == :text_area %>
    <%= form.text_area :notes, rows: notes_rows, class: "fb-textarea" %>
  <% else %>
    <%= form.text_field :notes, class: "fb-input" %>
  <% end %>
</div>
