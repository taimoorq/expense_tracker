<% timeline_view = local_assigns[:timeline_view] %>
<% selected_review = local_assigns[:selected_review] %>

<div class="space-y-3 md:hidden">
  <% expense_entries.each do |entry| %>
    <%= render "expense_entries/mobile_entry_card", entry: entry, budget_month: budget_month, timeline_view: timeline_view, selected_review: selected_review %>
  <% end %>
</div>

<div class="hidden overflow-x-auto md:block">
  <table class="ta-table" data-controller="sortable-table">
    <thead class="ta-table-head">
      <tr>
        <%= sortable_table_header("Date", key: "date", type: "date") %>
        <%= sortable_table_header("Section", key: "section") %>
        <%= sortable_table_header("Category", key: "category") %>
        <%= sortable_table_header("Payee", key: "payee") %>
        <%= sortable_table_header("Account", key: "account", classes: "hidden lg:table-cell") %>
        <%= sortable_table_header("Planned", key: "planned", type: "number", classes: "text-right") %>
        <%= sortable_table_header("Actual", key: "actual", type: "number", classes: "text-right") %>
        <%= sortable_table_header("Status", key: "status") %>
        <th class="ta-th">Action</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% expense_entries.each do |entry| %>
        <%= render "expense_entries/row", budget_month: budget_month, entry: entry, timeline_view: timeline_view, selected_review: selected_review %>
      <% end %>
    </tbody>
  </table>
</div>
