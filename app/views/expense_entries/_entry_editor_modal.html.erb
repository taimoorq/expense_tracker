<%= turbo_frame_tag "entry_editor_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/50 p-4" data-controller="template-modal" data-action="keydown.esc@window->template-modal#close click->template-modal#backdropClose">
    <div class="w-full max-w-3xl rounded-xl border border-slate-200 bg-white p-4 shadow-xl flex flex-col max-h-[90vh]">
      <div class="overflow-y-auto flex-1">
      <div class="mb-4 flex items-center justify-between">
        <h3 class="ta-section-title inline-flex items-center gap-2"><%= tabler_icon("pencil", classes: "h-4 w-4 text-indigo-600") %> Edit Entry</h3>
        <button type="button" class="ta-icon-btn" aria-label="Close entry editor" title="Close" data-action="click->template-modal#close">
          <%= tabler_icon("x", classes: "h-4 w-4 text-slate-500") %>
        </button>
      </div>

      <%= form_with model: [budget_month, expense_entry], class: "grid gap-3 sm:grid-cols-2" do |form| %>
        <%= render "expense_entries/edit_fields", form: form, notes_input: :text_area, notes_rows: 4, notes_wrapper_class: "sm:col-span-2" %>
        <%= render "expense_entries/edit_actions",
                   form: form,
                   expense_entry: expense_entry,
                   wrapper_class: "sm:col-span-2 flex items-center justify-end gap-2",
                   mark_paid_class: "fb-btn-secondary ta-action-btn",
                   submit_label: "Update Entry",
                   submit_class: "fb-btn-primary",
                   cancel_button: true,
                   cancel_label: "Cancel",
                   cancel_class: "fb-btn-secondary",
                   cancel_action: "click->template-modal#close",
                   cancel_path: nil,
                   cancel_options: {} %>
      <% end %>
    </div>
  </div>
<% end %>
