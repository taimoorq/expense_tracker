<%= turbo_frame_tag "timeline_section" do %>
  <% timeline_leftover = local_assigns[:budget_month]&.calculated_leftover || expense_entries.sum(&:cashflow_amount) %>
  <% default_timeline_view = local_assigns[:default_timeline_view].presence_in(%w[sections full-list calendar]) || "sections" %>
  <% reason_for_entry = ->(entry) { entry.category.presence || entry.section.humanize } %>
  <% reason_pills = expense_entries.filter_map { |entry| reason_for_entry.call(entry).to_s.strip.presence }
                    .tally
                    .sort_by { |reason, count| [-count, reason.downcase] }
                    .first(8) %>
  <% timeline_view_urls = {
    sections: budget_month_tab_path(budget_month, "timeline"),
    "full-list": budget_month_tab_path(budget_month, "timeline", view: "full-list"),
    calendar: budget_month_tab_path(budget_month, "calendar")
  } %>
  <section class="ta-card ta-surface-timeline" data-controller="collapsible-groups expense-entries-filter" data-collapsible-groups-storage-key-value="timeline-groups-<%= budget_month.id %>" style="view-transition-name: month-budget-shell; view-transition-class: ta-vt-shell;">
    <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
      <div>
        <h3 class="ta-section-title inline-flex items-center gap-2"><%= tabler_icon("timeline") %> Budget</h3>
        <p class="mt-1 text-sm text-slate-500">Switch between grouped entries, a flat month list, or calendar view.</p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <div class="ta-tab-list" role="tablist" aria-label="Budget view mode" style="view-transition-name: month-budget-tabs; view-transition-class: ta-vt-nav;">
          <%= link_to timeline_view_urls[:sections], class: ["ta-tab", ("ta-tab-active" if default_timeline_view == "sections")], role: "tab", "aria-selected": (default_timeline_view == "sections").to_s, "aria-label": "Grouped", data: { turbo_frame: "_top" } do %>
            <span class="inline-flex items-center gap-2"><%= tabler_icon("rectangle-group", classes: "ta-tab-icon") %><span class="hidden sm:inline">Grouped</span></span>
          <% end %>
          <%= link_to timeline_view_urls[:"full-list"], class: ["ta-tab", ("ta-tab-active" if default_timeline_view == "full-list")], role: "tab", "aria-selected": (default_timeline_view == "full-list").to_s, "aria-label": "Full List", data: { turbo_frame: "_top" } do %>
            <span class="inline-flex items-center gap-2"><%= tabler_icon("list-bullet", classes: "ta-tab-icon") %><span class="hidden sm:inline">Full List</span></span>
          <% end %>
          <%= link_to timeline_view_urls[:calendar], class: ["ta-tab", ("ta-tab-active" if default_timeline_view == "calendar")], role: "tab", "aria-selected": (default_timeline_view == "calendar").to_s, "aria-label": "Calendar", data: { turbo_frame: "_top" } do %>
            <span class="inline-flex items-center gap-2"><%= tabler_icon("calendar-month", classes: "ta-tab-icon") %><span class="hidden sm:inline">Calendar</span></span>
          <% end %>
        </div>

        <%= link_to new_wizard_budget_month_expense_entries_path(budget_month, timeline_view: default_timeline_view), class: "fb-btn-primary ta-action-btn", data: { turbo_frame: "entry_wizard_modal" }, title: "Add Entry with Wizard", aria: { label: "Add Entry with Wizard" } do %>
          <%= tabler_icon("plus", classes: "h-4 w-4") %>
          <span class="hidden sm:inline">Add Entry with Wizard</span>
        <% end %>
      </div>
    </div>

    <%= render "expense_entries/filters", reason_pills: reason_pills, id_prefix: "timeline" %>

    <% ordered_entries = expense_entries.sort_by { |entry| [entry.occurred_on || Date.new(9999, 12, 31), entry.created_at] } %>
    <% remaining_entries = ordered_entries.dup %>
    <% template_sources = %w[pay_schedule subscription monthly_bill payment_plan credit_card_estimate] %>

    <% group_rules = [
      ["Income & Paychecks", ->(entry) { entry.income? || entry.source_file == "pay_schedule" || entry.category.to_s.downcase.include?("paycheck") }],
      ["Payment Plans", ->(entry) { entry.source_file == "payment_plan" || entry.category.to_s.downcase.include?("payment plan") }],
      ["Credit Card Payments", ->(entry) { entry.source_file == "credit_card_estimate" || entry.category.to_s.downcase.include?("credit card") }],
      ["Recurring Subscriptions", ->(entry) { entry.source_file == "subscription" || entry.category.to_s.downcase.include?("subscription") }],
      ["Monthly Fixed Bills", ->(entry) { entry.source_file == "monthly_bill" && entry.category.to_s.downcase.include?("monthly payment") }],
      ["Monthly Variable Bills", ->(entry) { entry.source_file == "monthly_bill" && entry.category.to_s.downcase.include?("variable") }]
    ] %>

    <% grouped_entries = [] %>
    <% group_rules.each do |group_name, matcher| %>
      <% matches, remaining_entries = remaining_entries.partition { |entry| matcher.call(entry) } %>
      <% grouped_entries << [group_name, matches] if matches.any? %>
    <% end %>

    <% grouped_entries << ["Other", remaining_entries] if remaining_entries.any? %>

    <div data-panel-name="sections" role="tabpanel" class="<%= default_timeline_view == "sections" ? "space-y-4" : "hidden space-y-4" %>" <%= %(style="view-transition-name: month-budget-panel; view-transition-class: ta-vt-panel;") if default_timeline_view == "sections" %>>
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <button type="button" class="fb-btn-secondary ta-action-btn" data-action="click->collapsible-groups#expandAll">
        <%= tabler_icon("chevron-down", classes: "h-4 w-4 text-slate-600") %>
        <span>Expand all</span>
      </button>
      <button type="button" class="fb-btn-secondary ta-action-btn" data-action="click->collapsible-groups#collapseAll">
        <%= tabler_icon("chevron-up", classes: "h-4 w-4 text-slate-600") %>
        <span>Collapse all</span>
      </button>
    </div>
    <% if grouped_entries.any? %>
      <div class="space-y-4">
        <% grouped_entries.each_with_index do |(group_name, entries), index| %>
          <% group_total = entries.sum(&:cashflow_amount) %>
          <% show_reason_column = (group_name == "Other") %>
          <details class="rounded-lg border border-slate-200 bg-white" data-collapsible-groups-target="group" data-expense-entries-filter-target="group" data-group-id="<%= group_name.parameterize %>" style="view-transition-name: timeline-group-<%= group_name.parameterize %>; view-transition-class: ta-vt-card;" <%= "open" if index.zero? %>>
            <summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-2 bg-slate-50 px-3 py-2 marker:content-none [&::-webkit-details-marker]:hidden">
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-slate-800">
                <%= tabler_icon("list") %>
                <%= group_name %>
              </span>
              <div class="flex items-center gap-3 text-xs sm:text-sm">
                <span class="rounded-full bg-slate-200 px-2 py-0.5 font-medium text-slate-600" data-expense-entries-filter-target="groupCount"><%= pluralize(entries.count, "item") %></span>
                <span class="font-semibold <%= group_total >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
                  Net: <%= group_total >= 0 ? "+" : "" %><%= number_to_currency(group_total) %>
                </span>
                <span class="rounded bg-slate-200 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-slate-600">
                  Toggle
                </span>
              </div>
            </summary>

            <div class="overflow-x-auto border-t border-slate-200">
              <table class="ta-table">
                <thead class="bg-white">
                  <tr>
                    <th class="ta-th">Date</th>
                    <th class="ta-th">Payee</th>
                    <th class="ta-th hidden lg:table-cell">Account</th>
                    <% if show_reason_column %>
                      <th class="ta-th">Reason</th>
                    <% end %>
                    <th class="ta-th">Status</th>
                    <th class="ta-th text-right">Impact</th>
                    <th class="ta-th text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% entries.each do |entry| %>
                    <% impact = entry.cashflow_amount %>
                    <% generated_from_template = template_sources.include?(entry.source_file.to_s) %>
                    <% variable_payment_entry = entry.source_file.in?(["payment_plan", "credit_card_estimate"]) %>
                    <tr
                      data-expense-entries-filter-target="row"
                      data-date="<%= entry.occurred_on&.iso8601 %>"
                      data-payee="<%= entry.payee.to_s %>"
                      data-reason="<%= reason_for_entry.call(entry).to_s %>"
                      data-value="<%= reason_for_entry.call(entry).to_s.downcase %>"
                      data-status="<%= entry.status %>"
                      style="view-transition-name: timeline-entry-<%= dom_id(entry) %>; view-transition-class: ta-vt-row;">
                      <td class="px-3 py-2"><%= entry.occurred_on || "—" %></td>
                      <td class="px-3 py-2">
                        <div>
                          <div><%= entry.payee.presence || "—" %></div>
                          <% if variable_payment_entry %>
                            <p class="mt-1 text-xs text-slate-500">Amount/date may change month to month.</p>
                          <% end %>
                        </div>
                      </td>
                      <td class="px-3 py-2 hidden lg:table-cell"><%= entry.account_name.presence || "—" %></td>
                      <% if show_reason_column %>
                        <td class="px-3 py-2"><%= reason_for_entry.call(entry) %></td>
                      <% end %>
                      <td class="px-3 py-2"><span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-700"><%= entry.status.humanize %></span></td>
                      <td class="px-3 py-2 text-right <%= impact >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
                        <div>
                          <div><%= impact >= 0 ? "+" : "" %><%= number_to_currency(impact) %></div>
                          <% if variable_payment_entry %>
                            <p class="mt-1 text-xs font-medium text-slate-500">
                              Planned <%= number_to_currency(entry.planned_amount || 0) %>
                              <% if entry.actual_amount.present? %>
                                · Actual <%= number_to_currency(entry.actual_amount) %>
                              <% else %>
                                · Actual not set
                              <% end %>
                            </p>
                          <% end %>
                        </div>
                      </td>
                      <td class="px-3 py-2">
                        <div class="flex justify-end gap-2">
                          <% unless entry.paid? %>
                            <%= button_to budget_month_expense_entry_path(entry.budget_month, entry),
                                          method: :patch,
                                          params: {
                                            mark_as_paid: "1",
                                            timeline_view: default_timeline_view,
                                            expense_entry: {
                                              actual_amount: entry.actual_amount.presence || entry.planned_amount
                                            }
                                          },
                                          class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                          title: "Mark as paid",
                                          aria: { label: "Mark as paid" } do %>
                              <%= tabler_icon("check-circle", classes: "h-4 w-4 text-emerald-600") %>
                            <% end %>
                          <% end %>

                          <%= link_to edit_budget_month_expense_entry_path(entry.budget_month, entry, timeline_view: default_timeline_view),
                                      class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                      title: "Edit entry",
                                      aria: { label: "Edit entry" },
                                      data: { turbo_frame: "entry_editor_modal" } do %>
                            <%= tabler_icon("pencil", classes: "h-4 w-4 text-indigo-600") %>
                            <% if variable_payment_entry %>
                              <span>Edit</span>
                            <% end %>
                          <% end %>

                          <%= button_to budget_month_expense_entry_path(entry.budget_month, entry),
                                        method: :delete,
                                        params: { timeline_view: default_timeline_view },
                                        class: "fb-btn-danger ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                        title: "Delete entry",
                                        aria: { label: "Delete entry" },
                                        form: { data: { turbo_confirm: "Delete this entry?" } } do %>
                            <%= tabler_icon("trash", classes: "h-4 w-4 text-rose-600") %>
                          <% end %>

                          <% if generated_from_template %>
                            <%= link_to edit_template_budget_month_expense_entry_path(entry.budget_month, entry),
                                        class: "fb-btn-secondary ta-action-btn !px-2.5 !py-1.5 !text-xs",
                                        title: "Edit recurring item",
                                        aria: { label: "Edit recurring item" },
                                        data: { turbo_frame: "template_editor_modal" } do %>
                              <%= tabler_icon("file-pencil", classes: "h-4 w-4 text-violet-600") %>
                              <span>Template</span>
                            <% end %>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </details>
        <% end %>
      </div>
      <p class="hidden rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-500" data-expense-entries-filter-target="empty">No matching groups for the selected filters.</p>
    <% else %>
      <div class="rounded-[22px] border border-dashed border-slate-300 bg-slate-50/80 p-6 text-center">
        <p class="ta-muted">No entries for this month yet.</p>
        <div class="mt-4 flex justify-center">
          <%= link_to new_wizard_budget_month_expense_entries_path(budget_month, timeline_view: default_timeline_view), class: "fb-btn-primary ta-action-btn", data: { turbo_frame: "entry_wizard_modal" }, title: "Add First Entry with Wizard", aria: { label: "Add First Entry with Wizard" } do %>
            <%= tabler_icon("plus", classes: "h-4 w-4") %>
            <span class="hidden sm:inline">Add First Entry with Wizard</span>
          <% end %>
        </div>
      </div>
    <% end %>
    </div>

    <div data-panel-name="full-list" role="tabpanel" class="<%= default_timeline_view == "full-list" ? "space-y-4" : "hidden space-y-4" %>" <%= %(style="view-transition-name: month-budget-panel; view-transition-class: ta-vt-panel;") if default_timeline_view == "full-list" %>>
      <%= render "expense_entries/table", budget_month: budget_month, expense_entries: expense_entries, show_header: false, wrapper_classes: "rounded-[22px] border border-slate-200 bg-white/85 p-4", timeline_view: default_timeline_view %>
    </div>

    <div data-panel-name="calendar" role="tabpanel" class="<%= default_timeline_view == "calendar" ? "space-y-4" : "hidden space-y-4" %>" <%= %(style="view-transition-name: month-budget-panel; view-transition-class: ta-vt-panel;") if default_timeline_view == "calendar" %>>
      <div class="ta-surface-calendar">
        <%= render "expense_entries/calendar_grid", budget_month: budget_month, expense_entries: expense_entries %>
      </div>
    </div>

    <div class="mt-4 border-t border-slate-200 pt-3">
      <div class="flex items-center justify-end gap-3 text-sm">
        <span class="font-medium text-slate-600">Leftover</span>
        <span class="text-base font-semibold <%= timeline_leftover >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
          <%= number_to_currency(timeline_leftover) %>
        </span>
      </div>
    </div>
  </section>
<% end %>
