<section data-entry-wizard-target="step" class="hidden space-y-4">
  <div>
    <h4 class="text-lg font-semibold text-slate-900">4. Review before saving</h4>
    <p class="ta-muted mt-1">Confirm the details below, then save your entry.</p>
  </div>

  <div class="rounded-2xl border border-indigo-100 bg-indigo-50/70 px-4 py-3 text-sm text-slate-700">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="font-semibold text-slate-900">Final check before this lands in <%= budget_month.label %></p>
        <p class="mt-1 text-xs leading-5 text-slate-600">Review the entry details below. If "Save as recurring" is enabled, the recurring transaction will reuse the payee/source plus the account and notes from this entry.</p>
      </div>
      <div class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-indigo-700 shadow-sm">
        Optional recurring save
      </div>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Type</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summarySection">Not set</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Category / Payee / Account</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryWho">Not set</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Date</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryWhen">Not set</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Amounts</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryAmounts">Planned: $0.00 • Actual: $0.00</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:col-span-2">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Notes</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryNotes">No notes</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:col-span-2">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Recurring Link</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryRecurring">No recurring link</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:col-span-2">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Reuse This Later</p>
          <p class="mt-1 text-sm text-slate-600">Optionally save this wizard entry as a recurring transaction for future months.</p>
        </div>
        <label class="flex items-center gap-2 text-sm font-medium text-slate-900">
          <%= hidden_field_tag "planning_template[enabled]", "0" %>
          <%= check_box_tag "planning_template[enabled]", "1", wizard.template_enabled?, class: "fb-checkbox", data: { entry_wizard_target: "templateEnabled", action: "change->entry-wizard#toggleTemplateFields change->entry-wizard#updateSummary" } %>
          Save as recurring
        </label>
      </div>

      <%= render "expense_entries/entry_wizard_recurring_fields", wizard: wizard %>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 sm:col-span-2">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Recurring Save Summary</p>
      <p class="mt-1 text-sm text-slate-900" data-entry-wizard-target="summaryTemplate">One-off entry only</p>
    </div>
  </div>
</section>
