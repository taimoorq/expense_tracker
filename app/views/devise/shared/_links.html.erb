<div class="space-y-3">
  <% if controller_name != "sessions" %>
    <div>
      <%= link_to "Log in", new_session_path(resource_name), class: "ta-auth-link" %>
    </div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <div>
      <%= link_to "Sign up", new_registration_path(resource_name), class: "ta-auth-link" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div>
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "ta-auth-link" %>
    </div>
  <% end %>
</div>