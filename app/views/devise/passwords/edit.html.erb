<% content_for :title, "Choose a new password" %>

<div class="space-y-6">
  <div class="rounded-2xl border border-fuchsia-100 bg-fuchsia-50/70 p-4 text-sm leading-6 text-fuchsia-900">
    Your reset link is active. Enter a new password below to regain access to your account.
  </div>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |form| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= form.hidden_field :reset_password_token %>

    <div>
      <%= form.label :password, class: "fb-label" %>
      <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400"><%= tabler_icon("lock", classes: "h-4 w-4") %></span>
        <%= form.password_field :password, autofocus: true, autocomplete: "new-password", class: "ta-auth-input pl-11", placeholder: "New password" %>
      </div>
    </div>

    <div>
      <%= form.label :password_confirmation, class: "fb-label" %>
      <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400"><%= tabler_icon("shield-lock", classes: "h-4 w-4") %></span>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "ta-auth-input pl-11", placeholder: "Confirm new password" %>
      </div>
    </div>

    <%= form.button type: :submit, class: "ta-auth-submit from-fuchsia-600 to-violet-600 hover:from-fuchsia-500 hover:to-violet-500" do %>
      <%= tabler_icon("shield-lock", classes: "h-4 w-4") %>
      <span>Change my password</span>
    <% end %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>