# Copy to .env.production for a public self-hosted deployment.
# Example:
#   cp .env.production.example .env.production

APP_HOST=budget.example.com
APP_PROTOCOL=https
ALLOWED_HOSTS=budget.example.com

RAILS_ENV=production
RAILS_LOG_LEVEL=info
RAILS_MASTER_KEY=replace-with-your-master-key
SECRET_KEY_BASE=replace-with-a-long-random-secret

# Optional: pin or override the prebuilt app image used by docker-compose.production.yml.
# Use a version tag for repeatable deploys.
# GHCR example: ghcr.io/taimoorq/expense_tracker:v0.7.1
# Docker Hub example: docker.io/<dockerhub-username>/expense-tracker:v0.7.1
EXPENSE_TRACKER_IMAGE=ghcr.io/taimoorq/expense_tracker:latest

# Set both to false when running over HTTP (e.g. LAN without HTTPS).
# Cookies and redirects will work over plain HTTP.
ASSUME_SSL=true
FORCE_SSL=true

# Optional Cloudflare Turnstile protection for Devise sign-in/sign-up/reset flows.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

POSTGRES_DB=expense_tracker_production
POSTGRES_USER=expense_tracker
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgres://expense_tracker:replace-with-a-strong-password@db:5432/expense_tracker_production
