# Copy this file to .env for local development or local Docker overrides.
# Example:
#   cp .env.example .env

# Docker host port override
APP_PORT=4287

# Local Rails server port
PORT=3000

# Puma / Active Record thread pool size
RAILS_MAX_THREADS=5

# Optional local PostgreSQL connection string.
# Uncomment and adjust if you prefer an explicit TCP connection instead of the
# default local socket-based PostgreSQL setup in config/database.yml.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/expense_tracker_development

# Optional seed overrides for the demo user created by bin/rails db:seed
SEED_USER_EMAIL=demo@example.com
SEED_USER_PASSWORD=password123!

# Optional production/self-hosted setting used when running jobs inside Puma.
# Not typically needed for local development.
# SOLID_QUEUE_IN_PUMA=true